{
  "name": "giannacrisha-digital-garden",
  "type": "module",
  "version": "0.0.1",
  "scripts": {
    "dev": "astro dev",
    "start": "astro dev",
    "build": "astro build && pagefind --site .vercel/output/static && node scripts/copy-pagefind.mjs",
    "preview": "astro preview",
    "astro": "astro",
    "check": "astro check",
    "sync": "node scripts/sync-content.mjs",
    "format": "prettier --write \"src/**/*.{astro,ts,css,md}\" \"scripts/**/*.mjs\"",
    "test": "vitest run"
  },
  "dependencies": {
    "@astrojs/mdx": "^4.3.14",
    "@astrojs/rss": "^4.0.18",
    "@astrojs/sitemap": "^3.7.3",
    "@astrojs/vercel": "^9.0.5",
    "@fontsource/iosevka": "^5.2.5",
    "@hackernoon/pixel-icon-library": "^1.1.0",
    "@mux/mux-player": "^3.13.0",
    "@types/leaflet": "^1.9.21",
    "@types/three": "^0.184.1",
    "@upstash/ratelimit": "^2.0.8",
    "@upstash/redis": "^1.38.0",
    "astro": "^5.18.2",
    "leaflet": "^1.9.4",
    "three": "^0.184.0"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.2",
    "pagefind": "^1.5.2",
    "prettier": "^3.0.0",
    "prettier-plugin-astro": "^0.14.0",
    "typescript": "^5.0.0",
    "vitest": "^3.0.0"
