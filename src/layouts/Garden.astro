---
// src/layouts/Garden.astro
import Base from './Base.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import MinimizeBar from '../components/MinimizeBar.astro';

interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
  noFooter?: boolean;
}

const { title, description, ogImage, noFooter = false } = Astro.props;
---
<Base title={title} description={description} ogImage={ogImage}>
  <Nav />
  <main id="main-content" tabindex="-1">
    <slot />
  </main>
  {!noFooter && <Footer />}
  <MinimizeBar />
</Base>

<style is:global>
  html { background: var(--color-bg); }

  /* Parallax targets — will-change declared so browser composites them */
  .garden-header,
  .page-header,
  .now-header {
    will-change: transform;
  }
</style>

