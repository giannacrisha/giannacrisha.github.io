---
// src/pages/lab/index.astro
import Garden from '../../layouts/Garden.astro';
import Card from '../../components/Card.astro';
import CollectionFilters from '../../components/CollectionFilters.astro';
import { getCollection } from 'astro:content';

const entries = await getCollection('lab');
const sorted = entries.sort((a, b) => {
  const ad = (a.data.date_published ?? a.data.date_built).getTime();
  const bd = (b.data.date_published ?? b.data.date_built).getTime();
  return bd - ad;
});

const filters = [
  {
    param: 'stage',
    label: 'stage',
    options: [
      { value: 'all', label: 'all' },
      { value: 'dust', label: 'dust' },
      { value: 'spark', label: 'spark' },
      { value: 'star', label: 'star' },
    ],
  },
];
---
<Garden title="lab">
  <div class="page-wrapper">
    <div class="page-header">
      <div class="page-title-row">
        <h1 class="section-header">lab</h1>
        <span class="page-phonetic">[lab] &nbsp;/ læb /</span>
      </div>
      <p class="page-def">design and code projects, built in public.</p>
    </div>
    <CollectionFilters filters={filters} />
    <div class="card-grid">
      {sorted.map(entry => (
        <div
          data-filter={JSON.stringify({ stage: entry.data.growth_stage })}
          data-date={(entry.data.date_published ?? entry.data.date_built).getTime()}
          data-stage={entry.data.growth_stage}
        >
          <Card
            title={entry.data.title}
            slug={entry.slug}
            collection="lab"
            stage={entry.data.growth_stage}
            date_published={entry.data.date_published}
            date_built={entry.data.date_built}
            cover_image={entry.data.cover_image}
            description={entry.data.description}
            body={entry.body}
          />
        </div>
      ))}
    </div>
  </div>
</Garden>

<style>
</style>
