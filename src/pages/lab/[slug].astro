---
// src/pages/lab/[slug].astro
import Garden from '../../layouts/Garden.astro';
import GrowthPill from '../../components/GrowthPill.astro';
import Timestamps from '../../components/Timestamps.astro';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  const entries = await getCollection('lab');
  return entries.map(entry => ({ params: { slug: entry.slug }, props: { entry } }));
}

const { entry } = Astro.props;
const { Content } = await entry.render();
const { title, description, date_built, date_published, tools, cover_image, link, growth_stage } = entry.data;
---
<Garden title={title}>
  <div class="content-wrapper">
    <article class="lab-article">
      <nav class="breadcrumb" aria-label="Breadcrumb">
        <a href="/lab">lab</a>
        <span aria-hidden="true">/</span>
      </nav>
      {cover_image && (
        <div class="cover-image">
          <img src={cover_image} alt={title} />
        </div>
      )}
      <h1 class="entry-title">{title}</h1>
      <div class="entry-meta">
        <GrowthPill stage={growth_stage} />
        <Timestamps
          primaryLabel="built"
          primaryDate={date_built}
          secondaryLabel="planted"
          secondaryDate={date_published}
        />
        {link && (
          <a href={link} target="_blank" rel="noopener noreferrer" class="external-link">
            view project
            <svg width="12" height="12" viewBox="0 0 12 12" fill="none" aria-hidden="true">
              <path d="M2 10L10 2M10 2H5M10 2V7" stroke="currentColor" stroke-width="1.2" stroke-linecap="round"/>
            </svg>
          </a>
        )}
      </div>
      {tools && tools.length > 0 && (
        <div class="tools">
          {tools.map(tool => <span class="pill">{tool}</span>)}
        </div>
      )}
      {description && <p class="description">{description}</p>}
      <div class="prose">
        <Content />
      </div>
    </article>
  </div>
</Garden>

<style>
  .lab-article { padding: var(--space-section) 0; }
  .breadcrumb { display: flex; gap: var(--space-sm); font-family: var(--font-body); font-size: var(--text-xs); color: var(--color-muted); margin-bottom: var(--space-xl); }
  .breadcrumb a { color: var(--color-muted); }
  .cover-image { margin-bottom: var(--space-xxl); }
  .cover-image img { width: 100%; max-height: 400px; object-fit: cover; border-radius: var(--radius-card); }
  .entry-title { font-family: var(--font-serif); font-size: var(--text-xxl); color: var(--color-fg); line-height: var(--leading-tight); margin-bottom: var(--space-lg); }
  .entry-meta { display: flex; flex-wrap: wrap; gap: var(--space-md); align-items: center; margin-bottom: var(--space-lg); }
  .external-link { display: inline-flex; align-items: center; gap: var(--space-xs); font-family: var(--font-body); font-size: var(--text-xs); color: var(--color-accent); letter-spacing: 0.06em; }
  .tools { display: flex; gap: var(--space-sm); flex-wrap: wrap; margin-bottom: var(--space-lg); }
  .description { font-family: var(--font-body); font-size: var(--text-md); color: var(--color-muted); margin-bottom: var(--space-xl); line-height: var(--leading-base); }
  .prose { margin-top: var(--space-xxl); }
</style>
