---
// src/pages/garden.astro — main hub
import Garden from '../layouts/Garden.astro';
import Card from '../components/Card.astro';
import GardenFilters from '../components/GardenFilters.astro';
import { getCollection } from 'astro:content';
import { site } from '../config/design';

const [lab, archives, gallery, library] = await Promise.all([
  getCollection('lab'),
  getCollection('archives'),
  getCollection('gallery'),
  getCollection('library'),
]);

const allEntries = [
  ...lab.map(e => ({ ...e, collection: 'lab' as const, date: e.data.date_published })),
  ...archives.map(e => ({ ...e, collection: 'archives' as const, date: e.data.date_published })),
  ...gallery.map(e => ({ ...e, collection: 'gallery' as const, date: e.data.date_published })),
  ...library.map(e => ({ ...e, collection: 'library' as const, date: e.data.date_added })),
].sort((a, b) => b.date.getTime() - a.date.getTime());
---
<Garden title="the garden" description={site.description}>
  <div class="garden-page">
    <div class="page-wrapper">

      <header class="garden-header">
        <h1 class="garden-title">the garden</h1>
        <p class="garden-desc">{site.description}</p>
      </header>

      <GardenFilters />

      <div class="masonry">
        {allEntries.map(entry => {
          const data = entry.data as any;
          return (
            <div
              class="masonry-item"
              data-filter={JSON.stringify({ collection: entry.collection, stage: data.growth_stage })}
              data-date={entry.date.getTime()}
              data-stage={data.growth_stage}
            >
              <Card
                title={data.title}
                slug={entry.slug}
                collection={entry.collection}
                type={data.type}
                stage={data.growth_stage}
                date_published={data.date_published ?? data.date_added}
                date_written={data.date_written}
                date_built={data.date_built}
                date_made={data.date_made}
                date_added={data.date_added}
                cover_image={data.cover_image ?? data.image}
                rating={data.rating}
                description={data.description}
                body={entry.body}
                creator={data.creator}
                year={data.year}
              />
            </div>
          );
        })}
      </div>

    </div>
  </div>
</Garden>

<style>
  /* white bg so the burst transition lands cleanly */
  .garden-page {
    background: #ffffff;
    min-height: 100vh;
    animation: fadeIn 0.5s ease-out both;
  }

  @keyframes fadeIn {
    from { opacity: 0; }
    to   { opacity: 1; }
  }

  .garden-header {
    padding: var(--space-section) 0 var(--space-xxl);
  }

  .garden-title {
    font-family: var(--font-display);
    font-size: var(--text-hero);
    color: var(--color-fg);
    line-height: var(--leading-tight);
    margin-bottom: var(--space-lg);
  }

  .garden-desc {
    font-family: var(--font-body);
    font-size: var(--text-xl);
    color: var(--color-muted);
    line-height: var(--leading-loose);
    max-width: 600px;
  }

  /* 3-column masonry */
  .masonry {
    columns: 3;
    column-gap: var(--space-xl);
    padding-bottom: var(--space-section);
  }
  .masonry-item {
    break-inside: avoid;
    margin-bottom: var(--space-xl);
  }

  @media (max-width: 900px) {
    .masonry { columns: 2; }
  }
  @media (max-width: 600px) {
    .masonry { columns: 1; }
    .garden-title { font-size: var(--text-section); }
    .garden-desc  { font-size: var(--text-md); }
  }
</style>
