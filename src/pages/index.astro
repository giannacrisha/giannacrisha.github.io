---
import Base from '../layouts/Base.astro';
import Card from '../components/Card.astro';
import { getCollection } from 'astro:content';
import { site } from '../config/design';

const [lab, archives, gallery, library] = await Promise.all([
  getCollection('lab'),
  getCollection('archives'),
  getCollection('gallery'),
  getCollection('library'),
]);

const allEntries = [
  ...lab.map(e => ({ ...e, collection: 'lab' as const, date: e.data.date_published })),
  ...archives.map(e => ({ ...e, collection: 'archives' as const, date: e.data.date_published })),
  ...gallery.map(e => ({ ...e, collection: 'gallery' as const, date: e.data.date_published })),
  ...library.map(e => ({ ...e, collection: 'library' as const, date: e.data.date_added })),
].sort((a, b) => b.date.getTime() - a.date.getTime()).slice(0, 6);
---
<Base title={site.name}>
  <main class="landing">
    <!-- hero gate -->
    <section class="hero">
      <div class="hero-inner">
        <div class="hero-text">
          <h1 class="hero-title">{site.name}</h1>
          <p class="hero-bio">{site.description}</p>
        </div>
        <div class="hero-cta">
          <a href="/garden" class="hero-enter" id="enter-link">enter</a>
          <svg class="hero-chevron" width="20" height="20" viewBox="0 0 20 20"
               fill="none" aria-hidden="true">
            <path d="M5 8l5 5 5-5" stroke="currentColor"
                  stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </div>
      </div>
    </section>

    <!-- recently planted -->
    <section class="recent-section">
      <div class="page-wrapper">
        <h2 class="recent-title">recently planted</h2>
        <div class="recent-scroll">
          {allEntries.map(entry => {
            const data = entry.data as any;
            return (
              <div class="grid-item">
                <Card
                  title={data.title}
                  slug={entry.slug}
                  collection={entry.collection}
                  type={data.type}
                  stage={data.growth_stage}
                  date_published={data.date_published ?? data.date_added}
                  date_written={data.date_written}
                  date_built={data.date_built}
                  date_made={data.date_made}
                  date_added={data.date_added}
                  cover_image={data.cover_image ?? data.image}
                  rating={data.rating}
                  description={data.description}
                  body={entry.body}
                  creator={data.creator}
                  year={data.year}
                />
              </div>
            );
          })}
        </div>
      </div>
    </section>
  </main>
</Base>

<style>
  .landing {
    height: 100vh;
    display: flex;
    flex-direction: column;
    overflow: hidden;
    background: #faf7f2;
    background: var(--color-bg);
  }
  .hero {
    flex: 1;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .hero-inner {
    text-align: center;
    max-width: 480px;
    padding: 0 var(--space-xl);
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-xxl);
  }
  .hero-text {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-sm);
  }
  .hero-title {
    font-family: var(--font-display);
    font-size: var(--text-hero);
    color: var(--color-fg);
    line-height: var(--leading-tight);
    white-space: nowrap;
  }
  .hero-bio {
    font-family: var(--font-body);
    font-size: var(--text-lg);
    color: var(--color-muted);
    line-height: var(--leading-loose);
  }
  .hero-enter {
    display: inline-block;
    font-family: var(--font-body);
    font-size: var(--text-sm);
    color: var(--color-bg);
    background: var(--color-fg);
    letter-spacing: 0.1em;
    text-decoration: none;
    border: none;
    border-radius: var(--radius-pill);
    padding: 6px 20px;
    transition: background 0.15s, color 0.15s;
  }
  .hero-enter:hover {
    background: var(--color-accent);
  }
  .hero-cta {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-sm);
  }
  .hero-chevron {
    color: var(--color-accent);
  }

  .recent-section {
    flex-shrink: 0;
    padding: 0 var(--space-xl) var(--space-xl);
  }
  .recent-section .page-wrapper {
    padding: 0;
    overflow: hidden;
  }
  .recent-title {
    font-family: var(--font-display);
    font-size: var(--text-section);
    color: var(--color-fg);
    line-height: var(--leading-tight);
    margin-bottom: var(--space-lg);
  }
  .recent-scroll {
    display: flex;
    flex-direction: row;
    gap: var(--space-xl);
    overflow-x: auto;
    overflow-y: visible;
    scroll-snap-type: x mandatory;
    -webkit-overflow-scrolling: touch;
    /* hide scrollbar visually */
    scrollbar-width: none;
    padding-bottom: var(--space-lg);
  }
  .recent-scroll::-webkit-scrollbar { display: none; }
  .grid-item {
    flex: 0 0 300px;
    scroll-snap-align: start;
    display: flex;
    flex-direction: column;
  }
  .grid-item > * { flex: 1; }

  @media (max-width: 600px) {
    .grid-item { flex: 0 0 260px; }
  }
</style>

<script>
  const link = document.getElementById('enter-link');

  link?.addEventListener('click', (e) => {
    e.preventDefault();

    const x = (e as MouseEvent).clientX;
    const y = (e as MouseEvent).clientY;

    // Distance from click to the farthest viewport corner
    const maxDist = Math.hypot(
      Math.max(x, window.innerWidth  - x),
      Math.max(y, window.innerHeight - y)
    );

    const burst = document.createElement('div');
    burst.style.cssText = `
      position: fixed;
      inset: 0;
      z-index: 9999;
      pointer-events: none;
      background: #ffffff;
      clip-path: circle(0px at ${x}px ${y}px);
    `;
    document.body.appendChild(burst);

    // Force reflow so the starting state is painted before we animate
    burst.getBoundingClientRect();

    burst.style.transition = `clip-path 0.75s cubic-bezier(0.4, 0, 1, 1)`;
    burst.style.clipPath = `circle(${maxDist * 1.05}px at ${x}px ${y}px)`;

    burst.addEventListener('transitionend', () => {
      sessionStorage.setItem('garden-entered', '1');
      window.location.href = '/garden';
    }, { once: true });
  });
</script>
