---
// src/pages/index.astro — home (scrolling landing). Replaces the old overlay gate.
// Sections: hero → art wall → the garden → our garden (community) → now → footer.
import Garden from '../layouts/Garden.astro';
import HeartCanvas from '../components/HeartCanvas.astro';
import { getCollection } from 'astro:content';
import { site } from '../config/design';

const [lab, archives, gallery, library, now] = await Promise.all([
  getCollection('lab'),
  getCollection('archives'),
  getCollection('gallery'),
  getCollection('library'),
  getCollection('now'),
]);

const recent = <T,>(arr: T[], key: (e: T) => number, n = 4) =>
  [...arr].sort((a, b) => key(b) - key(a)).slice(0, n);

const labRecent     = recent(lab,      e => (e.data.date_published ?? e.data.date_built).getTime());
const galleryRecent = recent(gallery,  e => (e.data.date_published ?? e.data.date_made).getTime());
const archiveRecent = recent(archives, e => (e.data.date_published ?? e.data.date_written).getTime());
const libraryRecent = recent(library,  e => e.data.date_added.getTime(), 6);

const nowSorted = [...now].sort((a, b) => b.data.date.getTime() - a.data.date.getTime());
const latestNow = nowSorted[0];
const NowContent = latestNow ? (await latestNow.render()).Content : null;
const fmtLong = (d: Date) => d.toLocaleDateString('en-US', { month: 'long', day: 'numeric', year: 'numeric' });
const fmtShort = (d: Date) => d.toLocaleDateString('en-US', { month: '2-digit', day: '2-digit', year: '2-digit' });

const phonetic = '[gahr-dn]  / ˈɡɑːr.dən /';

type FrameShape = 'rect' | 'circle' | 'square' | 'oval';
type FrameItem  = { shape: FrameShape; href: string; image: string; title: string };

const featuredFrames: FrameItem[] = [
  ...lab.filter(e => e.data.featured && e.data.frame_shape && e.data.cover_image).map(e => ({
    shape: e.data.frame_shape as FrameShape,
    href:  `/lab/${e.slug}`,
    image: e.data.cover_image!,
    title: e.data.title,
  })),
  ...gallery.filter(e => e.data.featured && e.data.frame_shape).map(e => ({
    shape: e.data.frame_shape as FrameShape,
    href:  `/gallery/${e.slug}`,
    image: e.data.image,
    title: e.data.title,
  })),
  ...archives.filter(e => e.data.featured && e.data.frame_shape && e.data.cover_image).map(e => ({
    shape: e.data.frame_shape as FrameShape,
    href:  `/archives/${e.slug}`,
    image: e.data.cover_image!,
    title: e.data.title,
  })),
];

// Split into rows of 4
const frameRows: FrameItem[][] = [];
for (let i = 0; i < featuredFrames.length; i += 4) {
  frameRows.push(featuredFrames.slice(i, i + 4));
}
---

<Garden title={site.name} description={site.description}>
  <div class="home">

    <!-- ── Hero ─────────────────────────────────────────────────────────── -->
    <section class="hero">
      <h1 class="hero-title">
        Gi designs creative <em>systems</em>, <em>products</em>, &amp; <em>experiences</em>.
      </h1>
      <div class="hero-heart">
        <HeartCanvas />
      </div>
    </section>

    <!-- ── Art wall ─────────────────────────────────────────────────────── -->
    {frameRows.length > 0 && (
      <section class="artwall" aria-label="a wall of work">
        {frameRows.map(row => (
          <div class="artwall-row">
            {row.map(item => (
              <a class={`frame-slot frame-slot--${item.shape}`} href={item.href} title={item.title}>
                <img class="frame-project-img" src={item.image} alt={item.title} loading="lazy" />
                <img class="frame-overlay" src={`/home/frame-${item.shape}.png`} alt="" aria-hidden="true" />
              </a>
            ))}
          </div>
        ))}
      </section>
    )}

    <!-- ── The garden (summary of collections) ──────────────────────────── -->
    <section class="garden-summary">
      <header class="sec-head">
        <a class="sec-title" href="/garden">the garden</a>
        <span class="sec-phon">{phonetic}</span>
      </header>

      <div class="g-grid">
        <article class="g-card">
          <a class="g-card-label" href="/lab">lab</a>
          <ul class="g-card-list">
            {labRecent.map(e => <li><a href={`/lab/${e.slug}`}>{e.data.title}</a></li>)}
          </ul>
        </article>

        <article class="g-card">
          <a class="g-card-label" href="/gallery">gallery</a>
          <div class="g-thumbs">
            {galleryRecent.map(e => (
              <a href={`/gallery/${e.slug}`} class="g-thumb" title={e.data.title}>
                {e.data.image
                  ? <img src={e.data.image} alt={e.data.title} loading="lazy" />
                  : <span class="g-thumb-fallback">{e.data.title}</span>}
              </a>
            ))}
          </div>
        </article>

        <article class="g-card">
          <a class="g-card-label" href="/archives">archives</a>
          <ul class="g-card-list">
            {archiveRecent.map(e => <li><a href={`/archives/${e.slug}`}>{e.data.title}</a></li>)}
          </ul>
        </article>
      </div>

      <a class="g-card-label g-card-label--wide" href="/library">library</a>
      <div class="g-card g-card--wide">
        <div class="lib-row">
          {libraryRecent.map(b => (
            <a href={`/library/${b.slug}`} class="lib-item" title={`${b.data.title} — ${b.data.creator}`}>
              {b.data.cover_image
                ? <img src={b.data.cover_image} alt={b.data.title} loading="lazy" />
                : <span class="lib-spine">{b.data.title}</span>}
            </a>
          ))}
        </div>
      </div>
    </section>

    <!-- ── Our garden (community) ───────────────────────────────────────── -->
    <section class="community-summary">
      <header class="sec-head sec-head--end">
        <span class="sec-phon">{phonetic}</span>
        <a class="sec-title" href="/community">our garden</a>
      </header>
      <div class="comm-row">
        {Array.from({ length: 6 }).map(() => (
          <a href="/community" class="comm-tile" aria-label="visit the community garden"></a>
        ))}
      </div>
    </section>

    <!-- ── Now ──────────────────────────────────────────────────────────── -->
    <section class="now-summary">
      <header class="sec-head sec-head--center">
        <a class="sec-title" href="/now">now</a>
        <span class="sec-phon sec-phon--italic">
          last updated: {latestNow ? fmtShort(latestNow.data.date) : 'mm/dd/yy'}
        </span>
      </header>
      <article class="now-card">
        {latestNow && <p class="now-date">{fmtLong(latestNow.data.date)}</p>}
        <div class="now-body">
          {NowContent ? <NowContent /> : <p>nothing here yet.</p>}
        </div>
        <a class="now-more" href="/now">more now →</a>
      </article>
    </section>

  </div>
</Garden>

<style>
  .home {
    --home-max: 1152px;
    max-width: var(--home-max);
    margin-inline: auto;
    padding-inline: clamp(20px, 5vw, 64px);
  }

  /* shared section heading (Lora, gold) */
  .sec-head {
    display: flex;
    align-items: baseline;
    gap: clamp(12px, 2vw, 32px);
    flex-wrap: wrap;
    margin-bottom: var(--space-xxl);
  }
  .sec-head--end { justify-content: flex-end; text-align: right; }
  .sec-head--center { justify-content: center; flex-direction: column; align-items: center; text-align: center; gap: 4px; }
  .sec-title {
    font-family: var(--font-serif);
    font-weight: 600;
    font-size: var(--text-section);
    color: var(--color-heading);
    line-height: 1.1;
    text-decoration: none;
    transition: opacity 0.15s;
  }
  .sec-title:hover { opacity: 0.72; }
  .sec-phon {
    font-family: var(--font-serif);
    font-weight: 400;
    font-size: var(--text-lg);
    color: var(--color-heading);
    opacity: 0.85;
  }
  .sec-phon--italic { font-style: italic; }

  /* ── Hero ─────────────────────────────────────────────────────────────── */
  .hero {
    display: flex;
    align-items: center;
    gap: clamp(24px, 4vw, 48px);
    padding-block: clamp(56px, 12vw, 168px);
  }
  .hero-title {
    flex: 1 1 0;
    min-width: 0;
    font-family: var(--font-serif);
    font-weight: 600;
    font-size: clamp(34px, 5.2vw, 64px);
    line-height: 1.12;
    color: var(--color-heading);
    max-width: 16ch;
  }
  .hero-title em { font-style: italic; }
  .hero-heart {
    flex: 0 0 auto;
    display: flex;
    justify-content: center;
  }

  /* ── Art wall ─────────────────────────────────────────────────────────── */
  .artwall {
    background-image: url('/home/wall-texture.png');
    background-size: 240px 240px;
    background-position: top left;
    border-radius: var(--radius-lg);
    padding: clamp(16px, 3vw, 32px);
    display: flex;
    flex-direction: column;
    gap: clamp(8px, 1.5vw, 16px);
    overflow: hidden;
  }
  .artwall-row {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: clamp(8px, 1.5vw, 16px);
  }
  .frame-slot {
    position: relative;
    display: block;
    height: clamp(120px, 18vw, 216px);
    flex-shrink: 0;
    text-decoration: none;
  }
  .frame-slot--rect   { aspect-ratio: 900 / 492; }
  .frame-slot--circle { aspect-ratio: 900 / 894; }
  .frame-slot--square { aspect-ratio: 900 / 891; }
  .frame-slot--oval   { aspect-ratio: 667 / 900; height: clamp(150px, 24vw, 291px); }

  .frame-project-img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  .frame-overlay {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: contain;
    pointer-events: none;
    z-index: 1;
    filter: drop-shadow(0 6px 14px rgba(120, 90, 20, 0.22));
  }

  /* ── The garden summary ───────────────────────────────────────────────── */
  .garden-summary { padding-block: clamp(56px, 9vw, 128px); }
  .g-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-xl);
    margin-bottom: var(--space-xl);
  }
  .g-card-label {
    display: block;
    font-family: var(--font-serif);
    font-weight: 700;
    font-size: var(--text-xl);
    color: var(--color-heading);
    text-decoration: none;
    margin-bottom: var(--space-md);
    transition: opacity 0.15s;
  }
  .g-card-label:hover { opacity: 0.72; }
  .g-card-label--wide { margin-top: var(--space-sm); }
  .g-card {
    background: var(--color-card);
    border-radius: var(--radius-lg);
    box-shadow: var(--shadow-gold);
    padding: var(--space-xl);
    min-height: 196px;
  }
  .g-card--wide { min-height: 188px; display: flex; align-items: center; }
  .g-card-list { list-style: none; display: flex; flex-direction: column; gap: var(--space-sm); }
  .g-card-list a {
    font-family: var(--font-body);
    font-size: var(--text-sm);
    color: var(--color-fg);
    text-decoration: none;
    line-height: 1.4;
    display: -webkit-box;
    -webkit-line-clamp: 1;
    -webkit-box-orient: vertical;
    overflow: hidden;
    transition: color 0.15s;
  }
  .g-card-list a:hover { color: var(--color-heading); text-decoration: underline; }

  .g-thumbs { display: grid; grid-template-columns: repeat(2, 1fr); gap: var(--space-sm); }
  .g-thumb {
    aspect-ratio: 1 / 1;
    border-radius: var(--radius-card);
    overflow: hidden;
    background: var(--color-accent-light);
    display: flex; align-items: center; justify-content: center;
  }
  .g-thumb img { width: 100%; height: 100%; object-fit: cover; }
  .g-thumb-fallback { font-family: var(--font-body); font-size: 10px; color: var(--color-muted); padding: 4px; text-align: center; }

  .lib-row { display: flex; gap: var(--space-lg); overflow-x: auto; width: 100%; padding-bottom: 4px; scrollbar-width: thin; }
  .lib-item {
    flex: 0 0 auto;
    width: 96px; height: 140px;
    border-radius: var(--radius-card);
    overflow: hidden;
    background: var(--color-accent-light);
    display: flex; align-items: center; justify-content: center;
    box-shadow: 0 2px 8px rgba(120, 90, 20, 0.15);
  }
  .lib-item img { width: 100%; height: 100%; object-fit: cover; }
  .lib-spine { font-family: var(--font-serif); font-size: 11px; color: var(--color-muted); padding: 6px; text-align: center; }

  /* ── Community ────────────────────────────────────────────────────────── */
  .community-summary { padding-block: clamp(40px, 7vw, 96px); }
  .comm-row { display: flex; gap: clamp(16px, 3vw, 48px); overflow-x: auto; padding: var(--space-md) 2px; scrollbar-width: thin; }
  .comm-tile {
    flex: 0 0 auto;
    width: clamp(120px, 16vw, 196px);
    aspect-ratio: 1 / 1;
    background: var(--color-card);
    border-radius: var(--radius-lg);
    box-shadow: var(--shadow-gold);
    transition: transform 0.18s ease, box-shadow 0.18s ease;
  }
  .comm-tile:hover { transform: translateY(-4px); box-shadow: 0 10px 24px rgba(144, 100, 47, 0.28); }

  /* ── Now ──────────────────────────────────────────────────────────────── */
  .now-summary { padding-block: clamp(40px, 7vw, 96px) clamp(64px, 10vw, 128px); }
  .now-card {
    background: var(--color-card);
    border-radius: var(--radius-lg);
    box-shadow: var(--shadow-gold);
    padding: clamp(28px, 5vw, 64px);
    font-family: var(--font-serif);
    font-style: italic;
    color: var(--color-heading);
  }
  .now-date { font-weight: 700; font-size: var(--text-lg); margin-bottom: var(--space-lg); }
  .now-body { font-size: var(--text-md); line-height: 1.7; }
  .now-body :global(p) { margin-bottom: var(--space-md); }
  .now-body :global(p:last-child) { margin-bottom: 0; }
  .now-more {
    display: inline-block;
    margin-top: var(--space-lg);
    font-family: var(--font-body);
    font-style: normal;
    font-size: var(--text-sm);
    color: var(--color-heading);
    text-decoration: underline;
    text-underline-offset: 3px;
  }

  /* ── Responsive ───────────────────────────────────────────────────────── */
  @media (max-width: 820px) {
    .hero { flex-direction: column; text-align: center; }
    .hero-title { max-width: none; }
    .g-grid { grid-template-columns: 1fr; }
  }
</style>
