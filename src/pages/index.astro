---
// src/pages/index.astro — garden + landing overlay
import Garden from '../layouts/Garden.astro';
import Card from '../components/Card.astro';
import TopicCloud from '../components/TopicCloud.astro';
import GrowthPill from '../components/GrowthPill.astro';
import Icon from '../components/Icon.astro';
import Trinket from '../components/Trinket.astro';
import { getCollection } from 'astro:content';
import { site } from '../config/design';

const [lab, archives, gallery, library] = await Promise.all([
  getCollection('lab'),
  getCollection('archives'),
  getCollection('gallery'),
  getCollection('library'),
]);

// Featured entries for overlay widgets (up to 6)
const featuredWidgets = [
  ...lab.filter(e => e.data.featured).map(e => ({
    title: e.data.title, slug: e.slug, collection: 'lab' as const,
    type: 'project', preview: e.data.description ?? '',
    date: e.data.date_published ?? e.data.date_built,
    image: (e.data as any).cover_image ?? null,
  })),
  ...archives.filter(e => e.data.featured).map(e => ({
    title: e.data.title, slug: e.slug, collection: 'archives' as const,
    type: e.data.type, preview: '',
    date: e.data.date_published ?? e.data.date_written,
    image: null,
  })),
  ...gallery.filter(e => e.data.featured).map(e => ({
    title: e.data.title, slug: e.slug, collection: 'gallery' as const,
    type: e.data.medium, preview: e.data.caption ?? '',
    date: e.data.date_published ?? e.data.date_made,
    image: (e.data as any).image ?? null,
  })),
].slice(0, 6);

// Widget positions: { top, left?, right?, rot, delay }
const positions = [
  { top: '12%', left: '4%',  rot: '-3deg', delay: '0s'   },
  { top:  '8%', right: '4%', rot:  '2deg', delay: '0.6s' },
  { top: '42%', left: '2%',  rot: '-2deg', delay: '1.1s' },
  { top: '42%', right: '2%', rot:  '3deg', delay: '0.3s' },
  { top: '72%', left: '5%',  rot:  '2deg', delay: '0.9s' },
  { top: '68%', right: '5%', rot: '-2deg', delay: '0.5s' },
];

const colIcons: Record<string, string> = {
  lab:      '/icons/lab-icon.png',
  archives: '/icons/archive-icon.png',
  gallery:  '/icons/gallery-icon.png',
  library:  '/icons/lib-icon.png',
};

const labSorted      = [...lab]     .sort((a,b)=>(b.data.date_published??b.data.date_built).getTime()-(a.data.date_published??a.data.date_built).getTime());
const archivesSorted = [...archives].sort((a,b)=>(b.data.date_published??b.data.date_written).getTime()-(a.data.date_published??a.data.date_written).getTime());
const gallerySorted  = [...gallery] .sort((a,b)=>(b.data.date_published??b.data.date_made).getTime()-(a.data.date_published??a.data.date_made).getTime());
const librarySorted  = [...library] .sort((a,b)=>b.data.date_added.getTime()-a.data.date_added.getTime());

// All unique topics (lab + archives + gallery)
const allTopics = [...new Set([
  ...lab.flatMap(e=>e.data.topics??[]),
  ...archives.flatMap(e=>e.data.topics??[]),
  ...gallery.flatMap(e=>e.data.topics??[]),
])].sort();

// Growth stage weather — counts across all collections (excluding library, which has no stage)
const allStaged = [...lab, ...archives, ...gallery] as { data: { growth_stage?: string } }[];
const dustCount  = allStaged.filter(e => e.data.growth_stage === 'dust').length;
const sparkCount = allStaged.filter(e => e.data.growth_stage === 'spark').length;
const starCount  = allStaged.filter(e => e.data.growth_stage === 'star').length;

// Book spine color from title hash
function bookColor(s: string) {
  const p = ['#c9b99a','#b5c4b1','#b5a8c0','#c4b1b1','#a8bec4','#c4bdb5','#b1c4b5','#c4b5a8'];
  let h = 0; for (const c of s) h = c.charCodeAt(0)+((h<<5)-h);
  return p[Math.abs(h)%p.length];
}

const fmt = (d: Date) => d.toLocaleDateString('en-US',{month:'short',day:'numeric',year:'numeric'});
---

<Garden title={site.name} description={site.description}>

  <!-- ── Landing overlay (hidden for return visitors) ─────────────────── -->
  <div id="landing-overlay" class="landing-overlay">

    <!-- sparkle trail canvas -->
    <canvas id="sparkle-canvas" aria-hidden="true"></canvas>

    <!-- floating project widgets -->
    {featuredWidgets.map((w, i) => {
      const pos = positions[i];
      const posStyle = `top:${pos.top};${'left' in pos ? `left:${pos.left}` : `right:${pos.right}`};--rot:${pos.rot};--float-delay:${pos.delay}`;
      return (
        <div
          class="widget"
          style={posStyle}
          aria-hidden="true"
          data-href={`/${w.collection}/${w.slug}`}
        >
          <div class="widget-flipper">
            {/* Front: cover image (or fallback icon) */}
            <div class="widget-face widget-front">
              {w.image
                ? <img src={w.image} class="widget-cover" alt={w.title} draggable="false" />
                : <div class="widget-cover-fallback">
                    <img src={colIcons[w.collection]} class="widget-fallback-icon" alt="" />
                  </div>
              }
            </div>
            {/* Back: info */}
            <div class="widget-face widget-back">
              <div class="widget-top">
                <img src={colIcons[w.collection]} class="widget-icon" alt="" />
                <span class="widget-type">{w.type}</span>
              </div>
              <p class="widget-title">{w.title}</p>
              {w.preview && <p class="widget-preview">{w.preview.slice(0, 60)}{w.preview.length > 60 ? '…' : ''}</p>}
              <a href={`/${w.collection}/${w.slug}`} class="widget-visit" tabindex="-1">open →</a>
            </div>
          </div>
        </div>
      );
    })}

    <!-- ── Trinkets ──────────────────────────────────────────────────────── -->
    {/* ph stamp */}
    <Trinket type="stamp" bottom="8%" left="5%" rot={-6} delay={0.4}>
      <img src="/trinkets/ph-stamp.png" width="96" height="96" alt="" draggable="false" />
    </Trinket>

    <!-- hero -->
    <div class="hero-inner" id="hero-inner">
      <div class="hero-text">
        <h1 class="hero-title" id="hero-title">{site.name}</h1>
        <p class="hero-bio" id="hero-bio" aria-label={site.tagline}></p>
      </div>
      <div class="hero-cta">
        <button class="hero-enter" id="enter-btn" aria-label="Enter the garden">
          <img class="keyhole-svg" src="/keyhole.png" alt="" aria-hidden="true" draggable="false"/>
        </button>
      </div>
    </div>
  </div>

  <!-- ── Garden content (always in DOM for SEO) ───────────────────────── -->
  <div class="garden-page" id="garden-content">
    <div class="page-wrapper">

      <header class="garden-header">
        <div class="garden-title-row">
          <h1 class="garden-title">the garden</h1>
          <span class="garden-phonetic">[gahr-dn] &nbsp;/ ˈɡɑːr.dən /</span>
        </div>
        <p class="garden-def">
          a space where things grow. <a class="garden-learn-more" href="https://maggieappleton.com/garden-history" target="_blank" rel="noopener" aria-label="learn more about digital gardens (opens in new tab)">learn more →</a>
        </p>
        <div class="garden-links">
          <button class="garden-link-btn" id="btn-story">the story</button>
          <button class="garden-link-btn" id="btn-design">the design</button>
          <button class="garden-link-btn" id="btn-stages">growth stages</button>
        </div>
      </header>

      <!-- ── Modals ────────────────────────────────────────────────────── -->
      <div id="modal-backdrop" class="modal-backdrop" aria-hidden="true" role="dialog" aria-modal="true">
        <div class="modal" id="modal-box">
          <div class="modal-traffic">
            <button class="traffic-dot traffic-red" id="modal-close" aria-label="Close">
              <svg class="traffic-icon" width="8" height="8" viewBox="0 0 8 8" fill="none" aria-hidden="true">
                <path d="M1.5 1.5l5 5M6.5 1.5l-5 5" stroke="currentColor" stroke-width="1.2" stroke-linecap="round"/>
              </svg>
            </button>
            <div class="traffic-dot traffic-yellow" aria-hidden="true">
              <svg class="traffic-icon" width="8" height="2" viewBox="0 0 8 2" fill="none" aria-hidden="true">
                <path d="M1 1h6" stroke="currentColor" stroke-width="1.2" stroke-linecap="round"/>
              </svg>
            </div>
            <div class="traffic-dot traffic-green" id="modal-fullscreen" aria-label="Expand to full page">
              <svg class="traffic-icon" width="8" height="8" viewBox="0 0 8 8" fill="none" aria-hidden="true">
                <path d="M1 3V1h2M5 1h2v2M7 5v2H5M3 7H1V5" stroke="currentColor" stroke-width="1.1" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </div>
          </div>
          <div id="modal-body" class="modal-body"></div>
        </div>
      </div>

      <!-- Minimized modal tabbar -->
      <div class="modal-tabbar" id="modal-tabbar"></div>

      <!-- ── Garden bar: topics + filters + sort ──────────────────────────── -->
      <div class="garden-bar">
        {allTopics.length > 0 && (
          <div class="topic-pills-scroll">
            <div class="topic-pills" id="topic-cloud" role="group" aria-label="Filter by topic">
              <button class="topic-pill active" data-topic="all">all</button>
              {allTopics.map(t => <button class="topic-pill" data-topic={t}>{t}</button>)}
            </div>
          </div>
        )}
        <div class="bar-controls">
          <div class="chip-wrap">
            <button class="control-chip control-chip--icon" id="filters-btn" aria-expanded="false" aria-haspopup="true" aria-label="Filter and sort">
              <svg xmlns="http://www.w3.org/2000/svg" height="16px" viewBox="0 -960 960 960" width="16px" fill="currentColor" aria-hidden="true"><path d="M400-240v-80h160v80H400ZM240-440v-80h480v80H240ZM120-640v-80h720v80H120Z"/></svg>
            </button>
            <div class="dropdown" id="filters-dropdown" aria-hidden="true">
              <div class="dropdown-section">
                <span class="dropdown-label">filter by stage</span>
                <div class="dropdown-pills">
                  <button class="dpill active" data-filter-param="stage" data-filter-value="all">all</button>
                  <button class="dpill" data-filter-param="stage" data-filter-value="dust">dust</button>
                  <button class="dpill" data-filter-param="stage" data-filter-value="spark">spark</button>
                  <button class="dpill" data-filter-param="stage" data-filter-value="star">star</button>
                </div>
              </div>
              <div class="dropdown-section">
                <span class="dropdown-label">sort</span>
                <div class="dropdown-pills">
                  <button class="dpill active" data-sort-value="newest">most recent</button>
                  <button class="dpill" data-sort-value="oldest">oldest first</button>
                  <button class="dpill" data-sort-value="stage">by growth stage</button>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>

      <!-- ── Shelf sections ─────────────────────────────────────────────── -->
      <div id="garden-shelf">

        <!-- Lab -->
        <section class="shelf-section" id="section-lab" data-collection="lab">
          <h2 class="shelf-label"><a href="/lab" class="shelf-label-link">lab</a></h2>
          <div class="shelf-row shelf-row--lab">
            {labSorted.map(entry => (
              <div class:list={['shelf-item', { 'shelf-item--lab-img': !!entry.data.cover_image }]} data-topics={JSON.stringify(entry.data.topics??[])} data-stage={entry.data.growth_stage??''} data-date={(entry.data.date_published??entry.data.date_built).getTime()}>
                <Card title={entry.data.title} slug={entry.slug} collection="lab" stage={entry.data.growth_stage} date_published={entry.data.date_published??entry.data.date_built} date_built={entry.data.date_built} cover_image={entry.data.cover_image} description={entry.data.description} body={entry.body} />
              </div>
            ))}
          </div>
        </section>

        <!-- Gallery -->
        <section class="shelf-section" id="section-gallery" data-collection="gallery">
          <h2 class="shelf-label"><a href="/gallery" class="shelf-label-link">gallery</a></h2>
          <div class="shelf-row shelf-row--gallery">
            {gallerySorted.map(entry => {
              const d = entry.data;
              const date = d.date_published ?? d.date_made;
              return (
                <div class="shelf-item" data-topics={JSON.stringify(d.topics??[])} data-stage={d.growth_stage??''} data-date={date.getTime()}>
                  <a href={`/gallery/${entry.slug}`} class="frame-card">
                    <div class="frame-img-wrap">
                      {d.image
                        ? <img class="frame-img" src={d.image} alt={d.title} loading="lazy" />
                        : <div class="frame-empty">no image</div>
                      }
                      <div class="frame-overlay">
                        <div class="frame-stage"><GrowthPill stage={d.growth_stage} forceColor="rgba(255,255,255,0.9)" /></div>
                        <div class="frame-bottom">
                          <div class="frame-title-row">
                            <span class="frame-title">{d.title}</span>
                            <span class="frame-year">{d.date_made.getFullYear()}</span>
                          </div>
                          {d.caption && <p class="frame-caption">{d.caption}</p>}
                        </div>
                      </div>
                    </div>
                  </a>
                </div>
              );
            })}
          </div>
        </section>

        <!-- Archives -->
        <section class="shelf-section" id="section-archives" data-collection="archives">
          <h2 class="shelf-label"><a href="/archives" class="shelf-label-link">archives</a></h2>
          <div class="shelf-row">
            {archivesSorted.map(entry => (
              <div class="shelf-item" data-topics={JSON.stringify(entry.data.topics??[])} data-stage={entry.data.growth_stage??''} data-date={(entry.data.date_published??entry.data.date_written).getTime()}>
                <Card title={entry.data.title} slug={entry.slug} collection="archives" type={entry.data.type} stage={entry.data.growth_stage} date_published={entry.data.date_published??entry.data.date_written} date_written={entry.data.date_written} body={entry.body} />
              </div>
            ))}
          </div>
        </section>

        <!-- Library -->
        <section class="shelf-section" id="section-library" data-collection="library">
          <h2 class="shelf-label"><a href="/library" class="shelf-label-link">library</a></h2>
          <div class="shelf-row shelf-row--library">
            {librarySorted.map(entry => {
              const d = entry.data;
              return (
                <div class="shelf-item" data-topics="[]" data-stage="" data-date={d.date_added.getTime()}>
                  <a href={`/library/${entry.slug}`} class="book-card" style={`--book-color:${bookColor(d.title)}`}>
                    {d.cover_image
                      ? <img class="book-cover" src={d.cover_image} alt={d.title} loading="lazy" />
                      : <div class="book-spine"></div>
                    }
                    <p class="book-title">{d.title}</p>
                    <p class="book-author">{d.creator}</p>
                  </a>
                </div>
              );
            })}
          </div>
        </section>

      </div>

    </div>

  </div>
</Garden>

<style>
  /* ── Landing overlay ──────────────────────────────────────────────────── */
  .landing-overlay {
    position: fixed;
    inset: 0;
    z-index: 500;
    background: var(--color-bg);
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
  }
  .landing-overlay.exiting {
    animation: overlayExit 0.8s ease forwards;
    pointer-events: none;
  }
  @keyframes overlayExit {
    from { opacity: 1; }
    to   { opacity: 0; }
  }
  .landing-overlay.entering {
    animation: overlayEnter 0.45s ease forwards;
  }
  @keyframes overlayEnter {
    from { opacity: 0; }
    to   { opacity: 1; }
  }

  /* ── Sparkle trail canvas ────────────────────────────────────────────── */
  #sparkle-canvas {
    position: fixed;
    inset: 0;
    width: 100%;
    height: 100%;
    pointer-events: none;
    z-index: 1;
  }

  /* ── Floating widgets ────────────────────────────────────────────────── */
  .widget {
    position: absolute;
    cursor: grab;
    width: 160px;
    z-index: 2;
    transform: rotate(var(--rot, 0deg));
    animation: widgetIn 0.7s ease both, widgetFloat 4s ease-in-out infinite;
    animation-delay: var(--float-delay, 0s), var(--float-delay, 0s);
    perspective: 600px;
  }
  .widget:active { cursor: grabbing; }

  @keyframes widgetIn {
    from { opacity: 0; translate: 0 12px; }
    to   { opacity: 1; translate: 0 0; }
  }
  @keyframes widgetFloat {
    0%, 100% { translate: 0 0; }
    50%       { translate: 0 -8px; }
  }

  /* flipper — rotates on .flipped */
  .widget-flipper {
    position: relative;
    width: 100%;
    /* height set by front face (aspect-ratio) */
    transform-style: preserve-3d;
    transition: transform 0.55s cubic-bezier(0.4, 0.2, 0.2, 1);
    border-radius: var(--radius-card);
  }
  .widget.flipped .widget-flipper {
    transform: rotateY(180deg);
  }

  /* shared face styles */
  .widget-face {
    border-radius: var(--radius-card);
    backface-visibility: hidden;
    -webkit-backface-visibility: hidden;
    overflow: hidden;
  }

  /* front — cover image, natural size, no crop */
  .widget-front {
    width: 100%;
  }
  .widget-cover {
    width: 100%;
    height: auto;
    display: block;
    pointer-events: none;
  }
  .widget-cover-fallback {
    width: 100%;
    height: 100%;
    background: var(--color-accent-light);
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .widget-fallback-icon {
    width: 36px;
    height: 36px;
    opacity: 0.4;
  }

  /* back — info card */
  .widget-back {
    position: absolute;
    inset: 0;
    transform: rotateY(180deg);
    background: var(--color-card);
    border: 0.5px solid var(--color-border);
    padding: var(--space-md) var(--space-lg);
    display: flex;
    flex-direction: column;
    gap: var(--space-xs);
  }
  .widget-top {
    display: flex;
    align-items: center;
    gap: var(--space-xs);
  }
  .widget-icon {
    width: 14px;
    height: 14px;
    opacity: 0.6;
  }
  .widget-type {
    font-family: var(--font-body);
    font-size: 10px;
    color: var(--color-accent);
    letter-spacing: 0.07em;
  }
  .widget-title {
    font-family: var(--font-serif);
    font-size: var(--text-sm);
    color: var(--color-fg);
    line-height: var(--leading-tight);
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
  .widget-preview {
    font-family: var(--font-body);
    font-size: 10px;
    color: var(--color-muted);
    line-height: 1.5;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
    flex: 1;
  }
  .widget-visit {
    font-family: var(--font-body);
    font-size: 10px;
    color: var(--color-accent);
    text-decoration: none;
    letter-spacing: 0.05em;
    align-self: flex-end;
    pointer-events: auto;
  }
  .widget-visit:hover { text-decoration: underline; }

  @media (max-width: 768px) { .widget { display: none; } }

  /* ── Hero ────────────────────────────────────────────────────────────── */
  .hero-inner {
    text-align: center;
    max-width: 480px;
    padding: 0 var(--space-xl);
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-xxl);
    animation: heroIn 0.7s ease both;
    position: relative;
    z-index: 3;
  }
  @keyframes heroIn {
    from { opacity: 0; transform: translateY(18px); }
    to   { opacity: 1; transform: translateY(0); }
  }
  .landing-overlay.exiting .hero-inner {
    animation: heroOut 0.4s ease forwards;
  }
  @keyframes heroOut {
    to { opacity: 0; transform: translateY(-10px); }
  }

  .hero-text {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-sm);
  }
  .hero-title {
    font-family: var(--font-display);
    font-size: var(--text-hero);
    color: var(--color-fg);
    line-height: var(--leading-tight);
    white-space: nowrap;
    cursor: default;
  }
  /* letter hover — :global because spans are JS-created (no astro scope attr) */
  :global(.hero-title .letter) {
    display: inline-block;
    transition: transform 0.35s cubic-bezier(0.34, 1.56, 0.64, 1), color 0.3s ease;
    cursor: default;
  }
  :global(.hero-title .letter:hover) {
    transform: translateY(-7px);
    color: var(--color-accent);
  }

  .hero-bio {
    font-family: var(--font-body);
    font-size: var(--text-lg);
    color: var(--color-muted);
    line-height: var(--leading-loose);
    min-height: 1.6em;
  }
  /* typewriter cursor */
  .hero-bio::after {
    content: '|';
    color: var(--color-accent);
    animation: blink 0.9s step-end infinite;
    margin-left: 1px;
  }
  .hero-bio.typed::after { display: none; }
  @keyframes blink {
    0%, 100% { opacity: 1; }
    50%       { opacity: 0; }
  }

  .hero-enter {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    background: none;
    border: none;
    padding: 0;
    cursor: pointer;
    color: var(--color-fg);
    opacity: 0.75;
    transition: opacity 0.2s, transform 0.2s;
  }
  .hero-enter:hover {
    opacity: 1;
    transform: scale(1.1);
    cursor: url('/key.png') 16 16, pointer;
  }
  .keyhole-svg {
    width: 52px;
    height: 52px;
    display: block;
    transition: transform 0.1s;
  }
  .hero-enter.spinning .keyhole-svg {
    animation: keyholeSpin 0.5s ease-in-out forwards;
  }
  @keyframes keyholeSpin {
    0%   { transform: rotate(0deg); }
    45%  { transform: rotate(90deg); }
    100% { transform: rotate(0deg); }
  }
  .hero-cta {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-sm);
  }

  /* ── Garden content ───────────────────────────────────────────────────── */
  .garden-page {
    min-height: 100vh;
  }
  .garden-header {
    padding: var(--space-xxl) 0 var(--space-xxl);
  }
  .garden-title-row {
    display: flex;
    align-items: baseline;
    gap: var(--space-lg);
    flex-wrap: wrap;
    margin-bottom: var(--space-md);
  }
  .garden-title {
    font-family: var(--font-display);
    font-size: var(--text-hero);
    color: var(--color-fg);
    line-height: var(--leading-tight);
  }
  :global(:root[data-theme="dark"]) .garden-title {
    color: var(--color-fg);
  }
  :global(:root[data-theme="dark"]) .garden-def {
    color: var(--color-fg); /* cream */
  }
  .garden-phonetic {
    font-family: var(--font-body);
    font-size: var(--text-md);
    color: var(--color-muted);
    letter-spacing: 0.02em;
  }
  .garden-def {
    font-family: var(--font-body);
    font-size: var(--text-lg);
    color: var(--color-muted);
    line-height: var(--leading-loose);
    max-width: 560px;
    padding-left: var(--space-xl);
    margin-bottom: var(--space-lg);
  }
  .garden-learn-more {
    font-family: var(--font-body);
    font-size: var(--text-sm);
    font-style: italic;
    color: var(--color-muted);
    text-decoration: underline;
    text-decoration-color: var(--color-accent-border);
    text-underline-offset: 3px;
    white-space: nowrap;
    transition: color 0.15s;
  }
  .garden-learn-more:hover { color: var(--color-fg); }
  .garden-weather-wrap {
    position: relative;
    display: inline-flex;
    align-items: center;
    margin-bottom: var(--space-lg);
    padding-left: var(--space-xl);
  }
  .weather-info-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    background: none;
    border: none;
    padding: 0;
    color: var(--color-muted);
    cursor: default;
    opacity: 0.5;
    transition: opacity 0.15s;
  }
  .weather-info-btn:hover { opacity: 1; }
  .weather-info-btn:hover + .garden-weather,
  .garden-weather:hover { opacity: 1; pointer-events: auto; }

  .garden-weather {
    position: absolute;
    left: calc(var(--space-xl) + 18px);
    top: 50%;
    transform: translateY(-50%);
    display: flex;
    align-items: center;
    gap: var(--space-sm);
    font-family: var(--font-body);
    font-size: var(--text-xs);
    color: var(--color-muted);
    letter-spacing: 0.06em;
    background: var(--color-card);
    border: var(--border);
    border-radius: var(--radius-pill);
    padding: 3px 10px;
    white-space: nowrap;
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.15s;
  }
  .weather-sep { opacity: 0.4; }
  .weather-item--dust  { color: var(--color-muted);  }
  .weather-item--spark { color: var(--color-accent);  }
  .weather-item--star  { color: var(--color-fg); font-weight: 600; }

  .garden-links {
    display: flex;
    gap: var(--space-lg);
    padding-left: var(--space-xl);
    flex-wrap: wrap;
  }
  .garden-link-btn {
    background: none;
    border: none;
    padding: 0;
    font-family: var(--font-body);
    font-size: var(--text-sm);
    color: var(--color-muted);
    cursor: pointer;
    text-decoration: underline;
    text-decoration-color: var(--color-accent-border);
    text-underline-offset: 3px;
    transition: color 0.15s, text-decoration-color 0.15s;
  }
  .garden-link-btn:hover {
    color: var(--color-fg);
    text-decoration-color: var(--color-accent);
  }

  /* ── Modals ──────────────────────────────────────────────────────────── */
  .modal-backdrop {
    position: fixed;
    inset: 0;
    z-index: 800;
    background: rgba(0,0,0,0.35);
    display: flex;
    align-items: center;
    justify-content: center;
    padding: var(--space-xl);
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.2s ease;
  }
  .modal-backdrop.open {
    opacity: 1;
    pointer-events: all;
  }
  .modal {
    background: var(--color-card);
    border: 0.5px solid var(--color-border);
    border-radius: var(--radius-card);
    box-shadow: 0 8px 48px rgba(0,0,0,0.14);
    width: 100%;
    max-width: 680px;
    max-height: 80vh;
    display: flex;
    flex-direction: column;
    position: relative;
    overflow: hidden;
    transform: translateY(12px);
    transition: transform 0.35s cubic-bezier(0.4,0,0.2,1),
                max-width 0.35s cubic-bezier(0.4,0,0.2,1),
                max-height 0.35s cubic-bezier(0.4,0,0.2,1),
                border-radius 0.35s cubic-bezier(0.4,0,0.2,1);
  }
  .modal-backdrop.open .modal {
    transform: translateY(0);
  }
  /* Gradient fade at top to maintain contrast for traffic buttons over scrolled content */
  .modal::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 56px;
    background: linear-gradient(to bottom, var(--color-card) 40%, transparent);
    border-radius: var(--radius-card) var(--radius-card) 0 0;
    pointer-events: none;
    z-index: 1;
  }
  /* fullscreen state */
  .modal.modal--fullscreen {
    max-width: 100vw;
    max-height: 100vh;
    width: 100vw;
    height: 100vh;
    border-radius: 0;
    border: none;
    box-shadow: none;
  }
  .modal-backdrop.open.modal-backdrop--fullscreen {
    padding: 0;
    align-items: stretch;
  }
  .modal-traffic {
    position: absolute;
    top: var(--space-lg);
    left: var(--space-lg);
    display: flex;
    align-items: center;
    gap: 7px;
    z-index: 1;
  }
  .traffic-dot {
    width: 13px;
    height: 13px;
    border-radius: 50%;
    border: none;
    cursor: default;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    padding: 0;
    transition: filter 0.15s;
  }
  .traffic-red    { background: var(--color-traffic-red); cursor: pointer; }
  .traffic-yellow { background: #ffbd2e; cursor: pointer; }
  .traffic-green  { background: #28c841; cursor: pointer; }
  .traffic-icon {
    color: rgba(0,0,0,0.4);
    opacity: 0;
    transition: opacity 0.15s;
  }
  .modal-traffic:hover .traffic-icon { opacity: 1; }
  .traffic-red:hover { filter: brightness(0.9); }
  .traffic-dot:focus-visible {
    outline: 2px solid var(--color-accent);
    outline-offset: 3px;
  }

  @media (hover: none) {
    .modal-traffic { gap: 12px; }
    .traffic-dot {
      width: 22px;
      height: 22px;
    }
    .traffic-icon {
      opacity: 1;
      width: 12px;
      height: 12px;
    }
  }
  .modal-body {
    overflow-y: auto;
    padding: calc(var(--space-xxl) + 8px) var(--space-xxl) var(--space-xxl);
    scrollbar-width: thin;
    scrollbar-color: var(--color-border) transparent;
  }
  .modal-body::-webkit-scrollbar {
    width: 6px;
  }
  .modal-body::-webkit-scrollbar-track {
    background: transparent;
    margin: 12px;
  }
  .modal-body::-webkit-scrollbar-thumb {
    background: var(--color-border);
    border-radius: 999px;
    border: 2px solid transparent;
    background-clip: padding-box;
  }
  .modal-body::-webkit-scrollbar-thumb:hover {
    background: var(--color-muted);
    background-clip: padding-box;
  }
  .modal-body iframe {
    width: 100%;
    height: 60vh;
    border: none;
    border-radius: var(--radius-card);
  }
  /* ── Minimized modal tabbar ──────────────────────────────────────────── */
  .modal-tabbar {
    position: fixed;
    bottom: 0;
    left: 0;
    right: 0;
    z-index: 801;
    display: flex;
    align-items: flex-end;
    gap: 4px;
    padding: 20px var(--space-xl) 0;
    pointer-events: none;
    overflow-x: auto;
    overflow-y: visible;
    scrollbar-width: none;
    justify-content: center;
    /* allow shadow to bleed above the scrollable area */
    clip-path: none;
  }
  .modal-tabbar::-webkit-scrollbar { display: none; }
  :global(.modal-tab-item) {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    padding: 7px 8px 9px 14px;
    background: var(--color-card);
    border: 0.5px solid var(--color-border);
    border-bottom: none;
    border-radius: 10px 10px 0 0;
    box-shadow: 0 -2px 16px rgba(0,0,0,0.08);
    cursor: pointer;
    pointer-events: auto;
    transform: translateY(100%);
    transition: transform 0.28s cubic-bezier(0.4,0,0.2,1), box-shadow 0.18s;
    flex-shrink: 0;
    white-space: nowrap;
  }
  :global(.modal-tab-item.tab-visible) {
    transform: translateY(0);
  }
  :global(.modal-tab-item:hover) {
    box-shadow: 0 -4px 22px rgba(0,0,0,0.13);
  }
  :global(.modal-tab-label) {
    font-family: var(--font-body);
    font-size: var(--text-xs);
    color: var(--color-muted);
    letter-spacing: 0.04em;
    white-space: nowrap;
  }
  :global(.modal-tab-close) {
    flex-shrink: 0;
    /* visual: 14px red dot */
    width: 14px;
    height: 14px;
    border-radius: 50%;
    background: var(--color-traffic-red);
    border: none;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 0;
    opacity: 1;
    /* 44px touch target via outline box trick */
    position: relative;
  }
  :global(.modal-tab-close::before) {
    content: '';
    position: absolute;
    inset: -15px;
  }
  :global(.modal-tab-close svg) {
    display: block;
  }

  /* story modal prose — :global() because content is JS-injected */
  :global(.story-title) {
    font-family: var(--font-display);
    font-size: var(--text-xxl);
    color: var(--color-fg);
    margin: 0 0 var(--space-lg);
    line-height: 1.15;
  }
  :global(.modal-meta) {
    display: flex;
    flex-direction: column;
    gap: 6px;
    background: var(--color-accent-light);
    border: 0.5px solid var(--color-border);
    border-radius: var(--radius-card);
    padding: var(--space-lg) var(--space-xl);
    margin-bottom: var(--space-xxl);
  }
  :global(.modal-meta-desc) {
    font-family: var(--font-body);
    font-size: var(--text-sm);
    color: var(--color-fg);
    line-height: 1.65;
  }
  :global(.modal-meta-row) {
    display: flex;
    align-items: center;
    gap: var(--space-md);
    flex-wrap: wrap;
    margin-top: var(--space-xs);
  }
  :global(.modal-meta-badge) {
    font-family: var(--font-body);
    font-size: var(--text-xs);
    color: var(--color-muted);
    letter-spacing: 0.05em;
    display: flex;
    align-items: center;
    gap: 5px;
  }
  :global(.modal-meta-badge svg) {
    flex-shrink: 0;
    opacity: 0.6;
  }
  :global(.modal-meta-link) {
    font-family: var(--font-body);
    font-size: var(--text-xs);
    color: var(--color-accent);
    text-decoration: underline;
    text-decoration-color: var(--color-accent-border);
    text-underline-offset: 3px;
    transition: color 0.15s;
  }
  :global(.modal-meta-link:hover) { color: var(--color-fg); }
  :global(.story-body) {
    padding-top: var(--space-sm);
  }
  :global(.story-body p) {
    font-family: var(--font-body);
    font-size: var(--text-md);
    line-height: 1.9;
    color: var(--color-fg);
    margin: 0 0 var(--space-xl);
  }
  :global(.story-body p:first-of-type) {
    font-size: calc(var(--text-md) * 1.05);
  }
  :global(.story-body blockquote) {
    margin: var(--space-xl) 0;
    padding: var(--space-lg) var(--space-xl);
    border-left: 2px solid var(--color-accent);
    background: var(--color-accent-light);
    border-radius: 0 var(--radius-card) var(--radius-card) 0;
  }
  :global(.story-body blockquote p) {
    font-family: var(--font-serif);
    font-style: italic;
    font-size: var(--text-md);
    line-height: 1.75;
    color: var(--color-fg);
    margin-bottom: var(--space-sm);
  }
  :global(.story-body blockquote cite) {
    display: block;
    font-family: var(--font-body);
    font-style: normal;
    font-size: var(--text-sm);
    color: var(--color-muted);
    margin-top: var(--space-sm);
  }
  :global(.story-body a) {
    color: var(--color-fg);
    text-decoration: underline;
    text-decoration-color: var(--color-accent);
    text-underline-offset: 3px;
  }

  /* ── Growth stages modal ────────────────────────────────────────────── */
  :global(.stages-body) {
    display: flex;
    flex-direction: column;
    gap: var(--space-xxl);
    padding-top: var(--space-md);
  }
  :global(.stage-row) {
    display: flex;
    gap: var(--space-xl);
    align-items: flex-start;
  }
  :global(.stage-icon) {
    font-size: 22px;
    width: 32px;
    flex-shrink: 0;
    text-align: center;
    line-height: 1.4;
  }
  :global(.stage-icon--dust)  { color: #9C8B6E; }
  :global(.stage-icon--spark) { color: #C4B49A; }
  :global(.stage-icon--star)  { color: #5C4D3A; }
  :global(.stage-content) {
    display: flex;
    flex-direction: column;
    gap: var(--space-sm);
  }
  :global(.stage-name) {
    font-family: var(--font-serif);
    font-size: var(--text-lg);
    color: var(--color-fg);
    font-weight: 500;
    margin: 0;
  }
  :global(.stage-desc) {
    font-family: var(--font-body);
    font-size: var(--text-md);
    color: var(--color-muted);
    line-height: var(--leading-loose);
    margin: 0;
  }
  :global(.stage-note) {
    font-family: var(--font-body);
    font-size: var(--text-sm);
    color: var(--color-muted);
    font-style: italic;
    line-height: var(--leading-loose);
    padding-top: var(--space-md);
    border-top: 0.5px solid var(--color-border);
    margin: 0;
  }

  /* ── Design system modal ─────────────────────────────────────────────── */
  :global(.design-body) { padding-top: var(--space-sm); display: flex; flex-direction: column; gap: var(--space-xxl); }
  :global(.ds-section) { display: flex; flex-direction: column; gap: var(--space-md); }
  :global(.ds-label) {
    font-family: var(--font-body);
    font-size: var(--text-xs);
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--color-muted);
    padding-bottom: var(--space-sm);
    border-bottom: 0.5px solid var(--color-border);
  }
  :global(.ds-swatches) { display: flex; flex-wrap: wrap; gap: var(--space-lg); }
  :global(.ds-swatch) {
    display: flex; flex-direction: column; gap: 4px; align-items: center;
    font-family: var(--font-body); font-size: var(--text-xs); color: var(--color-muted);
  }
  :global(.ds-swatch-block) { width: 48px; height: 48px; border-radius: 12px; }
  :global(.ds-swatch code) {
    font-family: var(--font-body); font-size: 10px; color: var(--color-muted);
    background: var(--color-accent-light); padding: 1px 5px; border-radius: 4px;
  }
  :global(.ds-type-row) {
    display: flex; flex-direction: column; gap: 4px;
    padding-bottom: var(--space-md); border-bottom: 0.5px solid var(--color-border);
  }
  :global(.ds-type-row code) { font-family: var(--font-body); font-size: var(--text-xs); color: var(--color-muted); }
  :global(.ds-type-display) { font-family: var(--font-display); font-size: var(--text-xxl); color: var(--color-fg); }
  :global(.ds-type-serif) { font-family: var(--font-serif); font-size: var(--text-lg); color: var(--color-fg); }
  :global(.ds-type-body) { font-family: var(--font-body); font-size: var(--text-md); color: var(--color-fg); line-height: 1.7; }
  :global(.ds-scale) {
    display: flex; align-items: baseline; gap: var(--space-lg); flex-wrap: wrap;
    font-family: var(--font-body); color: var(--color-muted);
  }
  :global(.ds-spacing-row) { display: flex; align-items: flex-end; gap: var(--space-xl); flex-wrap: wrap; }
  :global(.ds-sp-item) { display: flex; flex-direction: column; align-items: center; gap: 6px; }
  :global(.ds-sp-block) { background: var(--color-accent); border-radius: 2px; }
  :global(.ds-sp-item code) { font-family: var(--font-body); font-size: 10px; color: var(--color-muted); white-space: nowrap; }
  :global(.ds-components) { display: flex; flex-direction: column; gap: var(--space-xl); }
  :global(.ds-comp-group) { display: flex; flex-direction: column; gap: var(--space-sm); }
  :global(.ds-comp-name) { font-family: var(--font-body); font-size: var(--text-xs); color: var(--color-muted); letter-spacing: 0.08em; }
  :global(.ds-comp-row) { display: flex; flex-wrap: wrap; gap: var(--space-sm); align-items: center; }

  /* Component demos — replicate actual styles for JS-injected elements */
  :global(.ds-comp-row .topic-pill) {
    flex-shrink: 0;
    padding: 4px 14px;
    border-radius: var(--radius-pill);
    border: 0.5px solid var(--color-accent-border);
    background: var(--color-pill-bg);
    color: var(--color-pill-text);
    font-family: var(--font-body);
    font-size: var(--text-xs);
    letter-spacing: 0.04em;
    cursor: default;
    white-space: nowrap;
  }
  :global(.ds-comp-row .topic-pill.active) {
    background: var(--color-fg);
    color: var(--color-bg);
    border-color: var(--color-fg);
  }
  :global(:root[data-theme="dark"]) :global(.ds-comp-row .topic-pill.active) {
    background: #ffffff;
    color: #1a1a1a;
    border-color: #ffffff;
  }
  :global(.ds-comp-row .garden-link-btn) {
    background: none;
    border: none;
    padding: 0;
    font-family: var(--font-body);
    font-size: var(--text-sm);
    color: var(--color-muted);
    cursor: default;
    text-decoration: underline;
    text-decoration-color: var(--color-accent-border);
    text-underline-offset: 3px;
  }

  /* ── Garden bar (topics + controls in one row) ───────────────────────── */
  .garden-bar {
    display: flex;
    flex-direction: row;
    align-items: center;
    gap: var(--space-md);
    margin-bottom: var(--space-xxl);
  }
  .topic-pills-scroll {
    flex: 1;
    min-width: 0;
    overflow-x: auto;
    overflow-y: visible;
    scrollbar-width: none;
  }
  .topic-pills-scroll::-webkit-scrollbar { display: none; }
  .topic-pills {
    display: flex;
    gap: var(--space-xs);
    padding-bottom: 2px; /* prevent clipping active outline */
  }
  .topic-pill {
    flex-shrink: 0;
    padding: 4px 14px;
    border-radius: var(--radius-pill);
    border: 0.5px solid var(--color-accent-border);
    background: var(--color-pill-bg);
    color: var(--color-pill-text);
    font-family: var(--font-body);
    font-size: var(--text-xs);
    letter-spacing: 0.04em;
    cursor: pointer;
    transition: background 0.12s, color 0.12s, border-color 0.12s;
    white-space: nowrap;
  }
  .topic-pill:hover:not(.active) { border-color: var(--color-accent); color: var(--color-fg); }
  .topic-pill.active { background: var(--color-fg); color: var(--color-bg); border-color: var(--color-fg); }
  :global(:root[data-theme="dark"]) .topic-pill.active { background: #ffffff; color: #1a1a1a; border-color: #ffffff; }
  .bar-controls {
    display: flex;
    gap: var(--space-sm);
    flex-shrink: 0;
    border-left: 1px solid var(--color-border);
    padding-left: var(--space-md);
  }
  .chip-wrap { position: relative; }
  .chip-wrap:last-child .dropdown { left: auto; right: 0; }
  .control-chip {
    display: inline-flex;
    align-items: center;
    gap: var(--space-xs);
    padding: 5px 14px;
    border-radius: var(--radius-pill);
    border: 0.5px solid var(--color-accent-border);
    background: var(--color-card);
    color: var(--color-fg);
    font-family: var(--font-body);
    font-size: var(--text-xs);
    letter-spacing: 0.05em;
    cursor: pointer;
    transition: border-color 0.12s, background 0.12s;
  }
  .control-chip--icon {
    padding: 5px 8px;
    color: var(--color-muted);
    border-color: transparent;
    background: transparent;
  }
  .control-chip:hover,
  .control-chip[aria-expanded="true"] {
    border-color: var(--color-fg);
    background: var(--color-fg);
    color: #fff;
  }
  .control-chip[aria-expanded="true"] svg { stroke: #fff; }
  .control-chip .hn { font-size: 16px; line-height: 1; }
  .dropdown {
    display: none;
    position: absolute;
    top: calc(100% + 8px);
    left: 0;
    min-width: 220px;
    background: var(--color-card);
    border: 0.5px solid var(--color-border);
    border-radius: var(--radius-card);
    box-shadow: 0 4px 24px rgba(0,0,0,0.08);
    z-index: 200;
    padding: var(--space-lg);
    flex-direction: column;
    gap: var(--space-lg);
  }
  .dropdown.open { display: flex; }
  .bar-controls .chip-wrap:hover .dropdown { display: flex; }
  .bar-controls .chip-wrap::after {
    content: '';
    position: absolute;
    top: 100%;
    left: 0;
    right: 0;
    height: 12px;
  }
  .dropdown-section { display: flex; flex-direction: column; gap: var(--space-sm); }
  .dropdown-label {
    font-family: var(--font-body);
    font-size: var(--text-xs);
    color: var(--color-muted);
    letter-spacing: 0.08em;
  }
  .dropdown-pills { display: flex; flex-wrap: wrap; gap: var(--space-xs); }
  .dpill {
    display: inline-flex;
    align-items: center;
    padding: 4px 12px;
    border-radius: var(--radius-pill);
    border: 0.5px solid var(--color-accent-border);
    background: var(--color-pill-bg);
    color: var(--color-pill-text);
    font-family: var(--font-body);
    font-size: var(--text-xs);
    letter-spacing: 0.04em;
    cursor: pointer;
    transition: background 0.1s, color 0.1s, border-color 0.1s;
