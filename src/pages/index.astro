      function addTab(id, title, content) {
        if (tabs[id]) return; // already there
        var el = document.createElement('div');
        el.className = 'modal-tab-item';
        el.dataset.tabId = id;
        el.innerHTML =
          '<span class="modal-tab-label">' + title + '</span>' +
          '<button class="modal-tab-close" aria-label="Close ' + title + '">' +
            '<svg width="6" height="6" viewBox="0 0 6 6" fill="none">' +
              '<path d="M0.5 0.5l5 5M5.5 0.5l-5 5" stroke="rgba(0,0,0,0.5)" stroke-width="1.1" stroke-linecap="round"/>' +
            '</svg>' +
          '</button>';
        tabs[id] = { content: content, title: title, el: el };
        tabbar.appendChild(el);
        // animate in
        requestAnimationFrame(function () {
          requestAnimationFrame(function () { el.classList.add('tab-visible'); });
        });

        // click label area → restore
        el.querySelector('.modal-tab-label').addEventListener('click', function () {
          var t = tabs[id];
          if (t) { removeTab(id); openModal(t.content, t.title, id); }
        });
        // click close → discard
        el.querySelector('.modal-tab-close').addEventListener('click', function (e) {
          e.stopPropagation();
          removeTab(id);
        });
      }

      function removeTab(id) {
        var t = tabs[id];
        if (!t) return;
        t.el.classList.remove('tab-visible');
        setTimeout(function () { t.el.remove(); }, 300);
        delete tabs[id];
      }

      // Yellow dot → minimize
      document.querySelector('.traffic-yellow')?.addEventListener('click', function () {
        if (!backdrop.classList.contains('open')) return;
        minimizeModal();
