---
// src/pages/index.astro — garden + landing overlay
import Garden from '../layouts/Garden.astro';
import Card from '../components/Card.astro';
import TopicCloud from '../components/TopicCloud.astro';
import { getCollection } from 'astro:content';
import { site } from '../config/design';

const [lab, archives, gallery, library] = await Promise.all([
  getCollection('lab'),
  getCollection('archives'),
  getCollection('gallery'),
  getCollection('library'),
]);

// Featured entries for overlay widgets (up to 6)
const featuredWidgets = [
  ...lab.filter(e => e.data.featured).map(e => ({
    title: e.data.title, slug: e.slug, collection: 'lab' as const,
    type: 'project', preview: e.data.description ?? '',
    date: e.data.date_published ?? e.data.date_built,
  })),
  ...archives.filter(e => e.data.featured).map(e => ({
    title: e.data.title, slug: e.slug, collection: 'archives' as const,
    type: e.data.type, preview: '',
    date: e.data.date_published ?? e.data.date_written,
  })),
  ...gallery.filter(e => e.data.featured).map(e => ({
    title: e.data.title, slug: e.slug, collection: 'gallery' as const,
    type: e.data.medium, preview: e.data.caption ?? '',
    date: e.data.date_published ?? e.data.date_made,
  })),
].slice(0, 6);

// Widget positions: { top, left?, right?, rot, delay }
const positions = [
  { top: '12%', left: '4%',  rot: '-3deg', delay: '0s'   },
  { top:  '8%', right: '4%', rot:  '2deg', delay: '0.6s' },
  { top: '42%', left: '2%',  rot: '-2deg', delay: '1.1s' },
  { top: '42%', right: '2%', rot:  '3deg', delay: '0.3s' },
  { top: '72%', left: '5%',  rot:  '2deg', delay: '0.9s' },
  { top: '68%', right: '5%', rot: '-2deg', delay: '0.5s' },
];

const colIcons: Record<string, string> = {
  lab:      '/icons/lab-icon.png',
  archives: '/icons/archive-icon.png',
  gallery:  '/icons/gallery-icon.png',
  library:  '/icons/lib-icon.png',
};

const allEntries = [
  ...lab.map(e => ({
    ...e, collection: 'lab' as const,
    date: e.data.date_published ?? e.data.date_built,
    topics: e.data.topics ?? [],
  })),
  ...archives.map(e => ({
    ...e, collection: 'archives' as const,
    date: e.data.date_published ?? e.data.date_written,
    topics: e.data.topics ?? [],
  })),
  ...gallery.map(e => ({
    ...e, collection: 'gallery' as const,
    date: e.data.date_published ?? e.data.date_made,
    topics: e.data.topics ?? [],
  })),
  ...library.map(e => ({
    ...e, collection: 'library' as const,
    date: e.data.date_added,
    topics: [],
  })),
].sort((a, b) => b.date.getTime() - a.date.getTime());

// Derive all unique topics across entries, sorted alphabetically
const allTopics = [...new Set(allEntries.flatMap(e => e.topics))].sort();
---

<Garden title={site.name} description={site.description}>

  <!-- ── Landing overlay (hidden for return visitors) ─────────────────── -->
  <div id="landing-overlay" class="landing-overlay">

    <!-- sparkle trail canvas -->
    <canvas id="sparkle-canvas" aria-hidden="true"></canvas>

    <!-- floating project widgets -->
    {featuredWidgets.map((w, i) => {
      const pos = positions[i];
      const posStyle = `top:${pos.top};${'left' in pos ? `left:${pos.left}` : `right:${pos.right}`};--rot:${pos.rot};--float-delay:${pos.delay}`;
      return (
        <a
          href={`/${w.collection}/${w.slug}`}
          class="widget"
          style={posStyle}
          tabindex="-1"
          aria-hidden="true"
        >
          <div class="widget-top">
            <img src={colIcons[w.collection]} class="widget-icon" alt="" />
            <span class="widget-type">{w.type}</span>
          </div>
          <p class="widget-title">{w.title}</p>
          {w.preview && <p class="widget-preview">{w.preview.slice(0, 60)}{w.preview.length > 60 ? '…' : ''}</p>}
        </a>
      );
    })}

    <!-- hero -->
    <div class="hero-inner" id="hero-inner">
      <div class="hero-text">
        <h1 class="hero-title" id="hero-title">{site.name}</h1>
        <p class="hero-bio" id="hero-bio" aria-label={site.description}></p>
      </div>
      <div class="hero-cta">
        <button class="hero-enter" id="enter-btn" aria-label="Enter the garden">
          <img class="keyhole-svg" src="/keyhole.png" alt="" aria-hidden="true" draggable="false"/>
        </button>
      </div>
    </div>
  </div>

  <!-- ── Garden content (always in DOM for SEO) ───────────────────────── -->
  <div class="garden-page" id="garden-content">
    <div class="page-wrapper">

      <header class="garden-header">
        <div class="garden-title-row">
          <h1 class="garden-title">the garden</h1>
          <span class="garden-phonetic">[gahr-dn] &nbsp;/ ˈɡɑːr.dən /</span>
        </div>
        <p class="garden-def">
          a collection of imperfect notes, essays, and ideas growing slowly over time.
        </p>
        <div class="garden-links">
          <a class="garden-link-btn" href="https://maggieappleton.com/garden-history" target="_blank" rel="noopener">what is a digital garden? ↗</a>
          <button class="garden-link-btn" id="btn-story">the story of my digital garden</button>
        </div>
      </header>

      <!-- ── Modals ────────────────────────────────────────────────────── -->
      <div id="modal-backdrop" class="modal-backdrop" aria-hidden="true" role="dialog" aria-modal="true">
        <div class="modal" id="modal-box">
          <button class="modal-close" id="modal-close" aria-label="Close">
            <svg width="14" height="14" viewBox="0 0 14 14" fill="none">
              <path d="M1 1l12 12M13 1L1 13" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
            </svg>
          </button>
          <div id="modal-body" class="modal-body"></div>
        </div>
      </div>

      {allTopics.length > 0 && <TopicCloud topics={allTopics} />}

      <!-- Filter + sort chips -->
      <div class="garden-controls" id="garden-controls">
        <div class="chip-wrap">
          <button class="control-chip" id="filters-btn" aria-expanded="false" aria-haspopup="true">
            <svg width="13" height="13" viewBox="0 0 13 13" fill="none" aria-hidden="true">
              <path d="M1 2.5h11M3 6.5h7M5 10.5h3" stroke="currentColor" stroke-width="1.3" stroke-linecap="round"/>
            </svg>
            filters
          </button>
          <div class="dropdown" id="filters-dropdown" aria-hidden="true">
            <div class="dropdown-section">
              <span class="dropdown-label">growth stage</span>
              <div class="dropdown-pills">
                <button class="dpill active" data-filter-param="stage" data-filter-value="all">all</button>
                <button class="dpill" data-filter-param="stage" data-filter-value="dust">dust</button>
                <button class="dpill" data-filter-param="stage" data-filter-value="spark">spark</button>
                <button class="dpill" data-filter-param="stage" data-filter-value="star">star</button>
              </div>
            </div>
            <div class="dropdown-section">
              <span class="dropdown-label">area</span>
              <div class="dropdown-pills">
                <button class="dpill active" data-filter-param="collection" data-filter-value="all">all</button>
                <button class="dpill" data-filter-param="collection" data-filter-value="archives">archives</button>
                <button class="dpill" data-filter-param="collection" data-filter-value="lab">lab</button>
                <button class="dpill" data-filter-param="collection" data-filter-value="gallery">gallery</button>
                <button class="dpill" data-filter-param="collection" data-filter-value="library">library</button>
              </div>
            </div>
          </div>
        </div>

        <div class="chip-wrap">
          <button class="control-chip" id="sort-btn" aria-expanded="false" aria-haspopup="true">
            <svg width="13" height="13" viewBox="0 0 13 13" fill="none" aria-hidden="true">
              <path d="M1 2.5h5M1 6.5h8M1 10.5h11" stroke="currentColor" stroke-width="1.3" stroke-linecap="round"/>
            </svg>
            sort
          </button>
          <div class="dropdown" id="sort-dropdown" aria-hidden="true">
            <div class="dropdown-section">
              <div class="dropdown-pills">
                <button class="dpill active" data-sort-value="newest">most recent</button>
                <button class="dpill" data-sort-value="oldest">oldest first</button>
                <button class="dpill" data-sort-value="stage">by growth stage</button>
              </div>
            </div>
          </div>
        </div>
      </div>

      <!-- Masonry grid -->
      <div class="masonry" id="garden-masonry">
        {allEntries.map((entry, i) => {
          const data = entry.data as any;
          return (
            <div
              class="masonry-item"
              data-filter={JSON.stringify({ collection: entry.collection, stage: data.growth_stage })}
              data-topics={JSON.stringify(entry.topics)}
              data-date={entry.date.getTime()}
              data-stage={data.growth_stage ?? ''}
              style={`--i: ${i}`}
            >
              <Card
                title={data.title}
                slug={entry.slug}
                collection={entry.collection}
                type={data.type}
                stage={data.growth_stage}
                date_published={data.date_published ?? data.date_added}
                date_written={data.date_written}
                date_built={data.date_built}
                date_made={data.date_made}
                date_added={data.date_added}
                cover_image={data.cover_image ?? data.image}
                rating={data.rating}
                description={data.description}
                body={entry.body}
                creator={data.creator}
                year={data.year}
              />
            </div>
          );
        })}
      </div>

    </div>
  </div>
</Garden>

<style>
  /* ── Landing overlay ──────────────────────────────────────────────────── */
  .landing-overlay {
    position: fixed;
    inset: 0;
    z-index: 500;
    background: var(--color-bg);
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
  }
  .landing-overlay.exiting {
    animation: overlayExit 0.8s ease forwards;
    pointer-events: none;
  }
  @keyframes overlayExit {
    from { opacity: 1; }
    to   { opacity: 0; }
  }
  .landing-overlay.entering {
    animation: overlayEnter 0.45s ease forwards;
  }
  @keyframes overlayEnter {
    from { opacity: 0; }
    to   { opacity: 1; }
  }

  /* ── Sparkle trail canvas ────────────────────────────────────────────── */
  #sparkle-canvas {
    position: fixed;
    inset: 0;
    width: 100%;
    height: 100%;
    pointer-events: none;
    z-index: 1;
  }

  /* ── Floating widgets ────────────────────────────────────────────────── */
  .widget {
    position: absolute;
    cursor: grab;
    width: 172px;
    background: var(--color-card);
    border: 0.5px solid var(--color-border);
    border-radius: var(--radius-card);
    padding: var(--space-md) var(--space-lg);
    text-decoration: none;
    color: inherit;
    transform: rotate(var(--rot, 0deg)) translateY(0px);
    animation: widgetIn 0.7s ease both, widgetFloat 4s ease-in-out infinite;
    animation-delay: var(--float-delay, 0s), var(--float-delay, 0s);
    box-shadow: 0 4px 20px rgba(0,0,0,0.06);
    transition: border-color 0.2s, box-shadow 0.2s, transform 0.2s;
    z-index: 2;
    display: flex;
    flex-direction: column;
    gap: var(--space-xs);
  }
  @keyframes widgetIn {
    from { opacity: 0; transform: rotate(var(--rot, 0deg)) translateY(12px); }
    to   { opacity: 1; transform: rotate(var(--rot, 0deg)) translateY(0); }
  }
  @keyframes widgetFloat {
    0%, 100% { transform: rotate(var(--rot, 0deg)) translateY(0px); }
    50%       { transform: rotate(var(--rot, 0deg)) translateY(-8px); }
  }
  .widget:hover {
    border-color: var(--color-accent);
    box-shadow: 0 8px 32px rgba(0,0,0,0.1);
    transform: rotate(0deg) translateY(-4px) scale(1.02);
    animation-play-state: paused;
  }
  .widget-top {
    display: flex;
    align-items: center;
    gap: var(--space-xs);
  }
  .widget-icon {
    width: 16px;
    height: 16px;
    opacity: 0.6;
  }
  .widget-type {
    font-family: var(--font-body);
    font-size: 10px;
    color: var(--color-accent);
    letter-spacing: 0.07em;
  }
  .widget-title {
    font-family: var(--font-serif);
    font-size: var(--text-sm);
    color: var(--color-fg);
    line-height: var(--leading-tight);
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
  .widget-preview {
    font-family: var(--font-body);
    font-size: 10px;
    color: var(--color-muted);
    line-height: 1.5;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
  @media (max-width: 768px) { .widget { display: none; } }

  /* ── Hero ────────────────────────────────────────────────────────────── */
  .hero-inner {
    text-align: center;
    max-width: 480px;
    padding: 0 var(--space-xl);
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-xxl);
    animation: heroIn 0.7s ease both;
    position: relative;
    z-index: 3;
  }
  @keyframes heroIn {
    from { opacity: 0; transform: translateY(18px); }
    to   { opacity: 1; transform: translateY(0); }
  }
  .landing-overlay.exiting .hero-inner {
    animation: heroOut 0.4s ease forwards;
  }
  @keyframes heroOut {
    to { opacity: 0; transform: translateY(-10px); }
  }

  .hero-text {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-sm);
  }
  .hero-title {
    font-family: var(--font-display);
    font-size: var(--text-hero);
    color: var(--color-fg);
    line-height: var(--leading-tight);
    white-space: nowrap;
    cursor: default;
  }
  /* letter hover — :global because spans are JS-created (no astro scope attr) */
  :global(.hero-title .letter) {
    display: inline-block;
    transition: transform 0.35s cubic-bezier(0.34, 1.56, 0.64, 1), color 0.3s ease;
    cursor: default;
  }
  :global(.hero-title .letter:hover) {
    transform: translateY(-7px);
    color: var(--color-accent);
  }

  .hero-bio {
    font-family: var(--font-body);
    font-size: var(--text-lg);
    color: var(--color-muted);
    line-height: var(--leading-loose);
    min-height: 1.6em;
  }
  /* typewriter cursor */
  .hero-bio::after {
    content: '|';
    color: var(--color-accent);
    animation: blink 0.9s step-end infinite;
    margin-left: 1px;
  }
  .hero-bio.typed::after { display: none; }
  @keyframes blink {
    0%, 100% { opacity: 1; }
    50%       { opacity: 0; }
  }

  .hero-enter {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    background: none;
    border: none;
    padding: 0;
    cursor: pointer;
    color: var(--color-fg);
    opacity: 0.75;
    transition: opacity 0.2s, transform 0.2s;
  }
  .hero-enter:hover {
    opacity: 1;
    transform: scale(1.1);
    cursor: url('/key.png') 16 16, pointer;
  }
  .keyhole-svg {
    width: 52px;
    height: 52px;
    display: block;
    transition: transform 0.1s;
  }
  .hero-enter.spinning .keyhole-svg {
    animation: keyholeSpin 1.1s ease-in-out forwards;
  }
  @keyframes keyholeSpin {
    0%   { transform: rotate(0deg); }
    45%  { transform: rotate(90deg); }
    100% { transform: rotate(0deg); }
  }
  .hero-cta {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-sm);
  }

  /* ── Garden content ───────────────────────────────────────────────────── */
  .garden-page {
    min-height: 100vh;
  }
  .garden-header {
    padding: var(--space-section) 0 var(--space-xxl);
  }
  .garden-title-row {
    display: flex;
    align-items: baseline;
    gap: var(--space-lg);
    flex-wrap: wrap;
    margin-bottom: var(--space-md);
  }
  .garden-title {
    font-family: var(--font-display);
    font-size: var(--text-hero);
    color: var(--color-fg);
    line-height: var(--leading-tight);
  }
  .garden-phonetic {
    font-family: var(--font-body);
    font-size: var(--text-md);
    color: var(--color-muted);
    letter-spacing: 0.02em;
  }
  .garden-def {
    font-family: var(--font-body);
    font-size: var(--text-lg);
    color: var(--color-muted);
    line-height: var(--leading-loose);
    max-width: 560px;
    padding-left: var(--space-xl);
    margin-bottom: var(--space-lg);
  }
  .garden-links {
    display: flex;
    gap: var(--space-lg);
    padding-left: var(--space-xl);
    flex-wrap: wrap;
  }
  .garden-link-btn {
    background: none;
    border: none;
    padding: 0;
    font-family: var(--font-body);
    font-size: var(--text-sm);
    color: var(--color-muted);
    cursor: pointer;
    text-decoration: underline;
    text-decoration-color: var(--color-accent-border);
    text-underline-offset: 3px;
    transition: color 0.15s, text-decoration-color 0.15s;
  }
  .garden-link-btn:hover {
    color: var(--color-fg);
    text-decoration-color: var(--color-accent);
  }

  /* ── Modals ──────────────────────────────────────────────────────────── */
  .modal-backdrop {
    position: fixed;
    inset: 0;
    z-index: 800;
    background: rgba(0,0,0,0.35);
    display: flex;
    align-items: center;
    justify-content: center;
    padding: var(--space-xl);
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.2s ease;
  }
  .modal-backdrop.open {
    opacity: 1;
    pointer-events: all;
  }
  .modal {
    background: var(--color-card);
    border: 0.5px solid var(--color-border);
    border-radius: var(--radius-card);
    box-shadow: 0 8px 48px rgba(0,0,0,0.14);
    width: 100%;
    max-width: 680px;
    max-height: 80vh;
    display: flex;
    flex-direction: column;
    position: relative;
    transform: translateY(12px);
    transition: transform 0.2s ease;
  }
  .modal-backdrop.open .modal {
    transform: translateY(0);
  }
  .modal-close {
    position: absolute;
    top: var(--space-lg);
    right: var(--space-lg);
    background: none;
    border: none;
    color: var(--color-muted);
    cursor: pointer;
    padding: 4px;
    z-index: 1;
    transition: color 0.15s;
  }
  .modal-close:hover { color: var(--color-fg); }
  .modal-body {
    overflow-y: auto;
    padding: var(--space-xxl);
  }
  .modal-body iframe {
    width: 100%;
    height: 60vh;
    border: none;
    border-radius: var(--radius-card);
  }
  /* story modal prose — :global() because content is JS-injected */
  :global(.story-title) {
    font-family: var(--font-display);
    font-size: var(--text-xl);
    color: var(--color-fg);
    margin: 0 0 var(--space-xl);
    padding-bottom: var(--space-lg);
    border-bottom: 0.5px solid var(--color-border);
  }
  :global(.story-body) {
    padding-top: var(--space-sm);
  }
  :global(.story-body p) {
    font-family: var(--font-body);
    font-size: var(--text-md);
    line-height: 1.9;
    color: var(--color-fg);
    margin: 0 0 var(--space-xl);
  }
  :global(.story-body p:first-of-type) {
    font-size: calc(var(--text-md) * 1.05);
  }
  :global(.story-body blockquote) {
    margin: var(--space-xl) 0;
    padding: var(--space-lg) var(--space-xl);
    border-left: 2px solid var(--color-accent);
    background: var(--color-accent-light);
    border-radius: 0 var(--radius-card) var(--radius-card) 0;
  }
  :global(.story-body blockquote p) {
    font-family: var(--font-serif);
    font-style: italic;
    font-size: var(--text-md);
    line-height: 1.75;
    color: var(--color-fg);
    margin-bottom: var(--space-sm);
  }
  :global(.story-body blockquote cite) {
    display: block;
    font-family: var(--font-body);
    font-style: normal;
    font-size: var(--text-sm);
    color: var(--color-muted);
    margin-top: var(--space-sm);
  }
  :global(.story-body a) {
    color: var(--color-fg);
    text-decoration: underline;
    text-decoration-color: var(--color-accent);
    text-underline-offset: 3px;
  }

  /* ── Filter chips (same style as CollectionFilters) ───────────────────── */
  .garden-controls {
    display: flex;
    gap: var(--space-sm);
    margin-bottom: var(--space-xxl);
  }
  .chip-wrap { position: relative; }
  .control-chip {
    display: inline-flex;
    align-items: center;
    gap: var(--space-xs);
    padding: 5px 14px;
    border-radius: var(--radius-pill);
    border: 0.5px solid var(--color-accent-border);
    background: var(--color-card);
    color: var(--color-fg);
    font-family: var(--font-body);
    font-size: var(--text-xs);
    letter-spacing: 0.05em;
    cursor: pointer;
    transition: border-color 0.12s, background 0.12s;
  }
  .control-chip:hover,
  .control-chip[aria-expanded="true"] {
    border-color: var(--color-fg);
    background: var(--color-fg);
    color: #fff;
  }
  .control-chip[aria-expanded="true"] svg { stroke: #fff; }
  .dropdown {
    display: none;
    position: absolute;
    top: calc(100% + 8px);
    left: 0;
    min-width: 220px;
    background: var(--color-card);
    border: 0.5px solid var(--color-border);
    border-radius: var(--radius-card);
    box-shadow: 0 4px 24px rgba(0,0,0,0.08);
    z-index: 200;
    padding: var(--space-lg);
    flex-direction: column;
    gap: var(--space-lg);
  }
  .dropdown.open { display: flex; }
  .dropdown-section { display: flex; flex-direction: column; gap: var(--space-sm); }
  .dropdown-label {
    font-family: var(--font-body);
    font-size: var(--text-xs);
    color: var(--color-muted);
    letter-spacing: 0.08em;
  }
  .dropdown-pills { display: flex; flex-wrap: wrap; gap: var(--space-xs); }
  .dpill {
    display: inline-flex;
    align-items: center;
    padding: 4px 12px;
    border-radius: var(--radius-pill);
    border: 0.5px solid var(--color-accent-border);
    background: var(--color-pill-bg);
    color: var(--color-pill-text);
    font-family: var(--font-body);
    font-size: var(--text-xs);
    letter-spacing: 0.04em;
    cursor: pointer;
    transition: background 0.1s, color 0.1s, border-color 0.1s;
  }
  .dpill.active { background: var(--color-fg); color: #fff; border-color: var(--color-fg); }
  .dpill:hover:not(.active) { border-color: var(--color-accent); color: var(--color-fg); }

  /* ── Masonry ──────────────────────────────────────────────────────────── */
  .masonry {
    columns: 3;
    column-gap: var(--space-xl);
    padding-bottom: var(--space-section);
  }
  .masonry-item {
    break-inside: avoid;
    margin-bottom: var(--space-xl);
    animation: cardIn 0.4s ease both;
    animation-delay: calc(var(--i, 0) * 28ms);
  }
  @keyframes cardIn {
    from { opacity: 0; transform: translateY(10px); }
    to   { opacity: 1; transform: translateY(0); }
  }
  .masonry-item.item-hiding {
    transition: opacity 0.15s ease, transform 0.15s ease;
    opacity: 0;
    transform: scale(0.97);
  }
  .masonry-item.item-in {
    animation: cardIn 0.3s ease both;
  }

  @media (max-width: 900px) { .masonry { columns: 2; } }
  @media (max-width: 600px) {
    .masonry { columns: 1; }
    .garden-title { font-size: var(--text-section); }
    .garden-desc  { font-size: var(--text-md); }
  }
</style>

<script is:inline>
  // ── Overlay ─────────────────────────────────────────────────────────────
  (function () {
    var overlay = document.getElementById('landing-overlay');
    if (!overlay) return;

    // ── Sparkle trail ─────────────────────────────────────────────────────
    var sparkCanvas = document.getElementById('sparkle-canvas');
    var sparkCtx = sparkCanvas ? sparkCanvas.getContext('2d') : null;
    var particles = [];
    var mouseX = window.innerWidth / 2, mouseY = window.innerHeight / 2;
    var sparkRunning = false;

    function resizeSparkCanvas() {
      if (!sparkCanvas) return;
      sparkCanvas.width  = window.innerWidth;
      sparkCanvas.height = window.innerHeight;
    }
    resizeSparkCanvas();
    window.addEventListener('resize', resizeSparkCanvas);

    var prevMouseX = mouseX, prevMouseY = mouseY;
    document.addEventListener('mousemove', function (e) {
      mouseX = e.clientX; mouseY = e.clientY;
    });

    function spawnParticle(x, y) {
      var size = 6 + Math.random() * 9;           // big stars: 6–15px
      // tiny random nudge so trail has texture, not a single line
      var scatter = 8;
      particles.push({
        x:  x + (Math.random() - 0.5) * scatter,
        y:  y + (Math.random() - 0.5) * scatter,
        vx: (Math.random() - 0.5) * 0.6,          // drift sideways gently
        vy: -0.4 - Math.random() * 0.8,            // float upward slowly
        size: size,
        life: 1,
        decay: 0.012 + Math.random() * 0.012,      // linger ~60–80 frames
        twinkle: Math.random() * Math.PI * 2,
      });
    }

    function startGlow() {
      if (sparkRunning || !sparkCtx) return;
      sparkRunning = true;
      (function loop() {
        if (overlay.style.display === 'none') {
          sparkCtx.clearRect(0, 0, sparkCanvas.width, sparkCanvas.height);
          particles.length = 0;
          sparkRunning = false;
          return;
        }

        // Spawn along the path between last and current mouse position
        var dx = mouseX - prevMouseX, dy = mouseY - prevMouseY;
        var dist = Math.sqrt(dx * dx + dy * dy);
        // one particle every ~6px of movement; minimum 1 if mouse moved at all
        if (dist > 0) {
          var steps = Math.max(1, Math.round(dist / 6));
          for (var s = 0; s < steps; s++) {
            var t = steps === 1 ? 0 : s / (steps - 1);
            spawnParticle(prevMouseX + dx * t, prevMouseY + dy * t);
          }
        }
        prevMouseX = mouseX; prevMouseY = mouseY;

        sparkCtx.clearRect(0, 0, sparkCanvas.width, sparkCanvas.height);
        for (var i = particles.length - 1; i >= 0; i--) {
          var p = particles[i];
          p.x      += p.vx;
          p.y      += p.vy;
          p.life   -= p.decay;
          p.twinkle += 0.25;
          if (p.life <= 0) { particles.splice(i, 1); continue; }

          var flicker = Math.max(0, p.life + Math.sin(p.twinkle) * 0.12);
          var sz = p.size * Math.sqrt(flicker);    // shrink gracefully

          sparkCtx.save();
          sparkCtx.globalAlpha = Math.min(1, flicker);
          sparkCtx.fillStyle = '#ffffff';

          // ✦ 4-pointed star: tall vertical + wide horizontal cross
          sparkCtx.fillRect(p.x - sz * 0.14, p.y - sz,       sz * 0.28, sz * 2);
          sparkCtx.fillRect(p.x - sz,        p.y - sz * 0.14, sz * 2,   sz * 0.28);

          // × diagonal arms at 50% opacity
          sparkCtx.globalAlpha = Math.min(1, flicker * 0.5);
          sparkCtx.translate(p.x, p.y);
          sparkCtx.rotate(Math.PI / 4);
          var dz = sz * 0.7;
          sparkCtx.fillRect(-dz * 0.14, -dz, dz * 0.28, dz * 2);
          sparkCtx.fillRect(-dz,        -dz * 0.14, dz * 2, dz * 0.28);

          sparkCtx.restore();
        }
        requestAnimationFrame(loop);
      })();
    }

    // ── Letter wave on title (one-time) ───────────────────────────────────
    var titleEl = document.getElementById('hero-title');
    if (titleEl && !titleEl.querySelector('.letter')) {
      titleEl.innerHTML = (titleEl.textContent || '').split('').map(function (ch, i) {
        return ch === ' ' ? ' ' : '<span class="letter" style="--li:' + i + '">' + ch + '</span>';
      }).join('');
    }

    // ── Typewriter ────────────────────────────────────────────────────────
    var bioEl = document.getElementById('hero-bio');
    var fullText = bioEl ? (bioEl.getAttribute('aria-label') || '') : '';
    var typeTimer = null;
    function startTypewriter() {
      if (!bioEl || !fullText) return;
      clearInterval(typeTimer);
      bioEl.textContent = '';
      bioEl.classList.remove('typed');
      var idx = 0;
      setTimeout(function () {
        typeTimer = setInterval(function () {
          idx++;
          bioEl.textContent = fullText.slice(0, idx);
          if (idx >= fullText.length) { clearInterval(typeTimer); bioEl.classList.add('typed'); }
        }, 38);
      }, 600);
    }

    // ── Show overlay ──────────────────────────────────────────────────────
    function showOverlay() {
      overlay.style.display = 'flex';
      overlay.classList.remove('exiting', 'entering');
      void overlay.offsetWidth;
      overlay.classList.add('entering');
      document.getElementById('enter-btn')?.classList.remove('spinning');
      startGlow();
      startTypewriter();
      if (physicsInited) runPhysics();
      else setTimeout(initWidgetPhysics, 900);
    }

    // ── Hide overlay ──────────────────────────────────────────────────────
    function hideOverlay() {
      overlay.classList.remove('entering');
      overlay.classList.add('exiting');
      setTimeout(function () {
        overlay.style.display = 'none';
        overlay.classList.remove('exiting');
        localStorage.setItem('gi-garden-entered', '1');
      }, 820);
    }

    // ── Init ──────────────────────────────────────────────────────────────
    if (localStorage.getItem('gi-garden-entered')) {
      overlay.style.display = 'none';
    } else {
      startGlow();
      startTypewriter();
      setTimeout(initWidgetPhysics, 900);
    }

    // ── Widget physics ────────────────────────────────────────────────────
    var pWidgets = [];
    var dragW = null;
    var physicsInited = false;
    var physicsRaf = null;

    function initWidgetPhysics() {
      if (physicsInited) return;
      physicsInited = true;
      document.querySelectorAll('.widget').forEach(function(el) {
        var rect = el.getBoundingClientRect();
        var rot = parseFloat(el.style.getPropertyValue('--rot') || '0');
        var pw = { el: el, x: rect.left, y: rect.top, w: rect.width, h: rect.height, vx: 0, vy: 0, rot: rot };
        el.style.animation = 'none';
        el.style.position = 'fixed';
        el.style.left = '0'; el.style.top = '0'; el.style.right = 'auto';
        el.style.transform = 'translate(' + pw.x + 'px,' + pw.y + 'px) rotate(' + pw.rot + 'deg)';
        pWidgets.push(pw);

        el.addEventListener('pointerdown', function(e) {
          e.preventDefault();
          dragW = pw;
          pw.wasDragged = false;
          pw.dragOX = e.clientX - pw.x;
          pw.dragOY = e.clientY - pw.y;
          pw.lastX = e.clientX; pw.lastY = e.clientY;
          el.style.zIndex = '20'; el.style.cursor = 'grabbing';
          el.setPointerCapture(e.pointerId);
        });
        el.addEventListener('pointermove', function(e) {
          if (dragW !== pw) return;
          pw.vx = e.clientX - pw.lastX; pw.vy = e.clientY - pw.lastY;
          pw.lastX = e.clientX; pw.lastY = e.clientY;
          pw.x = e.clientX - pw.dragOX; pw.y = e.clientY - pw.dragOY;
          pw.wasDragged = true;
          el.style.transform = 'translate(' + pw.x + 'px,' + pw.y + 'px) rotate(' + pw.rot + 'deg)';
        });
        el.addEventListener('pointerup', function() {
          if (dragW !== pw) return;
          dragW = null;
          el.style.zIndex = '2'; el.style.cursor = 'grab';
        });
        el.addEventListener('click', function(e) {
          if (pw.wasDragged) { e.preventDefault(); pw.wasDragged = false; }
        });
      });
      runPhysics();
    }

    function runPhysics() {
      if (physicsRaf) cancelAnimationFrame(physicsRaf);
      function loop() {
        if (!document.getElementById('landing-overlay') || document.getElementById('landing-overlay').style.display === 'none') {
          physicsRaf = null; return;
        }
        // Collision resolution
        for (var it = 0; it < 3; it++) {
          for (var i = 0; i < pWidgets.length; i++) {
            for (var j = i + 1; j < pWidgets.length; j++) {
              var a = pWidgets[i], b = pWidgets[j];
              var dx = (a.x + a.w / 2) - (b.x + b.w / 2);
              var dy = (a.y + a.h / 2) - (b.y + b.h / 2);
              var ox = (a.w + b.w) / 2 - Math.abs(dx);
              var oy = (a.h + b.h) / 2 - Math.abs(dy);
              if (ox > 0 && oy > 0) {
                if (ox < oy) {
                  var p = ox * 0.4 * Math.sign(dx);
                  if (a !== dragW) { a.vx += p; a.x += p * 0.5; }
                  if (b !== dragW) { b.vx -= p; b.x -= p * 0.5; }
                } else {
                  var p = oy * 0.4 * Math.sign(dy);
                  if (a !== dragW) { a.vy += p; a.y += p * 0.5; }
                  if (b !== dragW) { b.vy -= p; b.y -= p * 0.5; }
                }
              }
            }
          }
        }
        // Hero obstacle (static — re-read each frame to handle resize)
        var heroEl = document.getElementById('hero-inner');
        if (heroEl) {
          var pad = 24;
          var hr = heroEl.getBoundingClientRect();
          var hx = hr.left - pad, hy = hr.top - pad, hw = hr.width + pad * 2, hh = hr.height + pad * 2;
          pWidgets.forEach(function(pw) {
            var dx = (pw.x + pw.w / 2) - (hx + hw / 2);
            var dy = (pw.y + pw.h / 2) - (hy + hh / 2);
            var ox = (pw.w + hw) / 2 - Math.abs(dx);
            var oy = (pw.h + hh) / 2 - Math.abs(dy);
            if (ox > 0 && oy > 0) {
              if (ox < oy) {
                var push = ox * Math.sign(dx);
                pw.x += push;
                if (pw !== dragW) pw.vx += push * 0.5;
              } else {
                var push = oy * Math.sign(dy);
                pw.y += push;
                if (pw !== dragW) pw.vy += push * 0.5;
              }
              pw.el.style.transform = 'translate(' + pw.x + 'px,' + pw.y + 'px) rotate(' + pw.rot + 'deg)';
            }
          });
        }

        // Integrate + boundary
        pWidgets.forEach(function(pw) {
          if (pw === dragW) return;
          pw.vx *= 0.78; pw.vy *= 0.78;
          pw.x += pw.vx; pw.y += pw.vy;
          var maxX = window.innerWidth - pw.w - 8, maxY = window.innerHeight - pw.h - 8;
          if (pw.x < 8)    { pw.x = 8;    pw.vx =  Math.abs(pw.vx) * 0.4; }
          if (pw.x > maxX) { pw.x = maxX; pw.vx = -Math.abs(pw.vx) * 0.4; }
          if (pw.y < 8)    { pw.y = 8;    pw.vy =  Math.abs(pw.vy) * 0.4; }
          if (pw.y > maxY) { pw.y = maxY; pw.vy = -Math.abs(pw.vy) * 0.4; }
          pw.el.style.transform = 'translate(' + pw.x + 'px,' + pw.y + 'px) rotate(' + pw.rot + 'deg)';
        });
        physicsRaf = requestAnimationFrame(loop);
      }
      physicsRaf = requestAnimationFrame(loop);
    }

    document.getElementById('enter-btn')?.addEventListener('click', function () {
      var btn = document.getElementById('enter-btn');
      if (!btn || btn.classList.contains('spinning')) return;
      btn.classList.add('spinning');
      // wait for spin to finish, then hide overlay
      setTimeout(hideOverlay, 1050);
    });

    // ── Modal ──────────────────────────────────────────────────────────────
    (function () {
      var backdrop = document.getElementById('modal-backdrop');
      var body     = document.getElementById('modal-body');

      var storyHTML = `
        <h2 class="story-title">the story of my digital garden</h2>
        <div class="story-body">
          <p>I've struggled with perfectionism and people-pleasing for a lot of my life. I grew up wanting
          to be everyone's everything and never wanting to put out something that wasn't already perfect.
          So I mostly just never put anything out.</p>
          <p>I have a lot of projects and thoughts I keep in a very private journal. The things that I
          would love to share if I just had a little courage, or if I just didn't care as much about
          what others thought. Things that would gather dust until they were too outdated to ever post.</p>
          <p>I tried doing it in LinkedIn (professional panic), Instagram (felt too personal), a
          Wordpress blog (close, but the pressure of "posting" still got to me). I needed a space
          where the bar was lower—where things could exist without being finished.</p>
          <p>While browsing the World Wide Web, I found the concept of Digital Gardening through
          <a href="https://maggieappleton.com" target="_blank" rel="noopener">Maggie Appleton's</a> website.
          A way of thinking about personal websites less like a broadcast and more like a living
          workspace—somewhere ideas could grow slowly, visibly, without shame.</p>
          <blockquote>
            <p>"Digital gardening is… both intimate and public, weird and welcoming. It's less
            performative than a blog, but more intentional and thoughtful than a Twitter feed. It wants
            to build personal knowledge over time, rather than engage in banter and quippy conversations."</p>
            <cite>— Maggie Appleton</cite>
          </blockquote>
          <p>Currently this digital garden is a dirt patch compared to other sprawling personal
          knowledge webs and second brains out there, but this is me being okay with the wet paint.</p>
        </div>`;

      function openModal(content) {
        body.innerHTML = content;
        backdrop.removeAttribute('aria-hidden');
        backdrop.classList.add('open');
        document.body.style.overflow = 'hidden';
      }

      function closeModal() {
        backdrop.classList.remove('open');
        backdrop.setAttribute('aria-hidden', 'true');
        document.body.style.overflow = '';
        setTimeout(function () { body.innerHTML = ''; }, 300);
      }

      document.getElementById('btn-story')?.addEventListener('click', function () {
        openModal(storyHTML);
      });

      document.getElementById('modal-close')?.addEventListener('click', closeModal);

      backdrop?.addEventListener('click', function (e) {
        if (e.target === backdrop) closeModal();
      });

      document.addEventListener('keydown', function (e) {
        if (e.key === 'Escape' && backdrop.classList.contains('open')) closeModal();
      });
    })();

    document.querySelector('.nav-logo')?.addEventListener('click', function (e) {
      e.preventDefault();
      localStorage.removeItem('gi-garden-entered');
      showOverlay();
    });
  })();

  // ── State ────────────────────────────────────────────────────────────────
  var activeFilters = { stage: 'all', collection: 'all' };
  var activeTopic   = 'all';
  var activeSort    = 'newest';
  var stageOrder    = { dust: 1, spark: 2, star: 3 };

  // ── Apply all (filter + topic + sort) ───────────────────────────────────
  function applyAll() {
    var items = Array.from(document.querySelectorAll('.masonry-item'));

    items.forEach(function (item, idx) {
      var f      = JSON.parse(item.dataset.filter || '{}');
      var topics = JSON.parse(item.dataset.topics || '[]');

      var topicOk = activeTopic === 'all' || topics.indexOf(activeTopic) !== -1;
      var stageOk = activeFilters.stage === 'all' || f.stage === activeFilters.stage;
      var colOk   = activeFilters.collection === 'all' || f.collection === activeFilters.collection;
      var visible = topicOk && stageOk && colOk;

      if (visible) {
        item.style.display = '';
        item.classList.remove('item-hiding');
        item.classList.remove('item-in');
        void item.offsetWidth;
        item.style.animationDelay = idx * 28 + 'ms';
        item.classList.add('item-in');
      } else {
        item.classList.add('item-hiding');
        item.addEventListener('transitionend', function handler() {
          if (item.classList.contains('item-hiding')) {
            item.style.display = 'none';
            item.classList.remove('item-hiding');
          }
          item.removeEventListener('transitionend', handler);
        });
      }
    });
  }

  function applySort() {
    var container = document.getElementById('garden-masonry');
    if (!container) return;
    var items = Array.from(container.querySelectorAll('.masonry-item'));
    items.sort(function (a, b) {
      var ad  = Number(a.dataset.date), bd = Number(b.dataset.date);
      var as_ = stageOrder[a.dataset.stage] || 0;
      var bs_ = stageOrder[b.dataset.stage] || 0;
      if (activeSort === 'newest') return bd - ad;
      if (activeSort === 'oldest') return ad - bd;
      if (activeSort === 'stage')  return bs_ - as_;
      return 0;
    });
    items.forEach(function (i) { container.appendChild(i); });
    applyAll();
  }

  // ── Topic cloud ──────────────────────────────────────────────────────────
  document.querySelectorAll('#topic-cloud .topic-pill').forEach(function (pill) {
    pill.addEventListener('click', function () {
      activeTopic = pill.dataset.topic;
      document.querySelectorAll('#topic-cloud .topic-pill').forEach(function (p) {
        p.classList.toggle('active', p === pill);
      });
      applyAll();
    });
  });

  // ── Filter chips ─────────────────────────────────────────────────────────
  document.querySelectorAll('.dpill[data-filter-param]').forEach(function (pill) {
    pill.addEventListener('click', function () {
      activeFilters[pill.dataset.filterParam] = pill.dataset.filterValue;
      pill.closest('.dropdown-pills').querySelectorAll('.dpill')
        .forEach(function (p) { p.classList.toggle('active', p === pill); });
      applyAll();
    });
  });

  document.querySelectorAll('.dpill[data-sort-value]').forEach(function (pill) {
    pill.addEventListener('click', function () {
      activeSort = pill.dataset.sortValue;
      pill.closest('.dropdown-pills').querySelectorAll('.dpill')
        .forEach(function (p) { p.classList.toggle('active', p === pill); });
      applySort();
    });
  });

  // ── Dropdown toggles ─────────────────────────────────────────────────────
  function initDropdown(btnId, dropId) {
    var btn  = document.getElementById(btnId);
    var drop = document.getElementById(dropId);
    if (!btn || !drop) return;
    btn.addEventListener('click', function (e) {
      e.stopPropagation();
      var open = drop.classList.toggle('open');
      btn.setAttribute('aria-expanded', String(open));
      drop.setAttribute('aria-hidden', String(!open));
      document.querySelectorAll('.dropdown').forEach(function (d) {
        if (d !== drop) d.classList.remove('open');
      });
      document.querySelectorAll('.control-chip').forEach(function (b) {
        if (b !== btn) b.setAttribute('aria-expanded', 'false');
      });
    });
  }

  document.addEventListener('click', function () {
    document.querySelectorAll('.dropdown').forEach(function (d) { d.classList.remove('open'); });
    document.querySelectorAll('.control-chip').forEach(function (b) { b.setAttribute('aria-expanded', 'false'); });
  });

  initDropdown('filters-btn', 'filters-dropdown');
  initDropdown('sort-btn',    'sort-dropdown');
</script>
