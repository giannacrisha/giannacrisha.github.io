  // ── State ────────────────────────────────────────────────────────────────
  var activeStage  = 'all';
  var activeTopics = new Set(); // empty = show all
  var activeSort   = 'newest';
  var stageOrder   = { dust: 1, spark: 2, star: 3 };
  var sectionTimers = new Map();

  // ── Animated section show/hide (fade then height collapse) ───────────────
  function setSection(section, visible) {
    clearTimeout(sectionTimers.get(section));
    if (visible) {
      var startH = section.scrollHeight || 0;
      section.style.transition = 'none';
      section.style.height     = startH === 0 ? '0px' : section.style.height || '';
      section.style.opacity    = section.style.opacity || '0';
      section.style.overflow   = 'hidden';
      section.style.display    = '';
      // measure natural height
      var targetH = section.scrollHeight;
      requestAnimationFrame(function () {
        section.style.transition = 'opacity 0.22s ease, height 0.32s ease';
        section.style.opacity    = '1';
        section.style.height     = targetH + 'px';
        var t = setTimeout(function () {
          section.style.height     = '';
          section.style.overflow   = '';
          section.style.transition = '';
        }, 340);
        sectionTimers.set(section, t);
      });
    } else {
      var h = section.scrollHeight;
      section.style.transition = 'none';
      section.style.height     = h + 'px';
      section.style.overflow   = 'hidden';
      requestAnimationFrame(function () {
        section.style.transition = 'opacity 0.2s ease, height 0.32s ease 0.16s';
        section.style.opacity    = '0';
        section.style.height     = '0px';
        var t = setTimeout(function () {
          section.style.display    = 'none';
          section.style.height     = '';
          section.style.overflow   = '';
          section.style.transition = '';
        }, 520);
        sectionTimers.set(section, t);
      });
    }
  }

  // ── Apply filters + sort to every shelf row ───────────────────────────────
  function applyAll() {
    document.querySelectorAll('.shelf-section').forEach(function (section) {
      var row   = section.querySelector('.shelf-row');
      if (!row) return;
      var items = Array.from(row.querySelectorAll('.shelf-item'));

      // Sort within the row
      items.sort(function (a, b) {
        var ad = Number(a.dataset.date), bd = Number(b.dataset.date);
        var as_ = stageOrder[a.dataset.stage] || 0;
        var bs_ = stageOrder[b.dataset.stage] || 0;
        if (activeSort === 'newest') return bd - ad;
        if (activeSort === 'oldest') return ad - bd;
        if (activeSort === 'stage')  return bs_ - as_;
        return 0;
      });
      items.forEach(function (i) { row.appendChild(i); });

      // Filter each item
      var anyVisible = false;
      items.forEach(function (item) {
        var topics  = JSON.parse(item.dataset.topics || '[]');
        var topicOk = activeTopics.size === 0 ||
          topics.some(function (t) { return activeTopics.has(t); });
        var stageOk = activeStage === 'all' || item.dataset.stage === activeStage;
        var visible = topicOk && stageOk;
        item.classList.toggle('item-hiding', !visible);
        if (visible) anyVisible = true;
      });

      setSection(section, anyVisible);
    });
  }

  // ── Topic pills (multi-select) ────────────────────────────────────────────
  document.querySelectorAll('#topic-cloud .topic-pill').forEach(function (pill) {
    pill.addEventListener('click', function () {
      var topic = pill.dataset.topic;
      if (topic === 'all') {
        activeTopics.clear();
      } else {
        if (activeTopics.has(topic)) {
          activeTopics.delete(topic);
        } else {
          activeTopics.add(topic);
        }
      }
      // Sync pill active states
      document.querySelectorAll('#topic-cloud .topic-pill').forEach(function (p) {
        var t = p.dataset.topic;
        if (t === 'all') {
          p.classList.toggle('active', activeTopics.size === 0);
        } else {
          p.classList.toggle('active', activeTopics.has(t));
        }
      });
      applyAll();
    });
  });

  // ── Filter + sort pills ───────────────────────────────────────────────────
  document.querySelectorAll('.dpill[data-filter-param]').forEach(function (pill) {
    pill.addEventListener('click', function () {
      activeStage = pill.dataset.filterValue;
      pill.closest('.dropdown-pills').querySelectorAll('.dpill')
        .forEach(function (p) { p.classList.toggle('active', p === pill); });
      applyAll();
    });
  });

  document.querySelectorAll('.dpill[data-sort-value]').forEach(function (pill) {
    pill.addEventListener('click', function () {
      activeSort = pill.dataset.sortValue;
      pill.closest('.dropdown-pills').querySelectorAll('.dpill')
        .forEach(function (p) { p.classList.toggle('active', p === pill); });
      applyAll();
    });
  });

  // ── Dropdown toggles ─────────────────────────────────────────────────────
  function initDropdown(btnId, dropId) {
    var btn  = document.getElementById(btnId);
    var drop = document.getElementById(dropId);
    if (!btn || !drop) return;
    btn.addEventListener('click', function (e) {
      e.stopPropagation();
      var open = drop.classList.toggle('open');
      btn.setAttribute('aria-expanded', String(open));
      drop.setAttribute('aria-hidden', String(!open));
      document.querySelectorAll('.dropdown').forEach(function (d) {
        if (d !== drop) d.classList.remove('open');
      });
      document.querySelectorAll('.control-chip').forEach(function (b) {
        if (b !== btn) b.setAttribute('aria-expanded', 'false');
      });
    });
  }

  document.addEventListener('click', function () {
    document.querySelectorAll('.dropdown').forEach(function (d) { d.classList.remove('open'); });
    document.querySelectorAll('.control-chip').forEach(function (b) { b.setAttribute('aria-expanded', 'false'); });
  });

  initDropdown('filters-btn', 'filters-dropdown');
</script>
