      document.getElementById('modal-fullscreen')?.addEventListener('click', function () {
        if (!backdrop.classList.contains('open')) return;
        isFullscreen = !isFullscreen;
        box.classList.toggle('modal--fullscreen', isFullscreen);
        backdrop.classList.toggle('modal-backdrop--fullscreen', isFullscreen);
        // swap icon between expand arrows and compress arrows
        var icon = this.querySelector('.traffic-icon');
        if (isFullscreen) {
          icon.innerHTML = '<path d="M3 1H1v2M1 3V1M7 3V1H5M5 1h2M5 7h2v-2M7 5v2M1 5v2h2M3 7H1" stroke="currentColor" stroke-width="1.1" stroke-linecap="round" stroke-linejoin="round"/>';
        } else {
