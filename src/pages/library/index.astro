---
// src/pages/library/index.astro
import Garden from '../../layouts/Garden.astro';
import Card from '../../components/Card.astro';
import FilterBar from '../../components/FilterBar.astro';
import { getCollection } from 'astro:content';

const entries = await getCollection('library');
const sorted = entries.sort((a, b) => b.data.date_added.getTime() - a.data.date_added.getTime());

const filterGroups = [
  {
    param: 'type',
    label: 'type',
    options: [
      { value: 'all', label: 'all' },
      { value: 'film', label: 'film' },
      { value: 'book', label: 'book' },
      { value: 'album', label: 'album' },
      { value: 'show', label: 'show' },
    ],
  },
];
---
<Garden title="library">
  <div class="site-wrapper">
    <div class="page-header">
      <h1 class="section-header">library</h1>
      <p class="page-desc">films, books, albums, shows</p>
    </div>
    <FilterBar groups={filterGroups} />
    <div class="card-grid">
      {sorted.map(entry => (
        <div data-filter={JSON.stringify({ type: entry.data.type })}>
          <Card
            title={entry.data.title}
            slug={entry.slug}
            collection="library"
            type={entry.data.type}
            date_published={entry.data.date_added}
            date_added={entry.data.date_added}
            cover_image={entry.data.cover_image}
            rating={entry.data.rating}
            creator={entry.data.creator}
            year={entry.data.year}
          />
        </div>
      ))}
    </div>
  </div>
</Garden>

<style>
  .page-header { padding: var(--space-section) 0 var(--space-xxl); }
  .page-desc { font-family: var(--font-body); font-size: var(--text-md); color: var(--color-muted); margin-top: var(--space-sm); }
</style>
