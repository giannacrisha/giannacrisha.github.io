---
import Garden from '../layouts/Garden.astro';
import Icon from '../components/Icon.astro';
import IdentityWeb from '../components/IdentityWeb.astro';
---
<Garden title="about">
  <div class="page-wrapper">
    <div class="about">

      <!-- hero intro (full viewport) -->
      <section class="about-hero-section" id="about-top">
        <img src="/images/portrait.png" alt="Gianna Crisha Saludo" class="portrait" />
        <h1 class="about-name">gianna crisha</h1>
        <p class="about-role">design, tech & society ·</p>
        <p class="about-bio">
          my design is very human. at brandeis, i'm designing my major in design, tech, and society.
          whether that's building interfaces or advocating for tech policy, i'm always thinking about
          how the things we make shape the people who use them.
        </p>
      </section>

      <!-- migration history -->
      <section class="about-section">
        <h2 class="section-heading">where's home?</h2>
        <div class="migration-map">
          <div id="migration-leaflet" style="height:340px;width:100%;"></div>

          <div class="migration-card">
            <div class="migration-card-header">
              <div class="migration-progress" id="migration-progress">
                <span id="migration-step">1</span> / 5
              </div>
              <div class="migration-nav">
                <button id="migration-prev" aria-label="previous city" disabled>
                  <Icon name="chevron-left" size={14} />
                </button>
                <button id="migration-next" aria-label="next city">
                  <Icon name="chevron-right" size={14} />
                </button>
              </div>
            </div>
            <p class="migration-city-name" id="migration-city-name"></p>
            <p class="migration-city-sub" id="migration-city-sub"></p>
            <p class="migration-city-text" id="migration-city-text"></p>
          </div>
        </div>
      </section>

      <!-- identity web -->
      <section class="about-section">
        <h2 class="section-heading">who am i?</h2>
        <IdentityWeb />
      </section>

      <!-- linkedin -->
      <section class="about-section">
        <h2 class="section-heading">what i've done</h2>
        <a href="https://linkedin.com/in/giannacrisha" target="_blank" rel="noopener noreferrer" class="linkedin-cta">
          <Icon name="linkedin" size={22} />
          <span>see my full experience on linkedin</span>
          <Icon name="chevron-right" size={16} />
        </a>
      </section>


    </div>
  </div>
</Garden>

<style>
  .about {
    max-width: 720px;
    padding: 0 0 calc(var(--space-section) * 2);
    display: flex;
    flex-direction: column;
    gap: var(--space-section);
  }

  /* full-viewport hero */
  .about-hero-section {
    min-height: calc(100vh - 60px);
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    text-align: center;
    gap: var(--space-md);
    padding: var(--space-section) 0;
    position: relative;
  }
  .portrait {
    width: 160px;
    aspect-ratio: 3 / 4;
    object-fit: cover;
    object-position: center top;
    border-radius: var(--radius-card);
    display: block;
    margin-bottom: var(--space-sm);
  }
  .about-name {
    font-family: var(--font-serif);
    font-weight: 600;
    font-size: var(--text-section);
    color: var(--color-heading);
    line-height: 1.1;
  }
  .about-role {
    font-family: var(--font-body);
    font-size: var(--text-md);
    color: var(--color-muted);
  }
  .about-bio {
    font-family: var(--font-body);
    font-size: var(--text-md);
    color: var(--color-fg);
    line-height: var(--leading-loose);
    max-width: 480px;
    margin-top: var(--space-sm);
  }
  @media (min-width: 600px) {
    .portrait { width: 200px; }
  }

  /* sections */
  .about-section {
    display: flex;
    flex-direction: column;
    gap: var(--space-xl);
  }
  .section-heading {
    font-family: var(--font-serif);
    font-weight: 600;
    font-size: var(--text-xxl);
    color: var(--color-heading);
    line-height: var(--leading-tight);
  }

  /* now list */
  /* linkedin cta */
  .linkedin-cta {
    display: inline-flex;
    align-items: center;
    gap: var(--space-md);
    font-family: var(--font-body);
    font-size: var(--text-md);
    color: var(--color-heading);
    text-decoration: none;
    border: 1px solid var(--color-accent-border);
    border-radius: var(--radius-pill);
    padding: var(--space-md) var(--space-xl);
    transition: background 0.18s, border-color 0.18s, color 0.18s;
  }
  .linkedin-cta:hover {
    background: var(--color-accent-light);
    border-color: var(--color-heading);
  }

  /* migration map */
  .migration-intro {
    font-family: var(--font-body);
    font-size: var(--text-md);
    color: var(--color-muted);
    font-style: italic;
  }
  .migration-map {
    display: flex;
    flex-direction: column;
    gap: 0;
    border-radius: var(--radius-card);
    overflow: hidden;
  }
  #migration-leaflet {
    height: 340px;
    width: 100%;
    z-index: 0;
  }
  .migration-card {
    background: #ffffff;
    padding: var(--space-xl);
    display: flex;
    flex-direction: column;
    gap: var(--space-md);
  }
  .migration-card-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
  }
  .migration-progress {
    font-family: var(--font-body);
    font-size: var(--text-xs);
    color: var(--color-muted);
    letter-spacing: 0.06em;
  }
  .migration-nav {
    display: flex;
    gap: var(--space-sm);
  }
  .migration-nav button {
    background: none;
    border: 1px solid var(--color-border);
    border-radius: 50%;
    width: 30px;
    height: 30px;
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--color-fg);
    cursor: pointer;
    transition: background 0.15s, border-color 0.15s;
  }
  .migration-nav button:hover:not(:disabled) {
    background: var(--color-accent-light);
    border-color: var(--color-accent);
  }
  .migration-nav button:disabled {
    opacity: 0.3;
    cursor: default;
  }
  .migration-city-name {
    font-family: var(--font-serif);
    font-size: var(--text-xl);
    color: var(--color-fg);
    line-height: var(--leading-tight);
  }
  .migration-city-sub {
    font-family: var(--font-body);
    font-size: var(--text-sm);
    color: var(--color-accent);
    letter-spacing: 0.04em;
  }
  .migration-city-text {
    font-family: var(--font-body);
    font-size: var(--text-md);
    color: var(--color-fg);
    line-height: var(--leading-loose);
  }

  @media (min-width: 600px) {
  }
</style>


<script>
import L from 'leaflet';
import 'leaflet/dist/leaflet.css';

const stops = [
  {
    name: 'antipolo',
    sub: 'philippines · 2004 – 2014',
    lat: 14.5888, lng: 121.1228, zoom: 13,
    text: 'i was born in quezon city and raised in antipolo city. my family owned a small internet cafe, one of the firsts in the area. This is where i fell in love with computers. our house had two spaces: the back was our living space and the front was the internet cafe, where i spent my after-school hours playing games and exploring the web. at six, i troubleshot my first computer problem and became the family technician.',
  },
  {
    name: 'abu dhabi',
    sub: 'uae · 2014 – 2017',
    lat: 24.4539, lng: 54.3773, zoom: 11,
    text: 'we moved to abu dhabi after 4th grade. i wrote a story about it! my brother and i went to Philippine Emirates Private School.',
  },
  {
    name: 'butuan',
    sub: 'philippines · 2017 – 2021',
    lat: 8.9475, lng: 125.5406, zoom: 12,
    text: 'my family moved back to the Philippines after 6th grade. i didnt know any Cebuano, but thankfully, i managed to pick it up in my first two months.',
  },
  {
    name: 'cagayan de oro',
    sub: 'philippines · 2021 – 2024',
    lat: 8.4542, lng: 124.6319, zoom: 12,
    text: 'i got a scholarship at Xavier University - Ateneo de Cagayan and moved to cagayan de oro for senior high school. this city and its people molded me in so many ways! ill write about it soon.',
  },
  {
    name: 'boston',
    sub: 'usa · 2024 – present ✦',
    lat: 42.3601, lng: -71.0589, zoom: 12,
    text: "after getting the wien international scholarship at brandeis university, i moved to boston!",
  },
];

let current = 0;

const nameEl  = document.getElementById('migration-city-name') as HTMLElement;
const subEl   = document.getElementById('migration-city-sub') as HTMLElement;
const textEl  = document.getElementById('migration-city-text') as HTMLElement;
const stepEl  = document.getElementById('migration-step') as HTMLElement;
const prevBtn = document.getElementById('migration-prev') as HTMLButtonElement;
const nextBtn = document.getElementById('migration-next') as HTMLButtonElement;

const map = L.map('migration-leaflet', {
  zoomControl: false,
  scrollWheelZoom: false,
  dragging: true,
  attributionControl: true,
});

L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
  attribution: '© <a href="https://www.openstreetmap.org/copyright" target="_blank">OpenStreetMap</a>',
  maxZoom: 19,
}).addTo(map);

function makeIcon(active: boolean) {
  return L.divIcon({
    className: '',
    html: `<div style="width:12px;height:12px;border-radius:50%;background:${active ? '#3d2f1f' : '#9C8B6E'};border:2px solid #ffffff;box-shadow:0 0 0 3px rgba(156,139,110,0.3);"></div>`,
    iconSize: [12, 12],
    iconAnchor: [6, 6],
  });
}

const markers = stops.map(s => L.marker([s.lat, s.lng], { icon: makeIcon(false) }).addTo(map));

function goTo(index: number) {
  const s = stops[index];
  map.flyTo([s.lat, s.lng], s.zoom, { duration: 1.6, easeLinearity: 0.4 });
  nameEl.textContent = s.name;
  subEl.textContent  = s.sub;
  textEl.textContent = s.text;
  stepEl.textContent = String(index + 1);
  prevBtn.disabled = index === 0;
  nextBtn.disabled = index === stops.length - 1;
  markers.forEach((m, i) => m.setIcon(makeIcon(i === index)));
  current = index;
}

const s0 = stops[0];
map.setView([s0.lat, s0.lng], s0.zoom);
goTo(0);

prevBtn.addEventListener('click', () => { if (current > 0) goTo(current - 1); });
nextBtn.addEventListener('click', () => { if (current < stops.length - 1) goTo(current + 1); });
</script>
