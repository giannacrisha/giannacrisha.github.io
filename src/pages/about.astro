---
import Garden from '../layouts/Garden.astro';
import Icon from '../components/Icon.astro';
import IdentityWeb from '../components/IdentityWeb.astro';
import PortraitCanvas from '../components/PortraitCanvas.astro';
import LiquidGlass from '../components/LiquidGlass.astro';
import TerminalWindow from '../components/TerminalWindow.astro';

const migrationStops = [
  {
    name: 'antipolo',
    rail: 'antipolo',
    sub: 'philippines · 2004 – 2014',
    lat: 14.5888, lng: 121.1228, zoom: 15,
    text: 'i was born in quezon city and raised in antipolo city. my family owned a small internet cafe, one of the firsts in the area. This is where i fell in love with computers. our house had two spaces: the back was our living space and the front was the internet cafe, where i spent my after-school hours playing games and exploring the web. at six, i troubleshot my first computer problem and became the family technician.',
  },
  {
    name: 'abu dhabi',
    rail: 'abu dhabi',
    sub: 'uae · 2014 – 2017',
    lat: 24.4539, lng: 54.3773, zoom: 14,
    text: 'we moved to abu dhabi after 4th grade. i wrote a story about it! my brother and i went to Philippine Emirates Private School.',
  },
  {
    name: 'butuan',
    rail: 'butuan',
    sub: 'philippines · 2017 – 2021',
    lat: 8.9475, lng: 125.5406, zoom: 14,
    text: 'my family moved back to the Philippines after 6th grade. i didnt know any Cebuano, but thankfully, i managed to pick it up in my first two months.',
  },
  {
    name: 'cagayan de oro',
    rail: 'cdo',
    sub: 'philippines · 2021 – 2024',
    lat: 8.4542, lng: 124.6319, zoom: 14,
    text: 'i got a scholarship at Xavier University - Ateneo de Cagayan and moved to cagayan de oro for senior high school. this city and its people molded me in so many ways! ill write about it soon.',
  },
  {
    name: 'boston',
    rail: 'boston',
    sub: 'usa · 2024 – present ✦',
    lat: 42.3601, lng: -71.0589, zoom: 15,
    text: "after getting the wien international scholarship at brandeis university, i moved to boston!",
  },
];
---
<Garden title="about">
  <!-- hero + marquee: constrained to page-wrapper -->
  <div class="page-wrapper">
    <div class="about about--pre">

      <!-- hero intro (sticky scroll) -->
      <section class="about-hero-section" id="about-top">
        <div class="hero-sticky">
          <span class="hero-word hero-word--left" aria-hidden="true">Gianna</span>
          <div class="hero-portrait">
            <PortraitCanvas />
          </div>
          <span class="hero-word hero-word--right" aria-hidden="true">Crisha</span>
          <nav class="hero-socials" aria-label="social links">
            <a href="https://linkedin.com/in/giannacrisha" class="hero-social" aria-label="LinkedIn" target="_blank" rel="noopener noreferrer">
              <Icon name="linkedin" size={18} />
            </a>
            <a href="https://github.com/giannacrisha" class="hero-social" aria-label="GitHub" target="_blank" rel="noopener noreferrer">
              <Icon name="github" size={18} />
            </a>
            <a href="https://x.com/giannaesque" class="hero-social" aria-label="X" target="_blank" rel="noopener noreferrer">
              <Icon name="x" size={18} />
            </a>
            <a href="https://bsky.app/profile/giannacrisha.com" class="hero-social" aria-label="Bluesky" target="_blank" rel="noopener noreferrer">
              <Icon name="bluesky" size={18} />
            </a>
          </nav>
        </div>
      </section>

      <div class="hero-marquee" aria-hidden="true">
        <div class="hero-marquee-track">{"design · tech · society · ".repeat(12)}</div>
      </div>

    </div>
  </div>

  <!-- identity web: full-bleed -->
  <section class="about-identity-section" id="about-identity">
    <div class="about-identity-stage">
      <IdentityWeb />
    </div>
    <div class="hero-marquee identity-marquee" aria-hidden="true">
      <div class="hero-marquee-track">{"where's home? · ".repeat(12)}</div>
    </div>
  </section>

  <!-- migration map: full-bleed, outside page-wrapper -->
  <section class="map-section" id="migration-section">
    <div class="map-sticky">
      <div class="map-sticky-body">
        <div class="map-sticky-map">
          <div id="migration-leaflet"></div>
          <script type="application/json" id="migration-data" set:html={JSON.stringify(migrationStops)}></script>
          <div class="migration-ui">
        <div class="migration-card-wrap" id="migration-card-wrap">
          <TerminalWindow
            title="where-ive-lived.sh"
            class="migration-card migration-terminal"
            showClose={false}
            interactiveMinimize
          >
            <div class="migration-terminal-body">
              <div class="migration-terminal-line">
                <span class="migration-terminal-prompt" aria-hidden="true">$</span>
                <span class="migration-terminal-cmd" id="migration-city-name">{migrationStops[0].name}</span>
              </div>
              <p class="migration-terminal-meta" id="migration-city-sub">{migrationStops[0].sub}</p>
              <p class="migration-terminal-output" id="migration-city-text">{migrationStops[0].text}</p>
            </div>
          </TerminalWindow>
          <div class="migration-resize-handle migration-resize-handle--e" data-axis="e" aria-hidden="true"></div>
          <div class="migration-resize-handle migration-resize-handle--w" data-axis="w" aria-hidden="true"></div>
        </div>

        <nav class="migration-rail" id="migration-rail" aria-label="cities">
          <div class="migration-rail-track" aria-hidden="true"></div>
          {migrationStops.map((stop, i) => (
            <button
              type="button"
              class:list={['migration-rail-btn', { 'is-active': i === 0 }]}
              data-index={i}
              aria-current={i === 0 ? 'true' : 'false'}
            >
              <div
                class="migration-rail-btn-glass"
                aria-hidden="true"
                style={`--lg-filter: url(#migration-rail-${i})`}
              ></div>
              <div class="migration-rail-btn-panel">
                <LiquidGlass
                  displacement={100}
                  aberration={3}
                  cornerRadius={16}
                  filterId={`migration-rail-${i}`}
                  backdrop={false}
                >
                  <div class="migration-rail-btn-inner">
                    <span class="migration-rail-dot" aria-hidden="true"></span>
                    <span class="migration-rail-label">{stop.rail}</span>
                  </div>
                </LiquidGlass>
              </div>
            </button>
          ))}
        </nav>

        <button type="button" class="migration-section-nav migration-section-nav--prev" id="migration-section-prev">
          previous section
        </button>
        <button type="button" class="migration-section-nav migration-section-nav--next" id="migration-section-next">
          next section
        </button>
        </div>
        <div class="scroll-hint" id="scroll-hint" aria-hidden="true">
          <span class="scroll-hint-text">scroll to travel</span>
          <svg class="scroll-hint-arrow" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
            <polyline points="6 9 12 15 18 9"/>
          </svg>
        </div>
        </div>
        <div class="hero-marquee migration-marquee" aria-hidden="true">
          <div class="hero-marquee-track">{"anthropology · art · engineering · ".repeat(12)}</div>
        </div>
      </div>
    </div>
  </section>
</Garden>

<style>
  .about {
    display: flex;
    flex-direction: column;
    gap: var(--space-section);
  }
  .about--pre {
    padding-bottom: 0;
  }

  /* sticky scroll hero — pulled behind nav (56px) so hero fills true full viewport */
  .about-hero-section {
    height: 200vh;
    margin-top: -56px;
    /* clip without creating a scroll container (overflow:hidden breaks sticky) */
    overflow: clip;
  }
  .hero-sticky {
    position: sticky;
    top: 0;
    height: 100vh;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: clamp(16px, 3vw, 40px);
    /* needed for absolute-positioned marquee */
    isolation: isolate;
  }
  .hero-portrait {
    flex: 0 0 auto;
    display: flex;
    align-items: center;
    justify-content: center;
    z-index: 1;
  }
  .hero-word {
    font-family: var(--font-display);
    font-size: clamp(64px, 10vw, 140px);
    color: var(--color-fg);
    line-height: 1;
    white-space: nowrap;
    will-change: transform;
    transform: translateY(60vh);
  }
  .hero-word--left { text-align: right; }
  .hero-word--right { text-align: left; }

  .hero-socials {
    position: absolute;
    bottom: clamp(20px, 4vw, 40px);
    left: 50%;
    transform: translateX(-50%);
    display: flex;
    align-items: center;
    gap: var(--space-lg);
    z-index: 2;
  }
  .hero-social {
    display: flex;
    align-items: center;
    color: var(--color-muted);
    transition: color 0.15s ease;
  }
  .hero-social:hover,
  .hero-social:focus-visible {
    color: var(--color-fg);
    outline: none;
  }

  /* marquee strip — full-bleed dark band below the hero */
  .hero-marquee {
    width: 100vw;
    margin-left: calc(50% - 50vw);
    background: var(--color-fg);
    padding: 10px 0;
    overflow: hidden;
    pointer-events: none;
  }
  .hero-marquee-track {
    display: inline-block;
    white-space: nowrap;
    font-family: var(--font-body);
    font-size: var(--text-sm);
    color: var(--color-bg);
    letter-spacing: 0.08em;
    text-transform: uppercase;
    animation: marquee-scroll 28s linear infinite;
  }
  @keyframes marquee-scroll {
    from { transform: translateX(0); }
    to   { transform: translateX(-50%); }
  }

  /* bio section */
  .about-bio-section {
    padding-top: var(--space-section);
  }
  .about-name {
    font-family: var(--font-serif);
    font-weight: 600;
    font-size: clamp(36px, 5vw, 64px);
    color: var(--color-heading);
    line-height: 1.1;
  }
  .about-role {
    font-family: var(--font-body);
    font-size: var(--text-md);
    color: var(--color-muted);
  }
  .about-bio {
    font-family: var(--font-body);
    font-size: var(--text-md);
    color: var(--color-fg);
    line-height: var(--leading-loose);
    max-width: 48ch;
    margin-top: var(--space-sm);
  }
  @media (max-width: 640px) {
    .hero-word { font-size: clamp(40px, 11vw, 80px); }
    .about-bio { max-width: none; }
  }

  /* identity web — full viewport */
  .about-identity-section {
    position: relative;
    display: flex;
    flex-direction: column;
    width: 100vw;
    margin-left: calc(50% - 50vw);
    height: 100vh;
    min-height: 100svh;
  }
  .about-identity-stage {
    position: relative;
    flex: 1;
    min-height: 0;
  }
  .identity-marquee {
    flex-shrink: 0;
    width: 100%;
    margin-left: 0;
    z-index: 25;
  }
  /* full-screen satellite map — lives outside page-wrapper so it's naturally full-bleed */
  .map-section {
    height: 500vh;
  }
  .map-sticky {
    position: sticky;
    top: 0;
    height: 100vh;
    display: flex;
    flex-direction: column;
    overflow: hidden;
  }
  .map-sticky-body {
    flex: 1;
    min-height: 0;
    display: flex;
    flex-direction: column;
    overflow: hidden;
  }
  .map-sticky-map {
    position: relative;
    flex: 1;
    min-height: 0;
    overflow: hidden;
  }
  .migration-marquee {
    flex-shrink: 0;
    position: relative;
    width: 100%;
    margin-left: 0;
    z-index: 5;
  }
  #migration-leaflet {
    position: absolute;
    inset: 0;
    z-index: 0;
  }
  :global(.migration-logo-marker) {
    background: none !important;
    border: none !important;
  }
  :global(.migration-logo-marker img) {
    display: block;
    mix-blend-mode: screen;
    filter:
      drop-shadow(0 0 6px rgba(0, 0, 0, 0.85))
      drop-shadow(0 2px 10px rgba(0, 0, 0, 0.6));
    pointer-events: none;
  }
  .migration-ui {
    position: absolute;
    inset: 0;
    z-index: 10;
    pointer-events: none;
  }
  .migration-card-wrap,
  .migration-rail,
  .migration-section-nav {
    pointer-events: auto;
  }
  .migration-card-wrap {
    position: absolute;
    left: clamp(20px, 4vw, 48px);
    top: 50%;
    width: clamp(300px, 36vw, 440px);
    transform: translateY(-50%);
    touch-action: none;
  }
  .migration-card.migration-terminal {
    box-shadow: 0 24px 64px rgba(0, 0, 0, 0.45);
  }
  .migration-card.migration-terminal :global(.tw-bar) {
    cursor: grab;
    user-select: none;
  }
  .migration-card.migration-terminal.is-dragging :global(.tw-bar) {
    cursor: grabbing;
  }
  .migration-card-wrap.is-minimized .migration-terminal-body,
  .migration-card.migration-terminal.is-minimized .migration-terminal-body {
    display: none;
  }
  .migration-card-wrap.is-minimized .migration-resize-handle {
    display: none;
  }
  .migration-card.migration-terminal :global(.tw-dot[type="button"]) {
    pointer-events: auto;
    position: relative;
    z-index: 2;
  }
  .migration-card.migration-terminal.is-minimized :global(.tw-min) {
    box-shadow: 0 0 0 2px rgba(255, 189, 46, 0.45);
  }
  .migration-terminal-body {
    padding: var(--space-md) var(--space-lg) var(--space-lg);
    font-family: var(--font-mono);
    font-size: var(--text-sm);
    line-height: 1.55;
    color: #d4d4d8;
  }
  .migration-terminal-line {
    display: flex;
    align-items: baseline;
    gap: var(--space-sm);
    margin-bottom: var(--space-xs);
  }
  .migration-terminal-prompt {
    color: #28c841;
    font-weight: 700;
    flex-shrink: 0;
  }
  .migration-terminal-cmd {
    color: #f4f4f5;
    font-weight: 600;
    text-transform: lowercase;
  }
  .migration-terminal-meta {
    margin: 0 0 var(--space-sm);
    padding-left: calc(1ch + var(--space-sm));
    color: #71717a;
    font-size: var(--text-xs);
    letter-spacing: 0.03em;
  }
  .migration-terminal-output {
    margin: 0;
    padding-left: calc(1ch + var(--space-sm));
    color: #a1a1aa;
    white-space: pre-wrap;
    user-select: text;
    cursor: text;
  }
  .migration-resize-handle {
    position: absolute;
    z-index: 2;
    touch-action: none;
  }
  .migration-resize-handle--e,
  .migration-resize-handle--w {
    top: 8px;
    bottom: 8px;
    width: 10px;
    cursor: ew-resize;
  }
  .migration-resize-handle--e { right: -4px; }
  .migration-resize-handle--w { left: -4px; }
  .migration-rail {
    position: absolute;
    right: clamp(20px, 4vw, 48px);
    top: 50%;
    transform: translateY(-50%);
    display: flex;
    flex-direction: column;
    gap: var(--space-md);
    padding: var(--space-sm) 0;
  }
  .migration-rail-track {
    position: absolute;
    left: 17px;
    top: 20px;
    bottom: 20px;
    width: 2px;
    background: rgba(255, 255, 255, 0.35);
    border-radius: 1px;
    pointer-events: none;
  }
  .migration-rail-btn {
    position: relative;
    display: block;
    background: none;
    border: none;
    padding: 0;
    cursor: pointer;
    text-align: left;
    font-family: var(--font-body);
    font-size: var(--text-sm);
    letter-spacing: 0.02em;
  }
  .migration-rail-btn-panel {
    position: relative;
    display: inline-flex;
    z-index: 1;
  }
  .migration-rail-btn-glass {
    position: absolute;
    top: 0;
    left: 0;
    pointer-events: none;
    z-index: 0;
    border-radius: 16px;
    overflow: hidden;
    clip-path: inset(0 round 16px);
    background: rgba(255, 255, 255, 0.10);
    backdrop-filter: blur(2px) saturate(200%);
    -webkit-backdrop-filter: blur(2px) saturate(200%);
    box-shadow:
      0 0 0 0.75px rgba(255, 255, 255, 0.35) inset,
      0 4px 16px rgba(0, 0, 0, 0.12);
  }
  :global(:root[data-lg-refract="1"]) .migration-rail-btn-glass {
    filter: var(--lg-filter);
  }
  .migration-rail-btn-inner {
    display: flex;
    align-items: center;
    gap: var(--space-md);
    padding: 6px 14px 6px 10px;
  }
  .migration-rail-btn:hover,
  .migration-rail-btn:focus-visible {
    outline: none;
  }
  .migration-rail-dot {
    flex-shrink: 0;
    width: 12px;
    height: 12px;
    border-radius: 50%;
    border: 2px solid rgba(255, 255, 255, 0.75);
    background: transparent;
    transition:
      background 0.28s ease,
      border-color 0.28s ease,
      transform 0.28s ease;
  }
  .migration-rail-btn:hover .migration-rail-dot,
  .migration-rail-btn:focus-visible .migration-rail-dot {
    transform: scale(1.35);
    border-color: #fff;
  }
  .migration-rail-btn.is-active .migration-rail-dot {
    background: #fff;
    border-color: #fff;
    transform: scale(1.2);
  }
  .migration-rail-label {
    white-space: nowrap;
    color: #fff;
    font-weight: 400;
    text-shadow:
      0 1px 3px rgba(0, 0, 0, 0.55),
      0 0 10px rgba(0, 0, 0, 0.35);
    transition: font-weight 0.28s ease;
  }
  .migration-rail-btn.is-active .migration-rail-label {
    font-weight: 700;
  }

  .migration-section-nav {
    position: absolute;
    right: clamp(20px, 4vw, 48px);
    z-index: 11;
    font-family: var(--font-body);
    font-size: var(--text-xs);
    letter-spacing: 0.04em;
    color: #fff;
    background: rgba(20, 20, 22, 0.72);
    border: 1px solid rgba(255, 255, 255, 0.22);
    border-radius: var(--radius-pill);
    padding: 8px 14px;
    cursor: pointer;
    text-shadow: 0 1px 3px rgba(0, 0, 0, 0.55);
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
    transition: background 0.2s ease, border-color 0.2s ease;
  }
  .migration-section-nav:hover,
  .migration-section-nav:focus-visible {
    background: rgba(32, 32, 36, 0.88);
    border-color: rgba(255, 255, 255, 0.38);
    outline: none;
  }
  .migration-section-nav--prev {
    top: clamp(20px, 4vw, 48px);
  }
  .migration-section-nav--next {
    bottom: clamp(20px, 4vw, 48px);
    display: none;
  }

  /* scroll hint — bottom-center of the map viewport */
  .scroll-hint {
    position: absolute;
    bottom: 36px;
    left: 50%;
    transform: translateX(-50%);
    z-index: 10;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 4px;
    color: rgba(255, 255, 255, 0.9);
    font-family: var(--font-body);
    font-size: 10px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    text-shadow: 0 1px 6px rgba(0,0,0,0.9);
    pointer-events: none;
    transition: opacity 0.7s ease;
  }
  .scroll-hint-arrow {
    animation: hint-bounce 1.3s ease-in-out infinite;
  }
  @keyframes hint-bounce {
    0%, 100% { transform: translateY(0); opacity: 0.65; }
    50%       { transform: translateY(7px); opacity: 1; }
  }
  @media (max-width: 640px) {
    .migration-card-wrap {
      left: 16px;
      right: 16px;
      width: auto !important;
      top: auto;
      bottom: 24px;
      transform: none;
    }
    .migration-resize-handle {
      display: none;
    }
    .migration-rail {
      right: 16px;
      left: auto;
      top: auto;
      bottom: 24px;
      transform: none;
      gap: var(--space-xs);
      padding: var(--space-xs) 0;
    }
    .migration-rail-btn {
      font-size: var(--text-xs);
    }
    .migration-rail-dot {
      width: 10px;
      height: 10px;
    }
    .migration-section-nav {
      right: 16px;
      font-size: 10px;
      padding: 7px 12px;
    }
    .migration-section-nav--prev {
      top: 16px;
    }
    .migration-section-nav--next {
      top: 52px;
      bottom: auto;
    }
  }

</style>

<style is:global>
  /* nav slides away when satellite map is in view */
  .site-nav {
    transition: transform 0.35s ease, opacity 0.35s ease;
  }
  .site-nav.nav-map-hide {
    transform: translateY(-110%);
    opacity: 0;
    pointer-events: none;
  }
</style>


<script>
  import { initMigrationMap } from '../lib/migration-map';
  import { initMigrationCard } from '../lib/migration-card';

  const dataEl = document.getElementById('migration-data');
  if (dataEl?.textContent) {
    initMigrationMap(JSON.parse(dataEl.textContent));
  }
  initMigrationCard();

  const nav = document.querySelector('.site-nav');
  const immersiveSections = [
    document.getElementById('migration-section'),
    document.getElementById('about-identity'),
  ].filter((el): el is HTMLElement => !!el);
  if (nav && immersiveSections.length) {
    const visible = new Set<Element>();
    const syncNav = () => nav.classList.toggle('nav-map-hide', visible.size > 0);
    const navObserver = new IntersectionObserver(
      (entries) => {
        entries.forEach((e) => {
          if (e.isIntersecting) visible.add(e.target);
          else visible.delete(e.target);
        });
        syncNav();
      },
      { threshold: 0.01 },
    );
    immersiveSections.forEach((el) => navObserver.observe(el));
  }

  document.querySelectorAll<HTMLElement>('.migration-rail-btn').forEach((btn) => {
    const panel = btn.querySelector<HTMLElement>('.migration-rail-btn-panel');
    const glass = btn.querySelector<HTMLElement>('.migration-rail-btn-glass');
    const sync = () => {
      if (!panel || !glass) return;
      glass.style.width = `${panel.offsetWidth}px`;
      glass.style.height = `${panel.offsetHeight}px`;
    };
    sync();
    if (panel) new ResizeObserver(sync).observe(panel);
  });

  const prevBtn = document.getElementById('migration-section-prev');
  const identitySection = document.getElementById('about-identity');

  prevBtn?.addEventListener('click', () => {
    if (!identitySection) return;
    window.scrollTo({ top: identitySection.offsetTop, behavior: 'smooth' });
  });
</script>

<script>
// scroll-driven hero: slide "Gianna" and "Crisha" up into position
const heroSection = document.getElementById('about-top') as HTMLElement;
const wordLeft    = heroSection?.querySelector<HTMLElement>('.hero-word--left');
const wordRight   = heroSection?.querySelector<HTMLElement>('.hero-word--right');

if (heroSection && wordLeft && wordRight) {
  const left = wordLeft;   // narrow to HTMLElement so closure captures the non-null type
  const right = wordRight;
  const WORD_OFFSET = 60; // vh

  function easeInOut(t: number) {
    return t < 0.5 ? 2 * t * t : -1 + (4 - 2 * t) * t;
  }

  function updateHero() {
    const rect     = heroSection.getBoundingClientRect();
    const sectionH = heroSection.offsetHeight;
    const winH     = window.innerHeight;
    const raw      = Math.min(1, Math.max(0, -rect.top / (sectionH - winH)));
    const p        = easeInOut(raw);
    left.style.transform  = `translateY(${(1 - p) * WORD_OFFSET}vh)`;
    right.style.transform = `translateY(${(1 - p) * WORD_OFFSET}vh)`;
  }

  window.addEventListener('scroll', updateHero, { passive: true });
  updateHero();
}

</script>
