---
// src/pages/archives/index.astro
import Garden from '../../layouts/Garden.astro';
import Card from '../../components/Card.astro';
import FilterBar from '../../components/FilterBar.astro';
import { getCollection } from 'astro:content';

const entries = await getCollection('archives');
const sorted = entries.sort((a, b) => b.data.date_published.getTime() - a.data.date_published.getTime());

const filterGroups = [
  {
    param: 'type',
    label: 'type',
    options: [
      { value: 'all', label: 'all' },
      { value: 'essay', label: 'essay' },
      { value: 'poem', label: 'poem' },
      { value: 'thought', label: 'thought' },
    ],
  },
  {
    param: 'stage',
    label: 'stage',
    options: [
      { value: 'all', label: 'all' },
      { value: 'dust', label: 'dust', stage: 'dust' as const },
      { value: 'spark', label: 'spark', stage: 'spark' as const },
      { value: 'star', label: 'star', stage: 'star' as const },
    ],
  },
];
---
<Garden title="archives">
  <div class="site-wrapper">
    <div class="page-header">
      <h1 class="section-header">archives</h1>
      <p class="page-desc">essays, poems, thoughts</p>
    </div>
    <FilterBar groups={filterGroups} />
    <div class="card-grid">
      {sorted.map(entry => (
        <div
          data-filter={JSON.stringify({ type: entry.data.type, stage: entry.data.growth_stage })}
        >
          <Card
            title={entry.data.title}
            slug={entry.slug}
            collection="archives"
            type={entry.data.type}
            stage={entry.data.growth_stage}
            date_published={entry.data.date_published}
            date_written={entry.data.date_written}
          />
        </div>
      ))}
    </div>
  </div>
</Garden>

<style>
  .page-header { padding: var(--space-section) 0 var(--space-xxl); }
  .page-desc { font-family: var(--font-body); font-size: var(--text-md); color: var(--color-muted); margin-top: var(--space-sm); }
</style>
