---
// src/pages/archives/index.astro
import Garden from '../../layouts/Garden.astro';
import Card from '../../components/Card.astro';
import CollectionFilters from '../../components/CollectionFilters.astro';
import { getCollection } from 'astro:content';

const entries = await getCollection('archives');
const sorted = entries.sort((a, b) => {
  const ad = (a.data.date_published ?? a.data.date_written).getTime();
  const bd = (b.data.date_published ?? b.data.date_written).getTime();
  return bd - ad;
});

const filters = [
  {
    param: 'type',
    label: 'type',
    options: [
      { value: 'all', label: 'all' },
      { value: 'essay', label: 'essay' },
      { value: 'poem', label: 'poem' },
      { value: 'thought', label: 'thought' },
    ],
  },
  {
    param: 'stage',
    label: 'stage',
    options: [
      { value: 'all', label: 'all' },
      { value: 'dust', label: 'dust' },
      { value: 'spark', label: 'spark' },
      { value: 'star', label: 'star' },
    ],
  },
];
---
<Garden title="archives">
  <div class="page-wrapper">
    <div class="page-header">
      <div class="page-title-row">
        <h1 class="section-header">archives</h1>
        <span class="page-phonetic">[ahr-kahyvz] &nbsp;/ ˈɑːr.kaɪvz /</span>
      </div>
      <p class="page-def">essays, poems, and thoughts growing slowly over time.</p>
    </div>
    <CollectionFilters filters={filters} />
    <div class="card-grid">
      {sorted.map(entry => (
        <div
          data-filter={JSON.stringify({ type: entry.data.type, stage: entry.data.growth_stage })}
          data-date={(entry.data.date_published ?? entry.data.date_written).getTime()}
          data-stage={entry.data.growth_stage}
        >
          <Card
            title={entry.data.title}
            slug={entry.slug}
            collection="archives"
            type={entry.data.type}
            stage={entry.data.growth_stage}
            date_published={entry.data.date_published ?? entry.data.date_written}
            date_written={entry.data.date_written}
            body={entry.body}
          />
        </div>
      ))}
    </div>
  </div>
</Garden>

<style>
</style>
