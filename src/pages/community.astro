---
// src/pages/community.astro
// SSR so every visit fetches fresh submissions from GitHub Issues
export const prerender = false;
import Garden from '../layouts/Garden.astro';
import CommunityGarden from '../components/CommunityGarden.astro';
---
<Garden
  title="community"
  description="a shared pixel-art garden. draw a little plant, creature, or scene and leave it here."
  noFooter
>
  <CommunityGarden />
</Garden>

<style is:global>
  /* Desktop: main fills the remaining viewport height as a flex row */
  body, html { height: 100%; }
  main {
    height: calc(100vh - 56px);
    overflow: hidden;
    display: flex;
  }

  /* Mobile: let main scroll naturally */
  @media (max-width: 720px) {
    main {
      height: auto;
      overflow: visible;
      display: block;
    }
  }
</style>
