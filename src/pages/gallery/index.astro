---
// src/pages/gallery/index.astro
import Garden from '../../layouts/Garden.astro';
import CollectionFilters from '../../components/CollectionFilters.astro';
import GrowthPill from '../../components/GrowthPill.astro';
import { getCollection } from 'astro:content';

const entries = await getCollection('gallery');
const sorted = entries.sort((a, b) => {
  const ad = (a.data.date_published ?? a.data.date_made).getTime();
  const bd = (b.data.date_published ?? b.data.date_made).getTime();
  return bd - ad;
});

// Derive mediums dynamically
const mediums = [...new Set(entries.map(e => e.data.medium))];

const filters = [
  {
    param: 'stage',
    label: 'stage',
    options: [
      { value: 'all', label: 'all' },
      { value: 'dust', label: 'dust' },
      { value: 'spark', label: 'spark' },
      { value: 'star', label: 'star' },
    ],
  },
  {
    param: 'medium',
    label: 'medium',
    options: [
      { value: 'all', label: 'all' },
      ...mediums.map(m => ({ value: m, label: m })),
    ],
  },
];
---
<Garden title="gallery">
  <div class="page-wrapper">
    <div class="page-header">
      <div class="page-title-row">
        <h1 class="section-header">gallery</h1>
        <span class="page-phonetic">[gal-uh-ree] &nbsp;/ ˈɡæl.ər.i /</span>
      </div>
      <p class="page-def">artwork and visual experiments.</p>
    </div>
    <CollectionFilters filters={filters} />
    <div class="masonry">
      {sorted.map(entry => (
        <div
          class="masonry-item"
          data-filter={JSON.stringify({ stage: entry.data.growth_stage, medium: entry.data.medium })}
          data-date={(entry.data.date_published ?? entry.data.date_made).getTime()}
          data-stage={entry.data.growth_stage}
        >
          <a href={`/gallery/${entry.slug}`} class="gallery-card">
            <div class="gallery-image-wrap">
              <img src={entry.data.image} alt={entry.data.title} loading="lazy" />
            </div>
            <div class="gallery-meta">
              <span class="gallery-title">{entry.data.title}</span>
              <div class="gallery-bottom">
                <span class="pill">{entry.data.medium}</span>
                <GrowthPill stage={entry.data.growth_stage} />
              </div>
            </div>
          </a>
        </div>
      ))}
    </div>
  </div>
</Garden>

<style>
  .masonry { columns: 2; column-gap: var(--space-xl); }
  .masonry-item { break-inside: avoid; margin-bottom: var(--space-xl); }
  .gallery-card { display: block; background: var(--color-card); border: var(--border); border-radius: var(--radius-card); overflow: hidden; transition: border-color 0.15s ease; }
  .gallery-card:hover { border-color: var(--color-accent); }
  .gallery-image-wrap img { width: 100%; display: block; }
  .gallery-meta { padding: var(--space-lg); display: flex; flex-direction: column; gap: var(--space-sm); }
  .gallery-title { font-family: var(--font-serif); font-size: var(--text-md); color: var(--color-fg); }
  .gallery-bottom { display: flex; gap: var(--space-xs); flex-wrap: wrap; }
  @media (max-width: 600px) { .masonry { columns: 1; } }
</style>
