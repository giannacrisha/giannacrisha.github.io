---
// src/pages/gallery/[slug].astro
import Garden from '../../layouts/Garden.astro';
import GrowthPill from '../../components/GrowthPill.astro';
import Timestamps from '../../components/Timestamps.astro';
import Recommended from '../../components/Recommended.astro';
import ArticleBreadcrumb from '../../components/ArticleBreadcrumb.astro';
import TableOfContents from '../../components/TableOfContents.astro';
import ImageCarousel from '../../components/ImageCarousel.astro';
import MuxVideo from '../../components/MuxVideo.astro';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  const entries = await getCollection('gallery');
  return entries.map(entry => ({ params: { slug: entry.slug }, props: { entry } }));
}

const { entry } = Astro.props;
const { Content, headings } = await entry.render();
const { title, medium, date_made, date_published, image, caption, growth_stage, images, link, topics, mux_video_id } = entry.data;
const published = date_published ?? date_made;

const allEntries = await getCollection('gallery');
const related = allEntries
  .filter(e => e.slug !== entry.slug)
  .sort((a, b) => {
    const dateA = a.data.date_published ?? a.data.date_made;
    const dateB = b.data.date_published ?? b.data.date_made;
    return new Date(dateB).getTime() - new Date(dateA).getTime();
  })
  .slice(0, 3);
---
<Garden title={title}>
  <div class="content-with-sidebar">

    <div class="content-main">
      <article class="article">

        <ArticleBreadcrumb section="gallery" title={title} />

        <div class="entry-label-row">
          <span class="pill">{medium}</span>
          <GrowthPill stage={growth_stage} />
        </div>
        <div class="entry-title-row">
          <h1 class="entry-title">{title}</h1>
        </div>
        <div class="entry-meta-row">
          <div class="entry-topics">
            {topics && topics.map((t: string) => (
              <a href={`/gallery?topic=${encodeURIComponent(t)}`} class="topic-tag">{t}</a>
            ))}
          </div>
          <Timestamps
            primaryLabel="made"
            primaryDate={date_made}
            secondaryLabel="planted"
            secondaryDate={published}
          />
        </div>

        {mux_video_id
          ? <MuxVideo playbackId={mux_video_id} title={title} />
          : (
              <div class="image-full">
                <img src={image} alt={title} />
              </div>
            )
        }
        {caption && <p class="entry-caption">{caption}</p>}

        <hr class="article-divider" />

        {images && images.length > 0 && (
          <div class="process-carousel">
            <ImageCarousel images={images} label="stages" title={title} />
          </div>
        )}

        <TableOfContents headings={headings} variant="inline" />

        <div class="prose">
          <Content />
        </div>

        {link && (
          <a href={link} target="_blank" rel="noopener noreferrer" class="article-link">
            view more about this work
            <svg width="10" height="10" viewBox="0 0 12 12" fill="none" aria-hidden="true">
              <path d="M2 10L10 2M10 2H5M10 2V7" stroke="currentColor" stroke-width="1.2" stroke-linecap="round"/>
            </svg>
          </a>
        )}

      </article>
    </div>

    <div class="content-sidebar">
      <TableOfContents headings={headings} variant="sidebar" />
      <Recommended entries={related} />
    </div>

  </div>
</Garden>
