---
// src/pages/gallery/[slug].astro
import Garden from '../../layouts/Garden.astro';
import GrowthPill from '../../components/GrowthPill.astro';
import Timestamps from '../../components/Timestamps.astro';
import Recommended from '../../components/Recommended.astro';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  const entries = await getCollection('gallery');
  return entries.map(entry => ({ params: { slug: entry.slug }, props: { entry } }));
}

const { entry } = Astro.props;
const { title, medium, date_made, date_published, image, caption, growth_stage } = entry.data;
const published = date_published ?? date_made;

const allEntries = await getCollection('gallery');
const related = allEntries
  .filter(e => e.slug !== entry.slug)
  .sort((a, b) => {
    const dateA = a.data.date_published ?? a.data.date_made;
    const dateB = b.data.date_published ?? b.data.date_made;
    return new Date(dateB).getTime() - new Date(dateA).getTime();
  })
  .slice(0, 3);
---
<Garden title={title}>
  <div class="content-with-sidebar">

    <div class="content-main">
      <article class="gallery-article">

        <nav class="breadcrumb" aria-label="Breadcrumb">
          <a href="/garden">garden</a>
          <span class="breadcrumb-sep" aria-hidden="true">/</span>
          <a href="/gallery">gallery</a>
          <span class="breadcrumb-sep" aria-hidden="true">/</span>
        </nav>

        <div class="image-full">
          <img src={image} alt={title} />
        </div>
        <h1 class="entry-title">{title}</h1>
        <div class="entry-meta">
          <span class="pill">{medium}</span>
          <GrowthPill stage={growth_stage} />
          <Timestamps
            primaryLabel="made"
            primaryDate={date_made}
            secondaryLabel="planted"
            secondaryDate={published}
          />
        </div>
        {caption && <p class="caption">{caption}</p>}

      </article>
    </div>

    <div class="content-sidebar">
      <Recommended entries={related} />
    </div>

  </div>
</Garden>

<style>
  .gallery-article { padding: var(--space-section) 0; }
  .breadcrumb {
    display: flex;
    align-items: center;
    gap: var(--space-sm);
    font-family: var(--font-body);
    font-size: var(--text-xs);
    color: var(--color-muted);
    margin-bottom: var(--space-xl);
  }
  .breadcrumb a { color: var(--color-muted); text-decoration: none; }
  .breadcrumb a:hover { color: var(--color-fg); }
  .breadcrumb-sep { color: var(--color-accent-border); font-size: 10px; }
  .image-full { background: var(--color-accent-light); border-radius: var(--radius-card); overflow: hidden; margin-bottom: var(--space-xxl); }
  .image-full img { width: 100%; max-height: 70vh; object-fit: contain; display: block; }
  .entry-title { font-family: var(--font-serif); font-size: var(--text-xxl); color: var(--color-fg); margin-bottom: var(--space-lg); }
  .entry-meta { display: flex; flex-wrap: wrap; gap: var(--space-md); align-items: center; }
  .caption { font-family: var(--font-body); font-size: var(--text-md); color: var(--color-muted); font-style: italic; margin-top: var(--space-xl); }
</style>
