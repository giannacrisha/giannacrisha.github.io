---
// src/components/MinimizeBar.astro
// Global tab bar — rendered in Garden.astro
// Tabs are stored in localStorage under 'gi-page-tabs' as [{id, title, url}]
// Clicking a tab navigates to that page (no iframe).
---

<div id="gi-tabbar" class="gi-tabbar" role="list" aria-label="Minimized pages"></div>

<style is:global>
  /* ── Tab bar ─────────────────────────────────── */
  .gi-tabbar {
    position: fixed;
    bottom: 0;
    left: 50%;
    transform: translateX(-50%);
    display: flex;
    gap: 6px;
    padding: 0 16px;
    z-index: 300;
    align-items: flex-end;
    pointer-events: none;
    overflow: visible;
  }

  .gi-tab {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 7px 14px 20px;   /* tall bottom padding fills gap when scaled up */
    background: var(--color-card);
    border: 0.5px solid var(--color-border);
    border-bottom: none;
    border-radius: 8px 8px 0 0;
    font-family: var(--font-body);
    font-size: 11px;
    color: var(--color-fg);
    cursor: pointer;
    pointer-events: auto;
    box-shadow: 0 -2px 12px rgba(0,0,0,0.06);
    transition: background 0.15s, transform 0.2s cubic-bezier(0.34, 1.56, 0.64, 1), box-shadow 0.2s ease;
    max-width: 180px;
    white-space: nowrap;
    overflow: visible;
    transform-origin: center bottom;
    text-decoration: none;
    margin-bottom: -13px;     /* pull tab down so only the top portion is visible at rest */
  }

  /* Rise animation only on first appearance */
  .gi-tab--new {
    animation: tab-rise 0.3s cubic-bezier(0.34, 1.56, 0.64, 1) both;
  }
  @keyframes tab-rise {
    from { transform: translateY(100%); opacity: 0; }
    to   { transform: translateY(0);    opacity: 1; }
  }

  /* Sink animation when navigating away via tab click */
  .gi-tab--closing {
    animation: tab-sink 0.22s cubic-bezier(0.4, 0, 1, 1) forwards !important;
    pointer-events: none;
  }
  @keyframes tab-sink {
    from { transform: translateY(0); opacity: 1; }
    to   { transform: translateY(110%); opacity: 0; }
  }

  .gi-tab:hover {
    background: var(--color-accent-light);
    transform: scaleX(1.05) scaleY(1.08);   /* no translateY — bottom stays flush */
    box-shadow: 0 -4px 16px rgba(0,0,0,0.1);
  }
  .gi-tab:focus-visible {
    outline: 2px solid var(--color-accent);
    outline-offset: 2px;
  }

  .gi-tab-label {
    flex: 1;
    max-width: 140px;
    overflow: hidden;
    text-overflow: ellipsis;
    letter-spacing: 0.03em;
  }

  .gi-tab-close {
    flex-shrink: 0;
    width: 14px;
    height: 14px;
    border-radius: 50%;
    background: #e5534b;
    border: none;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    opacity: 0;
    transition: opacity 0.15s;
    /* expand touch target to 44×44 */
    padding: 15px;
    margin: -15px;
    box-sizing: content-box;
    color: #ffffff;
  }
  .gi-tab:hover .gi-tab-close,
  .gi-tab-close:focus-visible { opacity: 1; }
  .gi-tab-close:focus-visible {
    outline: 2px solid var(--color-accent);
    outline-offset: 2px;
    border-radius: 50%;
  }
  .gi-tab-close svg { display: block; pointer-events: none; }
</style>

<script is:inline>
(function () {
  var STORAGE_KEY = 'gi-page-tabs';
  var SEEN_KEY    = 'gi-tabs-seen';
  var tabbar      = document.getElementById('gi-tabbar');

  // ── Storage helpers ──────────────────────────────
  function getTabs() {
    try { return JSON.parse(localStorage.getItem(STORAGE_KEY) || '[]'); } catch { return []; }
  }
  function saveTabs(tabs) {
    localStorage.setItem(STORAGE_KEY, JSON.stringify(tabs));
  }
  function getSeenIds() {
    try { return JSON.parse(sessionStorage.getItem(SEEN_KEY) || '[]'); } catch { return []; }
  }
  function markSeen(id) {
    var seen = getSeenIds();
    if (!seen.includes(id)) { seen.push(id); sessionStorage.setItem(SEEN_KEY, JSON.stringify(seen)); }
  }
  function addTab(id, title, url) {
    var tabs = getTabs().filter(function(t) { return t.id !== id; });
    tabs.push({ id: id, title: title, url: url });
    saveTabs(tabs);
  }
  function removeTab(id) {
    saveTabs(getTabs().filter(function(t) { return t.id !== id; }));
    var seen = getSeenIds().filter(function(s) { return s !== id; });
    sessionStorage.setItem(SEEN_KEY, JSON.stringify(seen));
  }

  // ── Render tabs ──────────────────────────────────
  function renderTabs(newId) {
    var tabs    = getTabs();
    var seenIds = getSeenIds();
    tabbar.innerHTML = '';

    tabs.forEach(function(t) {
      var isNew = (t.id === newId) || !seenIds.includes(t.id);

      // Tab is an <a> so it's natively keyboard accessible and navigates on click
      var tab = document.createElement('a');
      tab.href      = t.url;
      tab.className = 'gi-tab' + (isNew ? ' gi-tab--new' : '');
      tab.setAttribute('role', 'listitem');
      tab.setAttribute('aria-label', t.title + ' — click to open');

      var label = document.createElement('span');
      label.className   = 'gi-tab-label';
      label.textContent = t.title;

      var closeBtn = document.createElement('button');
      closeBtn.type      = 'button';
      closeBtn.className = 'gi-tab-close';
      closeBtn.setAttribute('aria-label', 'Close ' + t.title);
      closeBtn.innerHTML = '<svg width="6" height="6" viewBox="0 0 6 6" fill="none"><line x1="1" y1="1" x2="5" y2="5" stroke="currentColor" stroke-width="1.2" stroke-linecap="round"/><line x1="5" y1="1" x2="1" y2="5" stroke="currentColor" stroke-width="1.2" stroke-linecap="round"/></svg>';
      closeBtn.addEventListener('click', function(e) {
        e.preventDefault();
        e.stopPropagation();
        removeTab(t.id);
        renderTabs();
      });

      tab.appendChild(label);
      tab.appendChild(closeBtn);

      // Intercept navigation: sink animation then navigate
      tab.addEventListener('click', function(e) {
        e.preventDefault();
        tab.classList.add('gi-tab--closing');
        var dest = t.url;
        setTimeout(function() { window.location.href = dest; }, 220);
      });

      tabbar.appendChild(tab);
      markSeen(t.id);
    });
  }

  // ── Public API for MinimizePageBtn ───────────────
  window.__giTabs = {
    add: function(id, title, url) {
      addTab(id, title, url);
      renderTabs(id);
    },
  };

  renderTabs();
})();
</script>
