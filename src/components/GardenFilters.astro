---
// src/components/GardenFilters.astro
// "filters" chip + dropdown panel, "sort" chip + dropdown
---
<div class="garden-controls" id="garden-controls">

  <!-- Filters chip -->
  <div class="chip-wrap">
    <button class="control-chip" id="filters-btn" aria-expanded="false" aria-haspopup="true">
      <svg width="13" height="13" viewBox="0 0 13 13" fill="none" aria-hidden="true">
        <path d="M1 2.5h11M3 6.5h7M5 10.5h3" stroke="currentColor" stroke-width="1.3" stroke-linecap="round"/>
      </svg>
      filters
    </button>
    <div class="dropdown" id="filters-dropdown" aria-hidden="true">
      <div class="dropdown-section">
        <span class="dropdown-label">growth stage</span>
        <div class="dropdown-pills">
          <button class="dpill active" data-filter-param="stage" data-filter-value="all">all</button>
          <button class="dpill" data-filter-param="stage" data-filter-value="dust">dust</button>
          <button class="dpill" data-filter-param="stage" data-filter-value="spark">spark</button>
          <button class="dpill" data-filter-param="stage" data-filter-value="star">star</button>
        </div>
      </div>
      <div class="dropdown-section">
        <span class="dropdown-label">area</span>
        <div class="dropdown-pills">
          <button class="dpill active" data-filter-param="collection" data-filter-value="all">all</button>
          <button class="dpill" data-filter-param="collection" data-filter-value="archives">archives</button>
          <button class="dpill" data-filter-param="collection" data-filter-value="lab">lab</button>
          <button class="dpill" data-filter-param="collection" data-filter-value="gallery">gallery</button>
          <button class="dpill" data-filter-param="collection" data-filter-value="library">library</button>
        </div>
      </div>
    </div>
  </div>

  <!-- Sort chip -->
  <div class="chip-wrap">
    <button class="control-chip" id="sort-btn" aria-expanded="false" aria-haspopup="true">
      <svg width="13" height="13" viewBox="0 0 13 13" fill="none" aria-hidden="true">
        <path d="M1 2.5h5M1 6.5h8M1 10.5h11" stroke="currentColor" stroke-width="1.3" stroke-linecap="round"/>
      </svg>
      sort
    </button>
    <div class="dropdown" id="sort-dropdown" aria-hidden="true">
      <div class="dropdown-section">
        <div class="dropdown-pills">
          <button class="dpill active" data-sort="newest">most recent</button>
          <button class="dpill" data-sort="oldest">oldest first</button>
          <button class="dpill" data-sort="stage">by growth stage</button>
        </div>
      </div>
    </div>
  </div>

</div>

<style>
  .garden-controls {
    display: flex;
    gap: var(--space-sm);
    margin-bottom: var(--space-xxl);
  }

  .chip-wrap {
    position: relative;
  }

  .control-chip {
    display: inline-flex;
    align-items: center;
    gap: var(--space-xs);
    padding: 5px 14px;
    border-radius: var(--radius-pill);
    border: 0.5px solid var(--color-accent-border);
    background: var(--color-card);
    color: var(--color-fg);
    font-family: var(--font-body);
    font-size: var(--text-xs);
    letter-spacing: 0.05em;
    cursor: pointer;
    transition: border-color 0.12s, background 0.12s;
  }
  .control-chip:hover,
  .control-chip[aria-expanded="true"] {
    border-color: var(--color-fg);
    background: var(--color-fg);
    color: #ffffff;
  }
  .control-chip[aria-expanded="true"] svg { stroke: #ffffff; }

  .dropdown {
    display: none;
    position: absolute;
    top: calc(100% + 8px);
    left: 0;
    min-width: 220px;
    background: var(--color-card);
    border: 0.5px solid var(--color-border);
    border-radius: var(--radius-card);
    box-shadow: 0 4px 24px rgba(0,0,0,0.08);
    z-index: 200;
    padding: var(--space-lg);
    display: none;
    flex-direction: column;
    gap: var(--space-lg);
  }
  .dropdown.open { display: flex; }

  .dropdown-section {
    display: flex;
    flex-direction: column;
    gap: var(--space-sm);
  }
  .dropdown-label {
    font-family: var(--font-body);
    font-size: var(--text-xs);
    color: var(--color-muted);
    letter-spacing: 0.08em;
    text-transform: lowercase;
  }
  .dropdown-pills {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-xs);
  }

  .dpill {
    display: inline-flex;
    align-items: center;
    padding: 4px 12px;
    border-radius: var(--radius-pill);
    border: 0.5px solid var(--color-accent-border);
    background: var(--color-pill-bg);
    color: var(--color-pill-text);
    font-family: var(--font-body);
    font-size: var(--text-xs);
    letter-spacing: 0.04em;
    cursor: pointer;
    transition: background 0.1s, color 0.1s, border-color 0.1s;
  }
  .dpill.active {
    background: var(--color-fg);
    color: #ffffff;
    border-color: var(--color-fg);
  }
  .dpill:hover:not(.active) {
    border-color: var(--color-accent);
    color: var(--color-fg);
  }
</style>

<script>
  // ── toggle dropdowns ─────────────────────────────────────────────────────
  function initDropdown(btnId: string, dropId: string) {
    const btn  = document.getElementById(btnId)!;
    const drop = document.getElementById(dropId)!;
    btn.addEventListener('click', (e) => {
      e.stopPropagation();
      const open = drop.classList.toggle('open');
      btn.setAttribute('aria-expanded', String(open));
      drop.setAttribute('aria-hidden', String(!open));
      // close the other one
      document.querySelectorAll('.dropdown').forEach(d => {
        if (d !== drop) { d.classList.remove('open'); }
      });
      document.querySelectorAll('.control-chip').forEach(b => {
        if (b !== btn) b.setAttribute('aria-expanded', 'false');
      });
    });
  }

  document.addEventListener('click', () => {
    document.querySelectorAll('.dropdown').forEach(d => d.classList.remove('open'));
    document.querySelectorAll('.control-chip').forEach(b => b.setAttribute('aria-expanded', 'false'));
  });

  initDropdown('filters-btn', 'filters-dropdown');
  initDropdown('sort-btn',    'sort-dropdown');

  // ── active state tracking ────────────────────────────────────────────────
  const activeFilters: Record<string, string> = { stage: 'all', collection: 'all' };
  let   activeSort = 'newest';

  // ── filter logic ─────────────────────────────────────────────────────────
  function applyFilters() {
    document.querySelectorAll<HTMLElement>('[data-filter]').forEach(item => {
      const f = JSON.parse(item.dataset.filter!);
      const stageOk = activeFilters.stage === 'all' || f.stage === activeFilters.stage;
      const colOk   = activeFilters.collection === 'all' || f.collection === activeFilters.collection;
      item.style.display = stageOk && colOk ? '' : 'none';
    });
  }

  // ── sort logic ───────────────────────────────────────────────────────────
  const stageOrder: Record<string, number> = { dust: 1, spark: 2, star: 3 };

  function applySort() {
    const container = document.querySelector('.masonry')!;
    const items = Array.from(container.querySelectorAll<HTMLElement>('.masonry-item'));
    items.sort((a, b) => {
      const ad = Number(a.dataset.date), bd = Number(b.dataset.date);
      const as_ = stageOrder[a.dataset.stage ?? ''] ?? 0;
      const bs_ = stageOrder[b.dataset.stage ?? ''] ?? 0;
      if (activeSort === 'newest') return bd - ad;
      if (activeSort === 'oldest') return ad - bd;
      if (activeSort === 'stage')  return bs_ - as_;
      return 0;
    });
    items.forEach(i => container.appendChild(i));
  }

  // ── filter pill clicks ────────────────────────────────────────────────────
  document.querySelectorAll<HTMLButtonElement>('.dpill[data-filter-param]').forEach(pill => {
    pill.addEventListener('click', () => {
      const param = pill.dataset.filterParam!;
      const val   = pill.dataset.filterValue!;
      activeFilters[param] = val;
      // update active state within this section
      pill.closest('.dropdown-pills')!
        .querySelectorAll('.dpill')
        .forEach(p => p.classList.toggle('active', p === pill));
      applyFilters();
    });
  });

  // ── sort pill clicks ─────────────────────────────────────────────────────
  document.querySelectorAll<HTMLButtonElement>('.dpill[data-sort]').forEach(pill => {
    pill.addEventListener('click', () => {
      activeSort = pill.dataset.sort!;
      pill.closest('.dropdown-pills')!
        .querySelectorAll('.dpill')
        .forEach(p => p.classList.toggle('active', p === pill));
      applySort();
    });
  });
</script>
