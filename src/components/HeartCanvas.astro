---
// HeartCanvas.astro — gold anatomical heart, Three.js.
// Loads a heart .glb and applies a gold PBR material + a procedural muscle-
// contraction beat (vertex wall-flex + directional squeeze + systolic twist).
// The model is meshopt-compressed, so the loader needs the meshopt decoder.
import LiquidGlass from './LiquidGlass.astro';
import TerminalWindow from './TerminalWindow.astro';
const { model = '/heart.glb' } = Astro.props;
---
<div class="heart-stage" data-heart-model={model}>
  <canvas class="heart-canvas" aria-hidden="true"></canvas>
</div>
<div class="heart-cursor-glass" aria-hidden="true"></div>
<div class="heart-cursor-label" aria-hidden="true">
  <LiquidGlass displacement={100} aberration={3} cornerRadius={24} filterId="heart-pill" backdrop={false}>
    <span class="heart-cursor-text">why a heart?</span>
  </LiquidGlass>
</div>
<div class="heart-terminal" role="dialog" aria-modal="true" aria-hidden="true">
  <TerminalWindow title="why-a-heart.sh" class="ht-window">
    <pre class="ht-body"></pre>
  </TerminalWindow>
</div>

<style>
  .heart-stage {
    width: clamp(260px, 34vw, 420px);
    aspect-ratio: 1 / 1;
    position: relative;
    z-index: 3;
    cursor: none;
    transition: transform 0.3s ease;
  }
  .heart-stage:hover {
    transform: scale(1.06);
  }
  .heart-canvas {
    width: 100%;
    height: 100%;
    display: block;
    filter: drop-shadow(0 0 26px rgba(255, 255, 255, 0.65))
            drop-shadow(0 0 64px rgba(255, 255, 255, 0.40));
  }
  /* dark mode: warmer + dimmer so it doesn't blow out against the dark bg */
  :global(:root[data-theme="dark"]) .heart-canvas {
    filter: drop-shadow(0 0 20px rgba(216, 175, 120, 0.32))
            drop-shadow(0 0 52px rgba(216, 175, 120, 0.20));
  }
  /* glass layer — frosted backdrop on all browsers; SVG refraction Chromium-only */
  .heart-cursor-glass {
    position: fixed;
    top: 0; left: 0;
    pointer-events: none;
    z-index: 9998;
    opacity: 0;
    transition: opacity 0.15s;
    border-radius: 24px;
    overflow: hidden;
    clip-path: inset(0 round 24px);
    background: rgba(255, 255, 255, 0.10);
    backdrop-filter: blur(2px) saturate(200%);
    -webkit-backdrop-filter: blur(2px) saturate(200%);
    box-shadow:
      0 0 0 0.75px rgba(255, 255, 255, 0.35) inset,
      0 4px 16px rgba(0, 0, 0, 0.12);
  }
  :global(:root[data-lg-refract="1"]) .heart-cursor-glass {
    filter: url(#heart-pill);
  }
  .heart-cursor-glass.is-visible { opacity: 1; }
  /* label layer — LiquidGlass chrome + text, sits above glass, no filter applied */
  .heart-cursor-label {
    position: fixed;
    top: 0; left: 0;
    display: inline-flex;
    pointer-events: none;
    z-index: 9999;
    opacity: 0;
    transition: opacity 0.15s;
  }
  .heart-cursor-label.is-visible { opacity: 1; }
  .heart-cursor-text {
    font-family: var(--font-display);
    font-size: var(--text-md);
    line-height: 1.5;
    color: #fff;
    white-space: nowrap;
    padding: 32px 16px;
    text-shadow: 0 1px 6px rgba(0, 0, 0, 0.55), 0 0 2px rgba(0, 0, 0, 0.3);
  }
  /* terminal modal */
  .heart-terminal {
    position: fixed;
    inset: 0;
    z-index: 10000;
    display: flex;
    align-items: center;
    justify-content: center;
    background: rgba(0, 0, 0, 0.55);
    backdrop-filter: blur(4px);
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.2s ease;
  }
  .heart-terminal.is-open { opacity: 1; pointer-events: auto; }
  .ht-window { width: min(520px, 90vw); }
  .ht-body {
    padding: 24px 28px;
    font-family: var(--font-mono);
    font-weight: 700;
    font-size: var(--text-base);
    line-height: 2.2;
    color: #d4d4d4;
    margin: 0;
    white-space: pre-wrap;
    text-align: left;
  }
  .ht-user { color: #d4d4d4; }
  .ht-dir  { color: #89b4fa; }
  .ht-pct  { color: #cdd6f4; }
  .ht-blink { display: inline-block; animation: ht-blink 1s step-start infinite; }
  @keyframes ht-blink { 50% { opacity: 0; } }
  @media (max-width: 768px) {
    .heart-stage { width: clamp(220px, 64vw, 320px); }
    .ht-body { padding: 20px; }
  }
</style>

<script>
  import * as THREE from 'three';
  import { GLTFLoader } from 'three/examples/jsm/loaders/GLTFLoader.js';
  import { MeshoptDecoder } from 'three/examples/jsm/libs/meshopt_decoder.module.js';
  import { RoomEnvironment } from 'three/examples/jsm/environments/RoomEnvironment.js';

  function fitToView(obj: THREE.Object3D, camera: THREE.PerspectiveCamera, fitRatio = 1.15) {
    const box = new THREE.Box3().setFromObject(obj);
    const size = box.getSize(new THREE.Vector3());
    const center = box.getCenter(new THREE.Vector3());
    obj.position.sub(center);                          // center at origin
    const maxDim = Math.max(size.x, size.y, size.z);
    const dist = (maxDim / 2) / Math.tan((camera.fov * Math.PI) / 360) * fitRatio;
    camera.position.set(0, 0, dist);
    camera.lookAt(0, 0, 0);
  }

  function initHeart(stage: HTMLElement) {
    const canvas = stage.querySelector('.heart-canvas');
    if (!canvas) return;
    const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    const dpr = Math.min(window.devicePixelRatio, 2);

    const renderer = new THREE.WebGLRenderer({ canvas, alpha: true, antialias: true });
    renderer.setPixelRatio(dpr);
    renderer.setClearColor(0x000000, 0);
    renderer.toneMapping = THREE.ACESFilmicToneMapping;
    renderer.toneMappingExposure = 1.1;

    const scene = new THREE.Scene();
    const camera = new THREE.PerspectiveCamera(35, 1, 0.1, 1000);

    // studio reflections so the gold reads as metal
    const pmrem = new THREE.PMREMGenerator(renderer);
    scene.environment = pmrem.fromScene(new RoomEnvironment(), 0.04).texture;
    const key = new THREE.DirectionalLight(0xfff4d6, 2.2);
    key.position.set(2, 3, 4);
    scene.add(key);

    // pivot wraps the heart so it rotates around its OWN centre (in place),
    // not the model's far-off local origin (which would swing it out of frame)
    const pivot = new THREE.Group();
    scene.add(pivot);

    // cardiac-cycle uniforms (shared across all meshes → one coherent beat)
    const uTime = { value: 0 };
    const uMinY = { value: 0 };       // world-space vertical bounds of the model
    const uMaxY = { value: 1 };
    const uPeriod = { value: 1.7 };   // seconds per beat — slow & calm
    const uAmpV = { value: 0.15 };    // ventricular squeeze depth (fraction of radius)
    const uAmpA = { value: 0.09 };    // atrial squeeze depth
    const uShorten = { value: 0.05 }; // longitudinal shortening during ventricular systole

    const goldColor = () => {
      const css = getComputedStyle(document.documentElement).getPropertyValue('--color-heading').trim();
      return new THREE.Color(css || '#90642f');
    };
    const gold = new THREE.MeshStandardMaterial({
      color: goldColor(), metalness: 1.0, roughness: 0.26, envMapIntensity: 1.25,
    });
    new MutationObserver(() => gold.color.set(goldColor())).observe(
      document.documentElement, { attributes: true, attributeFilter: ['data-theme'] },
    );
    // Procedural cardiac cycle: spatial regions of the shell stand in for chambers.
    // Sequence per beat: atrial systole (upper region squeezes) → ventricular systole
    // (lower bulk squeezes hard + heart shortens) → diastole (everything fills).
    // Reciprocal: when one region contracts the other relaxes (blood moving through).
    // All in WORLD space so meshopt vertex-quantization can't distort the scale.
    gold.onBeforeCompile = (shader) => {
      shader.uniforms.uTime = uTime;
      shader.uniforms.uMinY = uMinY;
      shader.uniforms.uMaxY = uMaxY;
      shader.uniforms.uPeriod = uPeriod;
      shader.uniforms.uAmpV = uAmpV;
      shader.uniforms.uAmpA = uAmpA;
      shader.uniforms.uShorten = uShorten;
      shader.vertexShader =
        'uniform float uTime;\nuniform float uMinY;\nuniform float uMaxY;\nuniform float uPeriod;\nuniform float uAmpV;\nuniform float uAmpA;\nuniform float uShorten;\n'
        + shader.vertexShader;
      shader.vertexShader = shader.vertexShader.replace(
        '#include <begin_vertex>',
        `#include <begin_vertex>
         vec4 _wp = modelMatrix * vec4(transformed, 1.0);
         float _range = max(0.0001, uMaxY - uMinY);
         float _v = clamp((_wp.y - uMinY) / _range, 0.0, 1.0);   // 0 apex .. 1 base
         float _p = fract(uTime / uPeriod);                       // cardiac phase 0..1
         float _atr  = exp(-pow((_p - 0.06) / 0.075, 2.0));       // atrial systole (early)
         float _vent = exp(-pow((_p - 0.26) / 0.130, 2.0));       // ventricular systole (the "lub")
         float _ventMask = smoothstep(0.65, 0.40, _v);            // lower bulk = ventricles
         float _atrMask  = smoothstep(0.58, 0.82, _v);            // upper base = atria
         // reciprocal filling: a region relaxes while its partner contracts
         float _ventEff = uAmpV * (_vent - 0.30 * _atr);
         float _atrEff  = uAmpA * (_atr  - 0.60 * _vent);
         float _squeeze = _ventEff * _ventMask + _atrEff * _atrMask;
         _wp.xz -= _wp.xz * _squeeze;                             // radial squeeze about the axis
         // longitudinal shortening during ventricular systole (symmetric about mid → no drift)
         float _mid = 0.5 * (uMinY + uMaxY);
         _wp.y -= (_wp.y - _mid) * (uShorten * _vent);
         transformed = (inverse(modelMatrix) * _wp).xyz;`,
      );
    };

    let model: THREE.Object3D | null = null;
    let mixer: THREE.AnimationMixer | null = null;

    function setModel(obj: THREE.Object3D) {
      // swap obj into the pivot; reset so centering math is in identity space
      while (pivot.children.length) pivot.remove(pivot.children[0]);
      pivot.rotation.set(0, 0, 0);
      pivot.add(obj);
      model = obj;
      fitToView(model, camera);   // centers obj within the pivot + frames camera
      // world-space vertical bounds drive the height-based cardiac cycle
      const box = new THREE.Box3().setFromObject(obj);
      uMinY.value = box.min.y;
      uMaxY.value = box.max.y;
    }

    // load the real model (meshopt-compressed); canvas stays empty until it arrives
    const loader = new GLTFLoader();
    loader.setMeshoptDecoder(MeshoptDecoder);
    loader.load(
      stage.dataset.heartModel || '/heart.glb',
      (gltf) => {
        const root = gltf.scene;
        root.traverse((o) => { if ((o as THREE.Mesh).isMesh) (o as THREE.Mesh).material = gold; });
        setModel(root);
        if (gltf.animations.length && !reduce) {
          mixer = new THREE.AnimationMixer(root);
          mixer.clipAction(gltf.animations[0]).play();
        }
        // Start the render loop only once the model is ready — prevents accumulated
        // spin/rotation before the heart is visible, and ensures a clean first delta.
        resize();
        last = performance.now();
        requestAnimationFrame(loop);
      },
      undefined,
      () => { /* model failed to load — canvas stays empty */ },
    );

    function resize() {
      const w = stage.clientWidth, h = stage.clientHeight;
      if (!w || !h) return;
      renderer.setSize(w, h, false);
      camera.aspect = w / h;
      camera.updateProjectionMatrix();
    }
    new ResizeObserver(resize).observe(stage);
    resize();

    // auto-rotate + hover tilt + cursor-label + drag + click → terminal
    const cursorLabel = document.querySelector<HTMLElement>('.heart-cursor-label');
    const cursorGlass = document.querySelector<HTMLElement>('.heart-cursor-glass');
    const terminal    = document.querySelector<HTMLElement>('.heart-terminal');

    // keep glass sized to match label (glass has no intrinsic size)
    const syncGlassSize = () => {
      if (!cursorGlass || !cursorLabel) return;
      cursorGlass.style.width  = cursorLabel.offsetWidth  + 'px';
      cursorGlass.style.height = cursorLabel.offsetHeight + 'px';
    };
    syncGlassSize();
    if (cursorLabel) new ResizeObserver(syncGlassSize).observe(cursorLabel);

    const idleSpin = 0.3;
    let spin = 0, targetSpin = idleSpin;
    let tiltX = 0, targetTiltX = 0;
    let isDragging = false;
    let dragPX = 0, dragPY = 0, dragStartX = 0, dragStartY = 0;

    stage.addEventListener('pointerenter', () => {
      cursorLabel?.classList.add('is-visible');
      cursorGlass?.classList.add('is-visible');
      if (!isDragging) targetTiltX = 0.18;
    });
    stage.addEventListener('pointerleave', () => {
      cursorLabel?.classList.remove('is-visible');
      cursorGlass?.classList.remove('is-visible');
      if (!isDragging) targetTiltX = 0;
    });
    stage.addEventListener('pointermove', (e: Event) => {
      const pe = e as PointerEvent;
      if (cursorLabel) {
        const x = pe.clientX + 14;
        const y = pe.clientY - cursorLabel.offsetHeight / 2;
        cursorLabel.style.left = x + 'px';
        cursorLabel.style.top  = y + 'px';
        if (cursorGlass) { cursorGlass.style.left = x + 'px'; cursorGlass.style.top = y + 'px'; }
      }
      if (isDragging) {
        pivot.rotation.y += (pe.clientX - dragPX) * 0.008;
        pivot.rotation.x += (pe.clientY - dragPY) * 0.008;
        dragPX = pe.clientX; dragPY = pe.clientY;
      }
    });
    stage.addEventListener('pointerdown', (e: Event) => {
      const pe = e as PointerEvent;
      (stage as HTMLElement).setPointerCapture(pe.pointerId);
      isDragging = true;
      dragPX = dragStartX = pe.clientX;
      dragPY = dragStartY = pe.clientY;
      targetSpin = 0;
    });
    const endDrag = (e: Event) => {
      if (!isDragging) return;
      const pe = e as PointerEvent;
      const dist = Math.hypot(pe.clientX - dragStartX, pe.clientY - dragStartY);
      isDragging = false;
      tiltX = pivot.rotation.x;
      targetTiltX = 0;
      targetSpin = idleSpin;
      if (dist < 6 && terminal) {
        terminal.classList.add('is-open');
        terminal.removeAttribute('aria-hidden');
        playTerminal();
      }
    };
    stage.addEventListener('pointerup', endDrag);
    stage.addEventListener('pointercancel', endDrag);

    // terminal typing animation
    const PROMPT_HTML =
      `<span class="ht-user">giannacrisha@Giannas-MacBook-Air</span> ` +
      `<span class="ht-dir">giannacrisha.github.io</span> ` +
      `<span class="ht-pct">%</span> `;
    const CMD = 'cat why-a-heart.sh';
    const FILE_CONTENT =
      '\nbecause everything worth\n' +
      'creating starts with one :)\n' +
      'it brings hope that deep down\n' +
      'we all have one that beats\n' +
      'inside of all of us.\n';

    let typeTimer: number | null = null;

    function playTerminal() {
      if (!terminal) return;
      const body = terminal.querySelector<HTMLElement>('.ht-body');
      if (!body) return;
      if (typeTimer !== null) { clearTimeout(typeTimer); typeTimer = null; }

      body.innerHTML =
        `<span>${PROMPT_HTML}<span class="ht-cmd"></span><span class="ht-blink">▋</span></span>`;

      const cmdEl  = body.querySelector<HTMLElement>('.ht-cmd')!;
      const cursor = body.querySelector<HTMLElement>('.ht-blink')!;
      let i = 0;

      function typeNext() {
        if (i < CMD.length) {
          cmdEl.textContent += CMD[i++];
          typeTimer = setTimeout(typeNext, 65 + Math.random() * 45) as unknown as number;
        } else {
          typeTimer = setTimeout(() => {
            cursor.remove();
            // file content dumps all at once (cat behaviour)
            const out = document.createElement('span');
            out.textContent = '\n' + FILE_CONTENT + '\n';
            body!.appendChild(out);
            // second prompt + cursor
            const p2 = document.createElement('span');
            p2.innerHTML = `${PROMPT_HTML}<span class="ht-blink">▋</span>`;
            body!.appendChild(p2);
          }, 250) as unknown as number;
        }
      }

      typeTimer = setTimeout(typeNext, 450) as unknown as number;
    }

    if (terminal) {
      terminal.addEventListener('click', (e) => {
        if (e.target === terminal) { terminal.classList.remove('is-open'); terminal.setAttribute('aria-hidden', 'true'); }
      });
      terminal.querySelector<HTMLElement>('[data-tw-close]')?.addEventListener('click', () => {
        terminal.classList.remove('is-open'); terminal.setAttribute('aria-hidden', 'true');
      });
      document.addEventListener('keydown', (e) => {
        if (e.key === 'Escape' && terminal.classList.contains('is-open')) {
          terminal.classList.remove('is-open'); terminal.setAttribute('aria-hidden', 'true');
        }
      });
    }

    const start = performance.now();
    let last = start;
    function loop(now: number) {
      const delta = Math.min((now - last) / 1000, 1 / 30); // cap at 30fps minimum to avoid jumps
      last = now;
      const t = reduce ? 0 : (now - start) / 1000;
      if (mixer) mixer.update(delta);
      uTime.value = t;
      if (!isDragging) {
        spin += (targetSpin - spin) * 0.06;
        pivot.rotation.y += spin * delta;
        tiltX += (targetTiltX - tiltX) * 0.06;
        pivot.rotation.x = tiltX;
      }
      renderer.render(scene, camera);
      requestAnimationFrame(loop);
    }
  }

  document.querySelectorAll<HTMLElement>('.heart-stage').forEach(initHeart);
</script>
