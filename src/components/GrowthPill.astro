---
// src/components/GrowthPill.astro
import GrowthIcon from './icons/GrowthIcon.astro';
import type { GrowthStage } from '../config/design';
import { growthStages } from '../config/design';

interface Props { stage: GrowthStage; forceColor?: string; }
const { stage, forceColor } = Astro.props;
const stageData = growthStages[stage];

// dust=mid, spark=lightest, star=darkest
const stageColor: Record<GrowthStage, string> = {
  dust:  '#9C8B6E',
  spark: '#C4B49A',
  star:  '#5C4D3A',
};
const color = forceColor ?? stageColor[stage];
---
<span class="growth-pill" style={`color: ${color};`}>
  <GrowthIcon stage={stage} size={12} color={color} />
  <span>{stageData.label}</span>
</span>

<style>
  .growth-pill {
    display: inline-flex;
    align-items: center;
    align-self: flex-start;
    width: fit-content;
    gap: var(--space-xs);
    padding: 2px 0;
    background: transparent;
    border: none;
    font-family: var(--font-body);
    font-size: var(--text-xs);
    letter-spacing: 0.06em;
  }
</style>
