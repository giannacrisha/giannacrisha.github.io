---
// src/components/Card.astro
import GrowthPill from './GrowthPill.astro';
import StarRating from './icons/StarRating.astro';
import type { GrowthStage } from '../config/design';

interface Props {
  title:          string;
  slug:           string;
  collection:     'lab' | 'archives' | 'gallery' | 'library';
  type?:          string;
  stage?:         GrowthStage;
  date_published: Date;
  date_written?:  Date;
  date_built?:    Date;
  date_made?:     Date;
  date_added?:    Date;
  cover_image?:   string;
  rating?:        number;
  description?:   string;
  creator?:       string;
  year?:          number;
  body?:          string;
}

const {
  title, slug, collection, type, stage,
  date_published, date_written, date_built, date_made, date_added,
  cover_image, rating, description, creator, year, body,
} = Astro.props;

// Strip markdown syntax and truncate to ~160 chars for preview
function excerpt(raw: string, max = 160): string {
  const stripped = raw
    .replace(/^---[\s\S]*?---/, '')   // remove frontmatter if any
    .replace(/#{1,6}\s+/g, '')        // headings
    .replace(/\*\*(.+?)\*\*/g, '$1') // bold
    .replace(/\*(.+?)\*/g, '$1')     // italic
    .replace(/`{1,3}[^`]*`{1,3}/g, '') // code
    .replace(/\[(.+?)\]\(.+?\)/g, '$1') // links
    .replace(/^\s*[-*>]\s+/gm, '')   // list/blockquote markers
    .replace(/\n+/g, ' ')            // collapse newlines
    .trim();
  return stripped.length > max ? stripped.slice(0, max).trimEnd() + '…' : stripped;
}

const preview = description ?? (body ? excerpt(body) : null);

const href = `/${collection}/${slug}`;

let primaryDate = date_published;
if (collection === 'archives' && date_written) primaryDate = date_written;
if (collection === 'lab'      && date_built)   primaryDate = date_built;
if (collection === 'gallery'  && date_made)    primaryDate = date_made;
if (collection === 'library'  && date_added)   primaryDate = date_added;

const fmt = (d: Date) => d.toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' });
const isGallery = collection === 'gallery';
const isLibrary = collection === 'library';
const hasImage = !!cover_image;
// Library cards show cover as a corner thumbnail, not full-width
const showFullImage = hasImage && !isGallery && !isLibrary;
const showCoverThumb = hasImage && isLibrary;
---
<article class:list={['card', { 'card--gallery': isGallery && hasImage }]}
         style={isGallery && hasImage ? `background-image: url(${cover_image}); background-size: cover; background-position: center;` : ''}>
  <a href={href} class="card-link">
    {showFullImage && (
      <div class="card-image">
        <img src={cover_image} alt={title} loading="lazy" />
      </div>
    )}
    <div class:list={['card-body', { 'card-body--gallery': isGallery && hasImage }]}>
      {stage && (
        <div class="card-stage-pill">
          <GrowthPill stage={stage} forceColor={isGallery && hasImage ? 'rgba(255,255,255,0.9)' : undefined} />
        </div>
      )}
      {showCoverThumb && (
        <img class="card-cover-thumb" src={cover_image} alt={title} loading="lazy" />
      )}
      {type && <span class="pill card-type-pill">{type}</span>}
      <h3 class="card-title">{title}</h3>
      {creator && (
        <p class="card-creator">{creator}{year ? ` · ${year}` : ''}</p>
      )}
      {preview && <p class="card-description">{preview}</p>}
      {rating !== undefined && <StarRating rating={rating} />}
      <div class="card-footer">
        {primaryDate && <span class="card-date">{fmt(primaryDate)}</span>}
      </div>
    </div>
  </a>
</article>

<style>
  .card {
    background: var(--color-card);
    border: 0.5px solid var(--color-border);
    border-radius: var(--radius-card);
    overflow: hidden;
    transition: border-color 0.15s ease;
    height: 100%;
    display: flex;
    flex-direction: column;
  }
  .card:hover { border-color: var(--color-accent); }

  .card-link {
    display: flex;
    flex-direction: column;
    flex: 1;
    text-decoration: none;
    color: inherit;
  }

  .card-image img {
    width: 100%;
    display: block;
    object-fit: cover;
    max-height: 200px;
  }

  .card-body {
    padding: var(--space-lg);
    display: flex;
    flex-direction: column;
    gap: var(--space-sm);
    flex: 1;
    position: relative;
  }

  .card-stage-pill {
    position: absolute;
    top: var(--space-lg);
    right: var(--space-lg);
    z-index: 1;
  }

  .card-cover-thumb {
    position: absolute;
    top: var(--space-lg);
    right: var(--space-lg);
    width: 52px;
    height: 72px;
    object-fit: cover;
    border-radius: 4px;
    box-shadow: 0 2px 8px rgba(0,0,0,0.15);
  }

  .card-title {
    font-family: var(--font-serif);
    font-size: var(--text-md);
    color: var(--color-fg);
    line-height: var(--leading-tight);
    padding-right: 76px; /* reserve space for the stage pill (~63px wide + breathing room) */
  }
  /* when both stage pill and cover thumb are present, push thumb below the pill */
  .card-stage-pill + .card-cover-thumb {
    top: calc(var(--space-lg) + 24px);
  }

  /* leave room for the cover thumbnail */
  .card-cover-thumb ~ * .card-title,
  :has(.card-cover-thumb) .card-title {
    padding-right: 68px;
  }

  .card-creator {
    font-family: var(--font-body);
    font-size: var(--text-sm);
    color: var(--color-muted);
  }

  .card-description {
    font-family: var(--font-body);
    font-size: var(--text-sm);
    color: var(--color-muted);
    line-height: var(--leading-base);
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .card-footer {
    margin-top: auto;
    padding-top: var(--space-sm);
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .card-date {
    font-family: var(--font-body);
    font-size: var(--text-xs);
    color: var(--color-muted);
    letter-spacing: 0.03em;
  }

  /* gallery variant — image fills the whole card */
  .card--gallery {
    border: none;
    min-height: 260px;
  }
  .card-body--gallery {
    background: linear-gradient(to top, rgba(0,0,0,0.55) 0%, transparent 60%);
    border-radius: 0 0 var(--radius-card) var(--radius-card);
  }
  .card--gallery .card-title { color: #fff; }
  .card--gallery .card-date  { color: rgba(255,255,255,0.7); }
  .card--gallery .pill       { background: rgba(255,255,255,0.15); border-color: rgba(255,255,255,0.3); color: #fff; }
</style>
