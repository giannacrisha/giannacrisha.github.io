---
import MiniCard from './MiniCard.astro';

interface Props {
  entries: any[];
  label?: string;
}

const { entries, label = 'more from the garden' } = Astro.props;
---

{entries.length > 0 && (
  <aside class="recommended">
    <p class="recommended-label">{label}</p>
    <div class="recommended-list">
      {entries.map(entry => (
        <MiniCard
          title={entry.data.title}
          slug={entry.slug}
          collection={entry.collection}
          type={entry.data.type}
          stage={entry.data.growth_stage}
          date={
            entry.data.date_published ??
            entry.data.date_written ??
            entry.data.date_built ??
            entry.data.date_made ??
            entry.data.date_added
          }
          body={entry.body}
          description={entry.data.description}
          creator={entry.data.creator}
          cover_image={entry.data.cover_image ?? entry.data.image}
        />
      ))}
    </div>
  </aside>
)}

<style>
  .recommended-label {
    font-family: var(--font-body);
    font-size: var(--text-xs);
    color: var(--color-muted);
    letter-spacing: 0.1em;
    margin-bottom: var(--space-lg);
  }
  .recommended-list {
    display: flex;
    flex-direction: column;
    gap: var(--space-md);
  }
</style>
