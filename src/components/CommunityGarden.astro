---
// src/components/CommunityGarden.astro
import { REPO_OWNER, REPO_NAME, LABEL } from '../config/github';
import Icon from './Icon.astro';

function timeAgo(dateStr: string): string {
  const now = Date.now();
  const then = new Date(dateStr).getTime();
  if (isNaN(then)) return '';
  const diff = Math.floor((now - then) / 1000);
  if (diff < 60) return 'just now';
  if (diff < 3600) return `${Math.floor(diff / 60)}m ago`;
  if (diff < 86400) return `${Math.floor(diff / 3600)}h ago`;
  if (diff < 86400 * 60) return `${Math.floor(diff / 86400)}d ago`;
  return `${Math.floor(diff / (86400 * 30))}mo ago`;
}

const FEATURED_COUNT = 4;

type Submission = {
  pixels: (string|null)[];
  name: string;
  note: string;
  website: string;
  ts: string;
  issueNumber: number;
  hearts: number;
};

let submissions: Submission[] = [];

try {
  const res = await fetch(
    `https://api.github.com/repos/${REPO_OWNER}/${REPO_NAME}/issues?labels=${LABEL}&state=open&per_page=100`,
    { headers: { Accept: 'application/vnd.github+json', 'X-GitHub-Api-Version': '2022-11-28' } }
  );
  if (res.ok) {
    const issues = await res.json() as { body: string; created_at: string; number: number; reactions?: { heart: number } }[];
    submissions = issues.map(i => {
      try {
        const parsed = JSON.parse(i.body);
        if (!parsed.ts) parsed.ts = i.created_at;
        parsed.issueNumber = i.number;
        parsed.hearts = i.reactions?.heart ?? 0;
        // Sanitize website: only keep http(s) URLs
        if (parsed.website) {
          try {
            const u = new URL(parsed.website);
            if (u.protocol !== 'http:' && u.protocol !== 'https:') parsed.website = '';
          } catch { parsed.website = ''; }
        }
        return parsed as Submission;
      } catch { return null; }
    }).filter(Boolean) as Submission[];

    // Sort by hearts desc, newest first as tiebreaker
    submissions.sort((a, b) => (b.hearts - a.hearts) || (new Date(b.ts).getTime() - new Date(a.ts).getTime()));
  }
} catch (e) { console.warn('Community garden fetch failed:', e); }

const featuredSubmissions = submissions.slice(0, FEATURED_COUNT);
const lockedSubmissions   = submissions.slice(FEATURED_COUNT);

const HEART_EMPTY = `<svg viewBox="0 0 24 24" width="20" height="20" fill="currentColor" aria-hidden="true"><path d="m22,6v-1h-1v-1h-1v-1h-6v1h-1v1h-2v-1h-1v-1h-6v1h-1v1h-1v1h-1v5h1v1h1v1h1v1h1v1h1v1h1v1h1v1h1v1h1v1h1v1h2v-1h1v-1h1v-1h1v-1h1v-1h1v-1h1v-1h1v-1h1v-1h1v-1h1v-5h-1Zm-2,4v1h-1v1h-1v1h-1v1h-1v1h-1v1h-1v1h-1v1h-2v-1h-1v-1h-1v-1h-1v-1h-1v-1h-1v-1h-1v-1h-1v-1h-1v-3h1v-1h1v-1h4v1h1v1h1v1h2v-1h1v-1h1v-1h4v1h1v1h1v3h-1Z"/></svg>`;
const HEART_FILLED = `<svg viewBox="0 0 24 24" width="20" height="20" fill="currentColor" aria-hidden="true"><polygon points="23 6 23 11 22 11 22 12 21 12 21 13 20 13 20 14 19 14 19 15 18 15 18 16 17 16 17 17 16 17 16 18 15 18 15 19 14 19 14 20 13 20 13 21 11 21 11 20 10 20 10 19 9 19 9 18 8 18 8 17 7 17 7 16 6 16 6 15 5 15 5 14 4 14 4 13 3 13 3 12 2 12 2 11 1 11 1 6 2 6 2 5 3 5 3 4 4 4 4 3 10 3 10 4 11 4 11 5 13 5 13 4 14 4 14 3 20 3 20 4 21 4 21 5 22 5 22 6 23 6"/></svg>`;

---

<link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:opsz,wght,FILL,GRAD@20,300,0,0" />

<div class="cg-layout" id="cg-layout">

  <!-- ── Left: drawing zone ────────────────────────────── -->
  <aside class="cg-left" id="cg-left">

    <!-- Editor -->
    <div class="editor-wrap">
      <div class="toolbar" id="toolbar" role="group" aria-label="Drawing tools"></div>
      <div class="canvas-col">
        <div class="canvas-controls">
          <div class="size-row" role="group" aria-label="Brush size">
            {[1,2,3,4].map(n => (
              <button class:list={['size-btn', { 'size-active': n === 1 }]} data-size={n} aria-label={`${n}px brush`}>
                <span class="size-dot" style={`width:${n*3}px;height:${n*3}px`}></span>
              </button>
            ))}
          </div>
          <div class="canvas-btn-group">
            <button class="zoom-btn" id="save-btn" aria-label="Save artwork as PNG">
              <span class="material-symbols-outlined">download</span>
            </button>
            <button class="zoom-btn" id="zoom-btn" aria-label="Toggle zoom">
              <span class="material-symbols-outlined">zoom_in</span>
            </button>
          </div>
        </div>
        <div class="canvas-zoom-wrap" id="canvas-zoom-wrap">
          <canvas id="pixel-canvas" width="256" height="256" class="pixel-canvas" aria-label="pixel art drawing canvas"></canvas>
        </div>
        <div class="palette" id="palette" role="group" aria-label="Color palette">
          <!-- custom color picker swatch -->
          <div class="custom-color-wrap" id="custom-color-wrap">
            <button class="swatch swatch-rainbow" id="swatch-rainbow" aria-label="Pick custom color" type="button" title="Custom color"></button>
            <div class="color-popover" id="color-popover" role="dialog" aria-label="Custom color picker" hidden>
              <input type="color" id="color-wheel" class="color-wheel" value="#ff0000" aria-label="Color wheel" />
              <div class="hex-row">
                <span class="hex-hash">#</span>
                <input type="text" id="hex-input" class="hex-input" maxlength="6" placeholder="ff0000" aria-label="Hex color code" spellcheck="false" />
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- Form -->
    <form class="plant-form" id="plant-form" novalidate>
      <input type="text" name="hp" tabindex="-1" autocomplete="off" aria-hidden="true" style="display:none" />
      <div class="form-row">
        <input type="text" id="plant-name" name="name" placeholder="your name or handle (optional)" maxlength="50" class="plant-input" aria-label="your name or handle (optional)" />
      </div>
      <textarea id="plant-note" name="note" placeholder="leave a little note (optional, 280 chars)" maxlength="280" class="plant-textarea" rows="2" aria-label="leave a little note (optional, 280 characters max)"></textarea>
      <div class="form-footer">
        <span class="pixel-count" id="pixel-count">draw at least 4 pixels to plant</span>
        <button type="submit" class="plant-btn" id="plant-btn" disabled>plant</button>
      </div>
      <p class="plant-confirm" id="plant-confirm" hidden>planted! it'll appear here soon. thank you ♡</p>
      <p class="plant-error"   id="plant-error"   hidden></p>
    </form>
  </aside>

  <!-- ── Resize handle ─────────────────────────────────── -->
  <div class="cg-resizer" id="cg-resizer" role="separator" aria-label="Resize drawing zone" aria-orientation="vertical" tabindex="0">
    <div class="cg-resizer-grip"></div>
  </div>

  <!-- ── Right: scrollable community plantings ─────────── -->
  <section class="cg-right" aria-label="Community plantings">

    <!-- Header -->
    <div class="cg-header page-header">
      <div class="cg-title-row page-title-row">
        <h1 class="section-header cg-title">our garden</h1>
        {submissions.length > 0 && (
          <span class="pill">{submissions.length} planted</span>
        )}
      </div>
      <p class="page-def">draw a tiny pixel-art plant or creature and leave it here for everyone to find.</p>
      <hr class="cg-divider" />
    </div>

    {submissions.length === 0 ? (
      <div class="cg-empty">
        <p>no plants yet.</p>
        <p class="cg-empty-sub">be the first to plant! ↙</p>
      </div>
    ) : (
      <>
        {/* Featured plantings — always visible */}
        <div class="plantings" id="cg-featured">
          {featuredSubmissions.map(s => (
            <div class="planting">
              <div class="planting-canvas-wrap">
                <canvas class="planting-canvas" width="96" height="96"
                  data-pixels={JSON.stringify(s.pixels)}
                  aria-label={`pixel art by ${s.name || 'anonymous'}`}></canvas>
                <button class="heart-overlay" data-issue={String(s.issueNumber)}
                  aria-label={`Heart ${s.name || 'anonymous'}'s planting`}>
                  <span class="heart-icon-empty" set:html={HEART_EMPTY} />
                  <span class="heart-icon-filled" set:html={HEART_FILLED} />
                </button>
              </div>
              <div class="planting-tooltip">
                <span class="planting-tooltip-name">{s.name || 'anonymous'}</span>
                {s.note && <p class="planting-tooltip-note">{s.note}</p>}
                {s.website && <a href={s.website} target="_blank" rel="noopener noreferrer" class="planting-tooltip-link">visit site ↗</a>}
                {s.ts && <span class="planting-tooltip-time">{timeAgo(s.ts)}</span>}
              </div>
              <div class="planting-meta">
                <span class="heart-count" data-issue={String(s.issueNumber)}>
                  <Icon name="heart" size={10} /><span class="heart-count-num">{s.hearts > 0 ? s.hearts : ''}</span>
                </span>
                {s.ts && <span class="planting-time">{timeAgo(s.ts)}</span>}
              </div>
            </div>
          ))}
        </div>

        {/* Locked plantings — hidden until visitor plants something */}
        {lockedSubmissions.length > 0 && (
          <div class="cg-locked" id="cg-locked">
            <div class="plantings plantings-peek">
              {lockedSubmissions.map(s => (
                <div class="planting">
                  <div class="planting-canvas-wrap">
                    <canvas class="planting-canvas" width="96" height="96"
                      data-pixels={JSON.stringify(s.pixels)}
                      aria-label={`pixel art by ${s.name || 'anonymous'}`}></canvas>
                    <button class="heart-overlay" data-issue={String(s.issueNumber)}
                      aria-label={`Heart ${s.name || 'anonymous'}'s planting`}>
                      <span class="heart-icon-empty" set:html={HEART_EMPTY} />
                      <span class="heart-icon-filled" set:html={HEART_FILLED} />
                    </button>
                  </div>
                  <div class="planting-tooltip">
                    <span class="planting-tooltip-name">{s.name || 'anonymous'}</span>
                    {s.note && <p class="planting-tooltip-note">{s.note}</p>}
                    {s.website && <a href={s.website} target="_blank" rel="noopener noreferrer" class="planting-tooltip-link">visit site ↗</a>}
                    {s.ts && <span class="planting-tooltip-time">{timeAgo(s.ts)}</span>}
                  </div>
                  <div class="planting-meta">
                    <span class="heart-count" data-issue={String(s.issueNumber)}>
                  <Icon name="heart" size={10} /><span class="heart-count-num">{s.hearts > 0 ? s.hearts : ''}</span>
                </span>
                    {s.ts && <span class="planting-time">{timeAgo(s.ts)}</span>}
                  </div>
                </div>
              ))}
            </div>
            <div class="cg-lock-overlay" id="cg-lock-overlay">
              <p class="cg-lock-msg">{lockedSubmissions.length} more planting{lockedSubmissions.length === 1 ? '' : 's'}</p>
              <p class="cg-lock-sub">draw something to see the full garden</p>
              <button class="cg-lock-btn" id="cg-lock-scroll">draw something ↙</button>
            </div>
          </div>
        )}
      </>
    )}
  </section>

  <hr class="cg-section-divider" />

</div>

<!-- ── Submit success modal ──────────────────────────────────── -->
<div id="cg-modal" class="cg-modal" aria-modal="true" role="dialog" aria-label="Submission confirmed" hidden>
  <div class="cg-modal-card">
    <p class="cg-modal-headline">you're in the garden ♡</p>
    <p class="cg-modal-sub">your submission will be live soon!</p>
  </div>
</div>

<style>
  /* ── Full-height split layout ───────────────────────── */
  .cg-layout {
    display: flex;
    width: 100%;
    height: 100%;
    overflow: hidden;
  }

  /* Left panel: explicit width set by JS drag, fills full height */
  .cg-left {
    width: 480px;
    min-width: 300px;
    max-width: 65vw;
    height: 100%;
    flex-shrink: 0;
    overflow-y: auto;
    display: flex;
    flex-direction: column;
    gap: var(--space-xl);
    padding: var(--space-section) var(--space-xxl);
    box-sizing: border-box;
    background: var(--color-bg);
  }

  /* Resize handle */
  .cg-resizer {
    width: 8px;
    flex-shrink: 0;
    height: 100%;
    background: var(--color-border);
    cursor: col-resize;
    position: relative;
    transition: background 0.15s;
    user-select: none;
  }
  .cg-resizer:hover,
  .cg-resizer.dragging { background: var(--color-accent); }

  /* Grip pill stays vertically centered in the viewport, not the full panel */
  .cg-resizer-grip {
    position: sticky;
    top: calc(50vh - 16px); /* center of visible viewport */
    width: 3px;
    height: 32px;
    border-radius: 999px;
    background: rgba(0,0,0,0.2);
    margin: 0 auto;
    pointer-events: none;
  }

  /* ── Header ──────────────────────────────────────────── */
  .cg-header {
    display: flex;
    flex-direction: column;
    gap: 0;
    padding: var(--space-xxl) 0 var(--space-md);
  }
  .cg-title-row {
    display: flex;
    align-items: center;
    gap: var(--space-lg);
    flex-wrap: wrap;
    margin-bottom: var(--space-md);
  }
  .cg-title { margin: 0; }
  .cg-divider {
    border: none;
    border-top: 0.5px solid var(--color-border);
    margin: var(--space-xl) 0 0;
  }

  /* section divider — mobile only */
  .cg-section-divider {
    display: none;
    border: none;
    border-top: 0.5px solid var(--color-border);
    margin: 0;
  }

  /* Info — plain text, matches page-def style */
  .cg-info {
    font-family: var(--font-body);
    font-size: var(--text-sm);
    color: var(--color-muted);
    line-height: var(--leading-loose);
    margin: 0;
  }

  /* ── Editor ───────────────────────────────────────────── */
  .editor-wrap { display: flex; gap: var(--space-md); align-items: flex-start; min-width: 0; justify-content: center; }

  /* toolbar — fixed vertical strip, doesn't need to grow */
  .toolbar { display: flex; flex-direction: column; gap: 4px; padding: 6px; background: var(--color-card); border: 0.5px solid var(--color-border); border-radius: var(--radius-card); flex-shrink: 0; }
  :global(.tool-btn) { width: 34px; height: 34px; border-radius: 12px; border: none; background: none; color: var(--color-muted); cursor: pointer; display: flex; align-items: center; justify-content: center; transition: background 0.12s, color 0.12s; }
  :global(.tool-btn:hover) { background: var(--color-accent-light); color: var(--color-fg); }
  :global(.tool-btn.tool-active) { background: var(--color-fg); color: var(--color-bg); }
  :global(.tool-divider) { height: 0.5px; background: var(--color-border); margin: 2px 4px; }
  :global(.material-symbols-outlined) { font-size: 18px; line-height: 1; user-select: none; }

  /* canvas-col grows to fill remaining editor-wrap width */
  .canvas-col { display: flex; flex-direction: column; gap: var(--space-md); flex: 1; min-width: 0; }

  /* canvas controls row: size row + zoom btn */
  .canvas-controls { display: flex; align-items: center; justify-content: space-between; gap: var(--space-md); }

  /* zoom wrap */
  .canvas-zoom-wrap { overflow: auto; width: 100%; }
  .canvas-zoom-wrap.canvas-zoomed .pixel-canvas { width: 512px; height: 512px; max-width: none; }

  .pixel-canvas {
    width: 100%;
    aspect-ratio: 1 / 1;
    height: auto;
    max-width: 480px;
    image-rendering: pixelated;
    display: block;
    background: #ffffff;
    border: 0.5px solid var(--color-border);
    border-radius: 12px;
    cursor: crosshair;
    touch-action: none;
  }

  /* size row stretches with canvas */
  .size-row { display: flex; gap: 6px; align-items: center; }
  .size-btn { width: 32px; height: 32px; border-radius: 12px; border: 0.5px solid var(--color-border); background: var(--color-card); cursor: pointer; display: flex; align-items: center; justify-content: center; transition: background 0.12s, border-color 0.12s; flex-shrink: 0; }
  .size-btn.size-active { background: var(--color-fg); border-color: var(--color-fg); }
  .size-btn.size-active .size-dot { background: var(--color-bg); }
  .size-dot { border-radius: 50%; background: var(--color-fg); display: block; }

  /* zoom button */
  .canvas-btn-group { display: flex; gap: 4px; flex-shrink: 0; }
  .zoom-btn { width: 32px; height: 32px; border-radius: 12px; border: 0.5px solid var(--color-border); background: var(--color-card); cursor: pointer; display: flex; align-items: center; justify-content: center; transition: background 0.12s; flex-shrink: 0; color: var(--color-muted); }
  .zoom-btn:hover, .zoom-btn.zoom-active { background: var(--color-fg); color: var(--color-bg); }

  /* palette matches canvas width */
  .palette { display: flex; flex-wrap: wrap; gap: 5px; width: 100%; max-width: 480px; align-items: flex-start; }

  /* rainbow swatch + popover */
  .custom-color-wrap { position: relative; }
  .swatch-rainbow {
    width: 20px; height: 20px; border-radius: 5px;
    border: 1.5px solid transparent;
    cursor: pointer;
    background: conic-gradient(red, yellow, lime, cyan, blue, magenta, red);
    transition: transform 0.1s, border-color 0.1s;
    padding: 0;
  }
  .swatch-rainbow:hover { transform: scale(1.2); }
  .swatch-rainbow.swatch-active { border-color: var(--color-fg); transform: scale(1.12); }

  .color-popover {
    position: absolute;
    bottom: calc(100% + 8px);
    left: 0;
    background: var(--color-card);
    border: 0.5px solid var(--color-border);
    border-radius: 12px;
    padding: var(--space-md);
    display: flex;
    flex-direction: column;
    gap: var(--space-sm);
    box-shadow: 0 4px 20px rgba(0,0,0,0.12);
    z-index: 50;
    width: 180px;
  }
  .color-popover[hidden] { display: none; }
  .color-wheel {
    width: 100%;
    height: 120px;
    border: none;
    border-radius: 8px;
    cursor: pointer;
    padding: 0;
    background: none;
  }
  .hex-row {
    display: flex;
    align-items: center;
    gap: 4px;
    background: var(--color-bg);
    border: 0.5px solid var(--color-border);
    border-radius: 8px;
    padding: 4px 8px;
  }
  .hex-hash {
    font-family: var(--font-mono, monospace);
    font-size: var(--text-sm);
    color: var(--color-muted);
  }
  .hex-input {
    flex: 1;
    border: none;
    background: none;
    font-family: var(--font-mono, monospace);
    font-size: var(--text-sm);
    color: var(--color-fg);
    outline: none;
    width: 100%;
  }
  :global(.swatch) { width: 20px; height: 20px; border-radius: 5px; border: 1.5px solid transparent; cursor: pointer; transition: transform 0.1s, border-color 0.1s; }
  :global(.swatch:hover) { transform: scale(1.2); }
  :global(.swatch.swatch-active) { border-color: var(--color-fg); transform: scale(1.12); }

  /* ── Form ────────────────────────────────────────────── */
  .plant-form { display: flex; flex-direction: column; gap: var(--space-md); }
  .form-row { display: flex; gap: var(--space-md); flex-wrap: wrap; }
  .plant-input { flex: 1; min-width: 120px; background: var(--color-card); border: 0.5px solid var(--color-border); border-radius: var(--radius-input); padding: var(--space-sm) var(--space-md); font-family: var(--font-body); font-size: var(--text-sm); color: var(--color-fg); outline: none; transition: border-color 0.15s; }
  .plant-input:focus { border-color: var(--color-accent); }
  .plant-input::placeholder { color: var(--color-muted); }
  .plant-textarea { background: var(--color-card); border: 0.5px solid var(--color-border); border-radius: var(--radius-input); padding: var(--space-sm) var(--space-md); font-family: var(--font-body); font-size: var(--text-sm); color: var(--color-fg); outline: none; resize: vertical; transition: border-color 0.15s; width: 100%; box-sizing: border-box; }
  .plant-textarea:focus { border-color: var(--color-accent); }
  .plant-textarea::placeholder { color: var(--color-muted); }
  .form-footer { display: flex; align-items: center; justify-content: space-between; gap: var(--space-md); flex-wrap: wrap; }
  .pixel-count { font-family: var(--font-body); font-size: var(--text-xs); color: var(--color-muted); }
  .plant-btn { background: var(--color-fg); color: var(--color-bg); border: none; border-radius: var(--radius-pill); padding: var(--space-sm) var(--space-xl); font-family: var(--font-body); font-size: var(--text-sm); cursor: pointer; transition: opacity 0.15s, background 0.15s; white-space: nowrap; }
  .plant-btn:disabled { opacity: 0.35; cursor: not-allowed; }
  .plant-btn:not(:disabled):hover { background: var(--color-accent); }
  .plant-confirm { font-family: var(--font-body); font-size: var(--text-sm); color: var(--color-muted); font-style: italic; }
  .plant-error { font-family: var(--font-body); font-size: var(--text-sm); color: #c0392b; }

  /* ── Right: plantings ────────────────────────────────── */
  .cg-right {
    flex: 1;
    min-width: 0;
    height: 100%;
    overflow-y: auto;
    padding: var(--space-xl) var(--space-xxl);
    box-sizing: border-box;
    background: var(--color-bg);
    display: flex;
    flex-direction: column;
    gap: var(--space-xl);
  }

  /* empty state */
  .cg-empty { display: flex; flex-direction: column; gap: var(--space-sm); padding-top: var(--space-xl); }
  .cg-empty p { font-family: var(--font-body); font-size: var(--text-sm); color: var(--color-muted); font-style: italic; margin: 0; }
  .cg-empty-sub { font-size: var(--text-xs) !important; }

  .plantings {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(140px, 1fr));
    gap: var(--space-xl);
  }

  /* planting item */
  .planting {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 4px;
    position: relative;
  }

  /* canvas wrap — positions the heart overlay */
  .planting-canvas-wrap {
    position: relative;
    display: block;
    border-radius: 12px;
    overflow: hidden;
  }

  /* heart overlay — covers canvas, appears on hover */
  .heart-overlay {
    position: absolute;
    inset: 0;
    border: none;
    background: rgba(0,0,0,0);
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    opacity: 0;
    transition: background 0.18s ease, opacity 0.18s ease;
    color: #ffffff;
    padding: 0;
    border-radius: 12px;
  }
  .planting:hover .heart-overlay { opacity: 1; background: rgba(0,0,0,0.38); }
  .heart-overlay.heart-active { color: var(--color-danger); }
  .planting:hover .heart-overlay.heart-active { background: rgba(0,0,0,0.18); }

  .heart-icon-empty,
  .heart-icon-filled {
    display: flex;
    align-items: center;
    justify-content: center;
    transition: transform 0.15s ease;
  }
  .heart-icon-filled { display: none; }
  .heart-overlay.heart-active .heart-icon-empty { display: none; }
  .heart-overlay.heart-active .heart-icon-filled { display: flex; }

  /* heart pop animation */
  @keyframes heart-pop {
    0%   { transform: scale(1);   }
    35%  { transform: scale(1.5); }
    65%  { transform: scale(0.88);}
    100% { transform: scale(1);   }
  }
  .heart-overlay.heart-popping .heart-icon-filled {
    animation: heart-pop 0.45s cubic-bezier(0.34, 1.56, 0.64, 1) forwards;
  }

  /* tooltip */
  .planting-tooltip {
    position: absolute;
    bottom: calc(100% + 8px);
    left: 50%;
    transform: translateX(-50%);
    background: var(--color-fg);
    color: var(--color-bg);
    border-radius: 10px;
    padding: 8px 12px;
    min-width: 120px;
    max-width: 200px;
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.15s;
    z-index: 10;
    white-space: normal;
    text-align: center;
  }
  .planting:hover .planting-tooltip { opacity: 1; }
  .planting-tooltip-name { font-family: var(--font-body); font-size: var(--text-xs); font-weight: 600; color: inherit; display: block; }
  .planting-tooltip-note { font-family: var(--font-body); font-size: 10px; color: inherit; opacity: 0.8; margin: 4px 0 0; display: -webkit-box; -webkit-line-clamp: 3; -webkit-box-orient: vertical; overflow: hidden; }
  .planting-tooltip-time { font-family: var(--font-body); font-size: 10px; opacity: 0.6; display: block; margin-top: 4px; }
  .planting-tooltip-link { font-family: var(--font-body); font-size: 10px; color: inherit; opacity: 0.75; display: block; margin-top: 4px; text-decoration: underline; }

  /* planting meta row: count + timestamp */
  .planting-meta {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: var(--space-sm);
    min-height: 16px;
  }
  .planting-time { font-family: var(--font-body); font-size: 10px; color: var(--color-muted); }

  /* heart count */
  .heart-count {
    display: inline-flex;
    align-items: center;
    gap: 3px;
    font-family: var(--font-body);
    font-size: 10px;
    color: var(--color-muted);
    transition: color 0.15s;
    min-width: 10px;
    text-align: center;
  }
  .heart-icon { flex-shrink: 0; }
  .heart-count.heart-count--active { color: var(--color-danger); }

  @keyframes count-up {
    from { opacity: 0; transform: translateY(3px); }
    to   { opacity: 1; transform: translateY(0);   }
  }
  .heart-count.animating { animation: count-up 0.2s ease forwards; }

  /* ── Lock / unlock ───────────────────────────────────── */
  .cg-locked {
    position: relative;
    overflow: hidden;
    max-height: 320px;
    min-height: 280px;
  }
  .plantings-peek {
    opacity: 0.35;
    pointer-events: none;
    user-select: none;
    filter: blur(2px);
  }
  .cg-lock-overlay {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    padding: var(--space-xxl) var(--space-lg) var(--space-xl);
    background: linear-gradient(to bottom, transparent, var(--color-bg) 55%);
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-sm);
    text-align: center;
  }
  .cg-lock-msg {
    font-family: var(--font-body);
    font-size: var(--text-sm);
    color: var(--color-fg);
    font-weight: 600;
    margin: 0;
  }
  .cg-lock-sub {
    font-family: var(--font-body);
    font-size: var(--text-xs);
    color: var(--color-muted);
    margin: 0;
  }
  .cg-lock-btn {
    margin-top: var(--space-sm);
    background: var(--color-fg);
    color: var(--color-bg);
    border: none;
    border-radius: var(--radius-pill);
    padding: var(--space-sm) var(--space-xl);
    font-family: var(--font-body);
    font-size: var(--text-sm);
    cursor: pointer;
    transition: opacity 0.15s;
  }
  .cg-lock-btn:hover { opacity: 0.8; }

  /* canvas button — mobile only */
  .cg-canvas-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    background: var(--color-fg);
    color: var(--color-bg);
    border: none;
    border-radius: var(--radius-pill);
    padding: var(--space-sm) var(--space-xl);
    font-family: var(--font-body);
    font-size: var(--text-sm);
    cursor: pointer;
    transition: opacity 0.15s;
    width: fit-content;
    margin-left: auto;
    flex-shrink: 0;
  }
  .cg-canvas-btn:hover { opacity: 0.8; }

  /* unlocked state — applied by JS when visitor has planted */
  .cg-locked.unlocked {
    max-height: none;
    overflow: visible;
  }
  .cg-locked.unlocked .plantings-peek {
    opacity: 1;
    pointer-events: auto;
    filter: none;
  }
  .cg-locked.unlocked .cg-lock-overlay { display: none; }

  .planting-canvas {
    width: 96px;
    height: 96px;
    image-rendering: pixelated;
    border-radius: 12px;
    border: 0.5px solid var(--color-border);
    transition: transform 0.25s cubic-bezier(0.34, 1.56, 0.64, 1);
    cursor: default;
    display: block;
  }
  .planting:hover .planting-canvas { transform: scale(1.06); }

  /* ── Mobile: stack vertically ────────────────────────── */
  @media (max-width: 720px) {
    .cg-layout {
      flex-direction: column;
      height: auto;
      overflow: visible;
    }
    .cg-right {
      order: -1;
      height: auto;
      overflow: visible;
      padding: 0 var(--space-lg);
    }
    .cg-left {
      width: 100% !important;
      max-width: 100%;
      height: auto;
      overflow: visible;
      padding: var(--space-xl) var(--space-lg);
    }
    .cg-resizer { display: none; }
    .cg-left { border-top: var(--border); }
    .cg-right { min-height: 100vh; }
    .cg-section-divider { display: block; }
  }

  /* ── Submit success modal ────────────────────────────────── */
  .cg-modal {
    position: fixed;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    z-index: 100;
    pointer-events: none;
  }
  .cg-modal[hidden] { display: none; }
  .cg-modal-card {
    background: var(--color-bg);
    border: 0.5px solid var(--color-border);
    border-radius: var(--radius-card);
    padding: var(--space-xxl) var(--space-section);
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-sm);
    text-align: center;
    box-shadow: 0 8px 32px rgba(0,0,0,0.08);
    animation: modal-in 0.3s cubic-bezier(0.34, 1.56, 0.64, 1) forwards;
  }
  .cg-modal.modal-out .cg-modal-card {
    animation: modal-out 0.25s ease-in forwards;
  }
  @keyframes modal-in {
    from { opacity: 0; transform: scale(0.88) translateY(8px); }
    to   { opacity: 1; transform: scale(1)    translateY(0);   }
  }
  @keyframes modal-out {
    from { opacity: 1; transform: scale(1)    translateY(0);   }
    to   { opacity: 0; transform: scale(0.94) translateY(-6px); }
  }
  .cg-modal-headline {
    font-family: var(--font-body);
    font-size: var(--text-md);
    font-weight: 600;
    color: var(--color-fg);
    margin: 0;
  }
  .cg-modal-sub {
    font-family: var(--font-body);
    font-size: var(--text-sm);
    color: var(--color-muted);
    margin: 0;
  }
</style>

<script>
import { GRID, idx, inBounds, bresenham, rectOutline, ellipseOutline, floodFill } from '../lib/pixel';
(function () {
  const CELL = 16;

  // ── Canvas setup ─────────────────────────────────────────────────────
  const canvas = document.getElementById('pixel-canvas') as HTMLCanvasElement;
  const ctx = canvas.getContext('2d')!;

  // ── Mobile canvas button ─────────────────────────────────────────────
  const canvasBtn = document.getElementById('cg-canvas-btn') as HTMLButtonElement;
  const canvasSection = document.getElementById('cg-left') as HTMLElement;
  if (canvasBtn && canvasSection) {
    canvasBtn.addEventListener('click', () => {
      canvasBtn.style.display = 'none';
      canvasSection.scrollIntoView({ behavior: 'smooth' });
    });
  }

  // ── State ─────────────────────────────────────────────────────────────
  let pixels: (string|null)[] = new Array(GRID*GRID).fill(null);
  let basePixels: (string|null)[]|null = null;
  let currentColor = '#1a1a1a';
  let tool = 'pen';
  let brushSize = 1;
  let isDown = false;
  let startCol = -1, startRow = -1;
  // Selection
  let selRect: {x1:number,y1:number,x2:number,y2:number}|null = null;
  let selPixels: (string|null)[]|null = null;
  let selPhase: 'idle'|'selecting'|'selected'|'moving' = 'idle';
  let selAnchor: {col:number,row:number}|null = null;

  // ── Undo stack ────────────────────────────────────────────────────────
  const undoStack: (string|null)[][] = [];
  function pushUndo() {
    undoStack.push([...pixels]);
    if (undoStack.length > 50) undoStack.shift();
  }
  function undo() {
    if (!undoStack.length) return;
    pixels = undoStack.pop()!;
    selRect = null; selPixels = null; selPhase = 'idle';
    redraw();
  }

  // ── Helpers ───────────────────────────────────────────────────────────
  function getColRow(e: MouseEvent|TouchEvent):{col:number,row:number} {
    const rect = canvas.getBoundingClientRect();
    let cx:number, cy:number;
    if ('touches' in e && e.touches.length) { cx=e.touches[0].clientX; cy=e.touches[0].clientY; }
    else if ('changedTouches' in e && e.changedTouches.length) { cx=e.changedTouches[0].clientX; cy=e.changedTouches[0].clientY; }
    else { cx=(e as MouseEvent).clientX; cy=(e as MouseEvent).clientY; }
    return {
      col: Math.floor((cx-rect.left) * GRID / rect.width),
      row: Math.floor((cy-rect.top)  * GRID / rect.height),
    };
  }

  function clamp(v:number,lo:number,hi:number){ return Math.max(lo,Math.min(hi,v)); }

  // ── Drawing primitives ────────────────────────────────────────────────
  function paintBrush(col:number, row:number, color:string|null, target=pixels) {
    const half = Math.floor(brushSize/2);
    for (let dy=0;dy<brushSize;dy++) for (let dx=0;dx<brushSize;dx++) {
      const c=col+dx-half, r=row+dy-half;
      if (inBounds(c,r)) target[idx(c,r)]=color;
    }
  }

  // ── Redraw ────────────────────────────────────────────────────────────
  function redraw(){
    ctx.clearRect(0,0,256,256);
    ctx.fillStyle='#ffffff'; ctx.fillRect(0,0,256,256);
    pixels.forEach((color,i)=>{
      if(!color)return;
      ctx.fillStyle=color;
      ctx.fillRect((i%GRID)*CELL,Math.floor(i/GRID)*CELL,CELL,CELL);
    });
    if(selPhase!=='idle'&&selPixels){
      selPixels.forEach((color,i)=>{
        if(!color)return;
        ctx.fillStyle=color;
        ctx.fillRect((i%GRID)*CELL,Math.floor(i/GRID)*CELL,CELL,CELL);
      });
    }
    if(selRect&&selPhase!=='idle'){
      const x=Math.min(selRect.x1,selRect.x2)*CELL, y=Math.min(selRect.y1,selRect.y2)*CELL;
      const w=(Math.abs(selRect.x2-selRect.x1)+1)*CELL, h=(Math.abs(selRect.y2-selRect.y1)+1)*CELL;
      ctx.save();
      ctx.strokeStyle='rgba(0,0,0,0.8)'; ctx.lineWidth=1; ctx.setLineDash([3,2]);
      ctx.strokeRect(x+0.5,y+0.5,w-1,h-1);
      ctx.strokeStyle='rgba(255,255,255,0.6)'; ctx.setLineDash([3,2]); ctx.lineDashOffset=3;
      ctx.strokeRect(x+0.5,y+0.5,w-1,h-1);
      ctx.restore();
    }
    ctx.strokeStyle='rgba(180,180,180,0.45)'; ctx.lineWidth=0.5;
    for(let i=0;i<=GRID;i++){
      ctx.beginPath();ctx.moveTo(i*CELL,0);ctx.lineTo(i*CELL,256);ctx.stroke();
      ctx.beginPath();ctx.moveTo(0,i*CELL);ctx.lineTo(256,i*CELL);ctx.stroke();
    }
    updateCount();
  }

  // ── Selection helpers ─────────────────────────────────────────────────
  function normSel(){
    if(!selRect)return null;
    return {x1:Math.min(selRect.x1,selRect.x2),y1:Math.min(selRect.y1,selRect.y2),x2:Math.max(selRect.x1,selRect.x2),y2:Math.max(selRect.y1,selRect.y2)};
  }
  function inSel(col:number,row:number){
    const s=normSel(); if(!s)return false;
    return col>=s.x1&&col<=s.x2&&row>=s.y1&&row<=s.y2;
  }
  function liftSel(){
    const s=normSel(); if(!s)return;
    selPixels=new Array(GRID*GRID).fill(null);
    for(let r=s.y1;r<=s.y2;r++) for(let c=s.x1;c<=s.x2;c++){
      selPixels[idx(c,r)]=pixels[idx(c,r)];
      pixels[idx(c,r)]=null;
    }
  }
  function stampSel(){
    if(!selPixels)return;
    selPixels.forEach((color,i)=>{ if(color)pixels[i]=color; });
    selPixels=null;
  }
  function moveSel(dc:number,dr:number){
    if(!selRect||!selPixels)return;
    const newSel=new Array(GRID*GRID).fill(null);
    selPixels.forEach((color,i)=>{
      if(!color)return;
      const c=(i%GRID)+dc, r=Math.floor(i/GRID)+dr;
      if(inBounds(c,r))newSel[idx(c,r)]=color;
    });
    selPixels=newSel;
    selRect={x1:selRect.x1+dc,y1:selRect.y1+dr,x2:selRect.x2+dc,y2:selRect.y2+dr};
  }
  function deselect(){
    stampSel();
    selRect=null; selPhase='idle'; selAnchor=null;
    redraw();
  }

  // ── Pointer events ────────────────────────────────────────────────────
  canvas.addEventListener('mousedown',  e=>onDown(e));
  canvas.addEventListener('mousemove',  e=>onMove(e));
  canvas.addEventListener('mouseup',    e=>onUp(e));
  canvas.addEventListener('mouseleave', ()=>{ isDown=false; });
  canvas.addEventListener('touchstart', e=>{e.preventDefault();onDown(e);},{passive:false});
  canvas.addEventListener('touchmove',  e=>{e.preventDefault();onMove(e);},{passive:false});
  canvas.addEventListener('touchend',   e=>{e.preventDefault();onUp(e);},{passive:false});

  function onDown(e:MouseEvent|TouchEvent){
    isDown=true;
    const {col,row}=getColRow(e);
    const cc=clamp(col,0,GRID-1), cr=clamp(row,0,GRID-1);
    startCol=cc; startRow=cr;

    if(tool==='pen'||tool==='eraser'){
      pushUndo();
      const color=tool==='eraser'?null:currentColor;
      paintBrush(cc,cr,color); redraw();
    } else if(tool==='mirror'){
      pushUndo();
      paintBrush(cc,cr,currentColor);
      paintBrush(GRID-1-cc,cr,currentColor);
      redraw();
    } else if(tool==='fill'){
      pushUndo();
      floodFill(pixels,cc,cr,currentColor); redraw(); isDown=false;
    } else if(tool==='line'||tool==='rect'||tool==='circle'){
      pushUndo();
      basePixels=[...pixels];
    } else if(tool==='move'){
      pushUndo();
      basePixels=[...pixels];
    } else if(tool==='eyedropper'){
      const color = pixels[idx(cc, cr)];
      if (color) {
        currentColor = color;
        document.querySelectorAll('.swatch').forEach(s => {
          s.classList.toggle('swatch-active', (s as HTMLElement).getAttribute('aria-label') === color);
        });
      }
      tool = 'pen';
      document.querySelectorAll('.tool-btn').forEach(b => b.classList.remove('tool-active'));
      document.getElementById('tool-pen')?.classList.add('tool-active');
      canvas.style.cursor = 'crosshair';
      isDown = false;
      return;
    } else if(tool==='select'){
      if(selPhase==='selected'&&inSel(cc,cr)){
        pushUndo();
        selPhase='moving'; selAnchor={col:cc,row:cr};
      } else {
        if(selPhase==='selected') stampSel();
        selPhase='selecting';
        selRect={x1:cc,y1:cr,x2:cc,y2:cr};
        selPixels=null;
        redraw();
      }
    }
  }

  function onMove(e:MouseEvent|TouchEvent){
    if(!isDown)return;
    const {col,row}=getColRow(e);
    const cc=clamp(col,0,GRID-1), cr=clamp(row,0,GRID-1);

    if(tool==='pen'||tool==='eraser'){
      paintBrush(cc,cr,tool==='eraser'?null:currentColor); redraw();
    } else if(tool==='mirror'){
      paintBrush(cc,cr,currentColor); paintBrush(GRID-1-cc,cr,currentColor); redraw();
    } else if(tool==='line'&&basePixels){
      pixels=[...basePixels];
      bresenham(startCol,startRow,cc,cr).forEach(({col:c,row:r})=>paintBrush(c,r,currentColor));
      redraw();
    } else if(tool==='rect'&&basePixels){
      pixels=[...basePixels];
      rectOutline(startCol,startRow,cc,cr).forEach(({col:c,row:r})=>paintBrush(c,r,currentColor));
      redraw();
    } else if(tool==='circle'&&basePixels){
      pixels=[...basePixels];
      ellipseOutline(startCol,startRow,cc,cr).forEach(({col:c,row:r})=>paintBrush(c,r,currentColor));
      redraw();
    } else if(tool==='move'&&basePixels){
      const dc=cc-startCol, dr=cr-startRow;
      pixels=new Array(GRID*GRID).fill(null);
      basePixels.forEach((color,i)=>{
        if(!color)return;
        const c=(i%GRID)+dc, r=Math.floor(i/GRID)+dr;
        if(inBounds(c,r))pixels[idx(c,r)]=color;
      });
      redraw();
    } else if(tool==='select'){
      if(selPhase==='selecting'){
        selRect={x1:startCol,y1:startRow,x2:cc,y2:cr}; redraw();
      } else if(selPhase==='moving'&&selAnchor){
        moveSel(cc-selAnchor.col, cr-selAnchor.row);
        selAnchor={col:cc,row:cr}; redraw();
      }
    }
  }

  function onUp(e:MouseEvent|TouchEvent){
    if(!isDown)return;
    isDown=false;
    const {col,row}=getColRow(e);
    const cc=clamp(col,0,GRID-1), cr=clamp(row,0,GRID-1);

    if(tool==='move') basePixels=null;
    if(tool==='line'||tool==='rect'||tool==='circle') basePixels=null;
    if(tool==='select'){
      if(selPhase==='selecting'){
        if(selRect&&selRect.x1===cc&&selRect.y1===cr){
          selRect=null; selPhase='idle'; selPixels=null;
        } else {
          selPhase='selected'; liftSel();
        }
        redraw();
      } else if(selPhase==='moving'){
        selPhase='selected'; selAnchor=null;
      }
    }
    startCol=-1; startRow=-1;
  }

  // ── Keyboard shortcuts ────────────────────────────────────────────────
  document.addEventListener('keydown', e => {
    if ((e.ctrlKey || e.metaKey) && e.key === 'z') { e.preventDefault(); undo(); }
    if (e.key === 'Escape' && selPhase !== 'idle') deselect();
  });

  // ── Toolbar ───────────────────────────────────────────────────────────
  const toolbar = document.getElementById('toolbar')!;

  // Undo button first
  const undoBtn = document.createElement('button');
  undoBtn.type='button'; undoBtn.className='tool-btn'; undoBtn.id='tool-undo';
  undoBtn.title='Undo'; undoBtn.setAttribute('aria-label','Undo (Cmd/Ctrl+Z)');
  undoBtn.innerHTML=`<span class="material-symbols-outlined" aria-hidden="true">undo</span>`;
  undoBtn.addEventListener('click', undo);
  toolbar.appendChild(undoBtn);
  const div0=document.createElement('div'); div0.className='tool-divider'; toolbar.appendChild(div0);

  const TOOLS = [
    { id:'pen',        label:'Pen',                icon:'edit'             },
    { id:'mirror',     label:'Mirror pen',         icon:'flip'             },
    { id:'eraser',     label:'Eraser',             icon:'ink_eraser'       },
    { id:'fill',       label:'Fill',               icon:'format_color_fill'},
    { id:'eyedropper', label:'Eyedropper',         icon:'colorize'         },
    { id:'--' },
    { id:'line',       label:'Line',               icon:'timeline'         },
    { id:'rect',       label:'Rectangle',          icon:'crop_square'      },
    { id:'circle',     label:'Ellipse',            icon:'circle'           },
    { id:'--' },
    { id:'move',       label:'Move',               icon:'open_with'        },
    { id:'select',     label:'Select',             icon:'highlight_alt'    },
  ] as { id: string; label?: string; icon?: string }[];

  TOOLS.forEach(t => {
    if (t.id === '--') {
      const div=document.createElement('div'); div.className='tool-divider'; toolbar.appendChild(div); return;
    }
    const btn=document.createElement('button');
    btn.type='button'; btn.className='tool-btn'+(t.id==='pen'?' tool-active':'');
    btn.id=`tool-${t.id}`; btn.title=t.label!; btn.setAttribute('aria-label',t.label!);
    btn.innerHTML=`<span class="material-symbols-outlined" aria-hidden="true">${t.icon}</span>`;
    btn.addEventListener('click', () => {
      if (selPhase !== 'idle') deselect();
      tool = t.id;
      document.querySelectorAll('.tool-btn').forEach(b => b.classList.remove('tool-active'));
      btn.classList.add('tool-active');
      canvas.style.cursor = t.id==='fill'?'cell':t.id==='move'?'grab':t.id==='eyedropper'?'crosshair':'crosshair';
    });
    toolbar.appendChild(btn);
  });

  // ── Brush size ────────────────────────────────────────────────────────
  document.querySelectorAll('.size-btn').forEach(btn=>{
    btn.addEventListener('click',()=>{
      brushSize=parseInt((btn as HTMLElement).dataset.size!);
      document.querySelectorAll('.size-btn').forEach(b=>b.classList.remove('size-active'));
      btn.classList.add('size-active');
    });
  });

  // ── Palette ───────────────────────────────────────────────────────────
  const COLORS = [
    '#000000','#1a1a1a','#3d3d3d','#6e6e6e','#afafaf','#d4d4d4','#f0f0f0','#ffffff',
    '#3d2f1f','#6B5234','#9C8B6E','#C4B49A','#E8DCC8',
    '#7c2d12','#c2410c','#ea580c','#fb923c','#fde68a',
    '#14532d','#166534','#4ade80','#86efac',
    '#1e3a5f','#1d4ed8','#60a5fa','#a5b4fc',
    '#6b21a8','#a855f7','#e879f9','#fda4af',
  ];

  const paletteEl=document.getElementById('palette')!;
  COLORS.forEach(color=>{
    const sw=document.createElement('button');
    sw.type='button'; sw.className='swatch'+(color===currentColor?' swatch-active':'');
    sw.style.background=color; sw.setAttribute('aria-label',color);
    sw.addEventListener('click',()=>{
      currentColor=color; tool=tool==='eraser'?'pen':tool;
      document.querySelectorAll('.swatch').forEach(s=>s.classList.remove('swatch-active'));
      sw.classList.add('swatch-active');
      if(tool==='eraser'){
        tool='pen';
        document.querySelectorAll('.tool-btn').forEach(b=>b.classList.remove('tool-active'));
        document.getElementById('tool-pen')?.classList.add('tool-active');
      }
    });
    paletteEl.appendChild(sw);
  });

  // ── Custom color picker ──────────────────────────────────────────────
  const rainbowBtn  = document.getElementById('swatch-rainbow') as HTMLButtonElement;
  const popover     = document.getElementById('color-popover') as HTMLElement;
  const colorWheel  = document.getElementById('color-wheel')   as HTMLInputElement;
  const hexInput    = document.getElementById('hex-input')     as HTMLInputElement;

  function applyCustomColor(hex: string) {
    currentColor = hex;
    colorWheel.value = hex;
    hexInput.value = hex.replace('#', '');
    rainbowBtn.style.setProperty('--custom-bg', hex);
    rainbowBtn.classList.add('swatch-active');
    document.querySelectorAll('.swatch:not(.swatch-rainbow)').forEach(s => s.classList.remove('swatch-active'));
    if (tool === 'eraser') {
      tool = 'pen';
      document.querySelectorAll('.tool-btn').forEach(b => b.classList.remove('tool-active'));
      document.getElementById('tool-pen')?.classList.add('tool-active');
    }
  }

  rainbowBtn.addEventListener('click', (e) => {
    e.stopPropagation();
    popover.hidden = !popover.hidden;
    if (!popover.hidden) hexInput.focus();
  });

  // Clicks inside popover don't bubble to document
  popover.addEventListener('click', (e) => e.stopPropagation());

  colorWheel.addEventListener('input', () => applyCustomColor(colorWheel.value));

  hexInput.addEventListener('input', () => {
    const val = hexInput.value.replace(/[^0-9a-fA-F]/g, '');
    hexInput.value = val;
    if (val.length === 6) applyCustomColor('#' + val);
  });

  hexInput.addEventListener('keydown', (e) => {
    if (e.key === 'Enter') { popover.hidden = true; }
  });

  // Close popover when clicking outside
  document.addEventListener('click', () => {
    if (!popover.hidden) popover.hidden = true;
  });

  // ── Clear button (double-click canvas) ───────────────────────────────
  canvas.addEventListener('dblclick', ()=>{
    if(confirm('Clear the canvas?')){pixels.fill(null);selRect=null;selPixels=null;selPhase='idle';redraw();}
  });

  // ── Pixel count + submit ──────────────────────────────────────────────
  const countEl=document.getElementById('pixel-count')!;
  const plantBtn=document.getElementById('plant-btn') as HTMLButtonElement;
  function updateCount(){
    const n=pixels.filter(Boolean).length+(selPixels?.filter(Boolean).length??0);
    countEl.textContent=n<4?(n===0?'draw at least 4 pixels to plant':`${n} pixel${n===1?'':'s'} — a bit more!`):`${n} pixels ✓`;
    plantBtn.disabled=n<4;
  }

  // ── Submit ────────────────────────────────────────────────────────────
  const form=document.getElementById('plant-form') as HTMLFormElement;
  const confirm2=document.getElementById('plant-confirm')!;
  const errorEl=document.getElementById('plant-error')!;

  form.addEventListener('submit',async e=>{
    e.preventDefault();
    if((form.querySelector('[name="hp"]') as HTMLInputElement).value)return;
    if(selPhase!=='idle') stampSel();
    const name=(form.querySelector('#plant-name') as HTMLInputElement).value;
    const note=(form.querySelector('#plant-note') as HTMLTextAreaElement).value;
    plantBtn.disabled=true; plantBtn.textContent='planting…'; errorEl.setAttribute('hidden','');
    try {
      const hp=(form.querySelector('[name="hp"]') as HTMLInputElement).value;
      const res=await fetch('/api/plant',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({pixels,name,note,hp})});
      const data=await res.json();
      if(!res.ok)throw new Error(data.error||'Something went wrong');
      // Mark as planted — unlocks the full garden
      localStorage.setItem('cg-planted', 'true');
      unlockGarden();
      form.style.opacity='0'; form.style.transition='opacity 0.2s';
      setTimeout(()=>{form.style.display='none';confirm2.removeAttribute('hidden');},200);
      // Flash success modal
      const modal = document.getElementById('cg-modal')!;
      modal.removeAttribute('hidden');
      modal.classList.remove('modal-out');
      setTimeout(() => {
        modal.classList.add('modal-out');
        setTimeout(() => modal.setAttribute('hidden', ''), 260);
      }, 2800);
    } catch(err:any){
      errorEl.textContent=err.message; errorEl.removeAttribute('hidden');
      plantBtn.disabled=false; plantBtn.textContent='plant';
    }
  });

  // ── Render existing plantings ─────────────────────────────────────────
  document.querySelectorAll('.planting-canvas').forEach(el=>{
    const c=el as HTMLCanvasElement;
    const data=JSON.parse(c.dataset.pixels??'[]') as (string|null)[];
    const pc=c.getContext('2d')!;
    const cell=c.width/GRID;
    pc.fillStyle='#ffffff'; pc.fillRect(0,0,c.width,c.height);
    data.forEach((color,i)=>{
      if(!color)return;
      pc.fillStyle=color;
      pc.fillRect((i%GRID)*cell,Math.floor(i/GRID)*cell,cell,cell);
    });
  });

  // ── Save as PNG ──────────────────────────────────────────────────────
  document.getElementById('save-btn')?.addEventListener('click', () => {
    // Render to a clean 512×512 canvas (no grid lines)
    const out = document.createElement('canvas');
    out.width = 512; out.height = 512;
    const octx = out.getContext('2d')!;
    octx.fillStyle = '#ffffff';
    octx.fillRect(0, 0, 512, 512);
    const cell = 512 / GRID;
    pixels.forEach((color, i) => {
      if (!color) return;
      octx.fillStyle = color;
      octx.fillRect((i % GRID) * cell, Math.floor(i / GRID) * cell, cell, cell);
    });
    const a = document.createElement('a');
    a.href = out.toDataURL('image/png');
    a.download = 'pixel-art.png';
    a.click();
  });

  // ── Zoom toggle ───────────────────────────────────────────────────────
  let zoomed = false;
  document.getElementById('zoom-btn')?.addEventListener('click', () => {
    zoomed = !zoomed;
    document.getElementById('canvas-zoom-wrap')?.classList.toggle('canvas-zoomed', zoomed);
    const btn = document.getElementById('zoom-btn');
    btn?.classList.toggle('zoom-active', zoomed);
    const icon = btn?.querySelector('.material-symbols-outlined');
    if (icon) icon.textContent = zoomed ? 'zoom_out' : 'zoom_in';
  });

  // ── Init ─────────────────────────────────────────────────────────────
  redraw();

  // ── Garden unlock ─────────────────────────────────────────────────────
  function unlockGarden() {
    const locked = document.getElementById('cg-locked');
    if (locked) locked.classList.add('unlocked');
  }

  if (localStorage.getItem('cg-planted') === 'true') unlockGarden();

  // Scroll-to-canvas from lock overlay
  document.getElementById('cg-lock-scroll')?.addEventListener('click', () => {
    document.getElementById('pixel-canvas')?.scrollIntoView({ behavior: 'smooth', block: 'center' });
  });

  // ── Hearts ────────────────────────────────────────────────────────────
  function getHearted(): number[] {
    try { return JSON.parse(localStorage.getItem('cg-hearted') || '[]'); } catch { return []; }
  }
  function addHearted(n: number) {
    const h = getHearted();
    if (!h.includes(n)) { h.push(n); localStorage.setItem('cg-hearted', JSON.stringify(h)); }
  }
  function removeHearted(n: number) {
    localStorage.setItem('cg-hearted', JSON.stringify(getHearted().filter(x => x !== n)));
  }

  // Fetch real counts from Redis on load
  const allIssueNums = Array.from(document.querySelectorAll<HTMLElement>('.heart-count[data-issue]'))
    .map(el => el.dataset.issue).filter(Boolean).join(',');
  if (allIssueNums) {
    fetch(`/api/hearts?issues=${allIssueNums}`)
      .then(r => r.json())
      .then((counts: Record<string, number>) => {
        Object.entries(counts).forEach(([issue, count]) => {
          const el = document.querySelector<HTMLElement>(`.heart-count[data-issue="${issue}"]`);
          if (el) { const num = el.querySelector('.heart-count-num'); if (num) num.textContent = count > 0 ? String(count) : ''; }
        });
      })
      .catch(() => {});
  }

  // Mark already-hearted overlays on load
  const heartedNums = getHearted();
  document.querySelectorAll<HTMLButtonElement>('.heart-overlay').forEach(btn => {
    const issue = parseInt(btn.dataset.issue || '0');
    if (heartedNums.includes(issue)) {
      btn.classList.add('heart-active');
      const countEl = document.querySelector<HTMLElement>(`.heart-count[data-issue="${issue}"]`);
      if (countEl) countEl.classList.add('heart-count--active');
    }
    btn.addEventListener('click', () => {
      const isActive = btn.classList.contains('heart-active');
      const countEl = document.querySelector<HTMLElement>(`.heart-count[data-issue="${issue}"]`);

      if (isActive) {
        // Unlike — optimistic
        btn.classList.remove('heart-active');
        removeHearted(issue);
        if (countEl) {
          const numEl = countEl.querySelector('.heart-count-num');
          const current = parseInt(numEl?.textContent || '0') || 0;
          if (numEl) numEl.textContent = current > 1 ? String(current - 1) : '';
          countEl.classList.remove('heart-count--active');
        }
        fetch('/api/heart', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ issueNumber: issue, action: 'unlike' }),
        }).catch(() => {});
      } else {
        // Like — optimistic
        btn.classList.add('heart-active', 'heart-popping');
        setTimeout(() => btn.classList.remove('heart-popping'), 450);
        if (countEl) {
          const numEl = countEl.querySelector('.heart-count-num');
          const current = parseInt(numEl?.textContent || '0') || 0;
          if (numEl) numEl.textContent = String(current + 1);
          countEl.classList.add('heart-count--active', 'animating');
          setTimeout(() => countEl.classList.remove('animating'), 200);
        }
        addHearted(issue);
        fetch('/api/heart', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ issueNumber: issue, action: 'like' }),
        }).catch(() => {});
      }
    });
  });

  // ── Resizable divider ────────────────────────────────────────────────
  const resizer   = document.getElementById('cg-resizer') as HTMLElement | null;
  const leftPanel = document.getElementById('cg-left')    as HTMLElement | null;
  const layout    = document.getElementById('cg-layout')  as HTMLElement | null;

  if (resizer && leftPanel && layout) {
    let dragging = false;
    let startX   = 0;
    let startW   = 0;

    resizer.addEventListener('mousedown', (e: MouseEvent) => {
      dragging = true;
      startX   = e.clientX;
      startW   = leftPanel.getBoundingClientRect().width;
      resizer.classList.add('dragging');
      document.body.style.cursor     = 'col-resize';
      document.body.style.userSelect = 'none';
    });

    document.addEventListener('mousemove', (e: MouseEvent) => {
      if (!dragging) return;
      const delta = e.clientX - startX;
      const minW  = 260;
      const maxW  = layout.getBoundingClientRect().width * 0.6;
      leftPanel.style.width = Math.min(maxW, Math.max(minW, startW + delta)) + 'px';
    });

    document.addEventListener('mouseup', () => {
      if (!dragging) return;
      dragging = false;
      resizer.classList.remove('dragging');
      document.body.style.cursor     = '';
      document.body.style.userSelect = '';
    });

    resizer.addEventListener('keydown', (e: KeyboardEvent) => {
      const current = leftPanel.getBoundingClientRect().width;
      const step    = e.shiftKey ? 40 : 10;
      if (e.key === 'ArrowRight') leftPanel.style.width = (current + step) + 'px';
      if (e.key === 'ArrowLeft')  leftPanel.style.width = Math.max(260, current - step) + 'px';
    });
  }
})();
</script>
