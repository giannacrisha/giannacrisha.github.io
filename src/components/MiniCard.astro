---
import type { GrowthStage } from '../config/design';

interface Props {
  title:       string;
  slug:        string;
  collection:  'lab' | 'archives' | 'gallery' | 'library';
  type?:       string;
  stage?:      GrowthStage;
  date:        Date;
  body?:       string;
  description?: string;
  creator?:    string;
  cover_image?: string;
}

const { title, slug, collection, type, date, body, description, creator, cover_image } = Astro.props;

function oneliner(raw: string, max = 80): string {
  return raw
    .replace(/^---[\s\S]*?---/, '')
    .replace(/#{1,6}\s+/g, '')
    .replace(/\*\*(.+?)\*\*/g, '$1')
    .replace(/\*(.+?)\*/g, '$1')
    .replace(/`{1,3}[^`]*`{1,3}/g, '')
    .replace(/\[(.+?)\]\(.+?\)/g, '$1')
    .replace(/^\s*[-*>]\s+/gm, '')
    .replace(/\n+/g, ' ')
    .trim()
    .slice(0, max)
    .trimEnd() + (raw.trim().length > max ? '…' : '');
}

const preview = body ? oneliner(body) : description ? oneliner(description) : creator ?? null;
const href = `/${collection}/${slug}`;
const fmt = (d: Date) => d.toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' });
const isGallery = collection === 'gallery';
---

<a href={href} class="mini-card">
  {isGallery && cover_image && (
    <div class="mini-card-thumb" style={`background-image: url(${cover_image})`} aria-hidden="true"></div>
  )}
  <div class="mini-card-body">
    <div class="mini-card-top">
      {type && <span class="mini-card-type">{type}</span>}
      <span class="mini-card-date">{fmt(date)}</span>
    </div>
    <p class="mini-card-title">{title}</p>
    {preview && <p class="mini-card-preview">{preview}</p>}
  </div>
</a>

<style>
  .mini-card {
    display: flex;
    flex-direction: row;
    align-items: stretch;
    background: var(--color-card);
    border: 0.5px solid var(--color-border);
    border-radius: var(--radius-card);
    overflow: hidden;
    text-decoration: none;
    color: inherit;
    transition: border-color 0.15s;
    min-height: 80px;
  }
  .mini-card:hover { border-color: var(--color-accent); }

  .mini-card-thumb {
    width: 72px;
    flex-shrink: 0;
    background-size: cover;
    background-position: center;
  }

  .mini-card-body {
    padding: var(--space-md) var(--space-lg);
    display: flex;
    flex-direction: column;
    gap: var(--space-xs);
    flex: 1;
    min-width: 0;
  }

  .mini-card-top {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-sm);
  }

  .mini-card-type {
    font-family: var(--font-body);
    font-size: 10px;
    color: var(--color-accent);
    letter-spacing: 0.07em;
    text-transform: lowercase;
  }

  .mini-card-date {
    font-family: var(--font-body);
    font-size: 10px;
    color: var(--color-muted);
    letter-spacing: 0.03em;
    white-space: nowrap;
  }

  .mini-card-title {
    font-family: var(--font-serif);
    font-size: var(--text-sm);
    color: var(--color-fg);
    line-height: var(--leading-tight);
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .mini-card-preview {
    font-family: var(--font-body);
    font-size: 11px;
    color: var(--color-muted);
    line-height: 1.5;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }
</style>
