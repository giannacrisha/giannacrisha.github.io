---
import LiquidGlass from './LiquidGlass.astro';
---

<div class="iw-outer" id="iw-outer">
  <div class="iw-cover" id="iw-cover" aria-hidden="false">
    <canvas class="iw-cover-stars" aria-hidden="true"></canvas>
    <div class="iw-cover-glow" id="iw-cover-glow" aria-hidden="true"></div>
    <div class="iw-cover-inner">
      <h2 class="iw-cover-title">who am i?</h2>
      <p class="iw-cover-text">
        intersectionality is one of my favorite topics in anthropology, and i developed this star map to visualize that.
      </p>
      <div class="iw-cover-actions">
        <button type="button" class="iw-cover-action iw-cover-action--enter" id="iw-cover-enter">
          <span class="iw-cover-action-label">enter my star map</span>
        </button>
        <button type="button" class="iw-cover-action iw-cover-action--soon" id="iw-cover-create" aria-disabled="true">
          <span class="iw-cover-action-label">create your own</span>
          <span class="iw-cover-soon">coming soon</span>
        </button>
      </div>
    </div>
  </div>
  <div class="iw-container" id="iw-container"></div>
  <div class="iw-legend">
    <span class="iw-leg-label">most salient</span>
    <span class="iw-leg iw-leg--O"></span>
    <span class="iw-leg iw-leg--B"></span>
    <span class="iw-leg iw-leg--A"></span>
    <span class="iw-leg iw-leg--F"></span>
    <span class="iw-leg iw-leg--G"></span>
    <span class="iw-leg iw-leg--K"></span>
    <span class="iw-leg iw-leg--M"></span>
    <span class="iw-leg-label">least</span>
  </div>
  <button class="iw-recenter" id="iw-recenter" aria-label="recenter view">
    <svg width="16" height="16" viewBox="0 0 16 16" fill="none" xmlns="http://www.w3.org/2000/svg">
      <circle cx="8" cy="8" r="2.5" fill="currentColor"/>
      <path d="M8 1v2.5M8 12.5V15M1 8h2.5M12.5 8H15" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
    </svg>
    recenter
  </button>
  <button class="iw-reset" id="iw-reset" aria-label="reset node positions">
    <svg width="16" height="16" viewBox="0 0 16 16" fill="none" xmlns="http://www.w3.org/2000/svg">
      <path d="M2.5 8a5.5 5.5 0 1 0 1.2-3.4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
      <polyline points="2.5,2.5 2.5,5.5 5.5,5.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
    </svg>
    reset nodes
  </button>
  <p class="iw-hint">drag to orbit · drag nodes to reposition</p>
  <button type="button" class="iw-menu" id="iw-menu" aria-label="back to menu">
    <div class="iw-menu-glass" aria-hidden="true"></div>
    <div class="iw-menu-panel">
      <LiquidGlass displacement={100} aberration={3} cornerRadius={24} filterId="iw-menu" backdrop={false}>
        <span class="iw-glass-inner">
          <span class="iw-menu-label">menu</span>
        </span>
      </LiquidGlass>
    </div>
  </button>
</div>

<style>
  .iw-outer {
    position: relative;
    width: 100%;
    height: 100%;
    min-height: 0;
    border-radius: 0;
    border: none;
    overflow: hidden;
    background: radial-gradient(ellipse at 50% 45%, #201612 0%, #100908 70%);
  }

  .iw-cover {
    position: absolute;
    inset: 0;
    z-index: 20;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: clamp(24px, 5vw, 64px);
    background: radial-gradient(ellipse at 50% 45%, #201612 0%, #100908 70%);
    transition: opacity 0.45s ease, visibility 0.45s ease;
    cursor: none;
  }
  .iw-cover.is-hidden {
    opacity: 0;
    visibility: hidden;
    pointer-events: none;
  }
  .iw-cover-stars {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    display: block;
    pointer-events: none;
    z-index: 0;
  }
  .iw-cover-glow {
    position: fixed;
    top: 0;
    left: 0;
    width: 44px;
    height: 44px;
    pointer-events: none;
    z-index: 2;
    opacity: 0;
    border-radius: 50%;
    background: radial-gradient(
      circle,
      rgba(255, 250, 240, 0.95) 0%,
      rgba(255, 230, 200, 0.42) 38%,
      transparent 72%
    );
    box-shadow: 0 0 32px rgba(255, 228, 190, 0.5);
    mix-blend-mode: screen;
    will-change: transform, opacity;
    transform: translate3d(-1000px, -1000px, 0) translate(-50%, -50%);
  }
  .iw-cover-action,
  .iw-cover-action * {
    cursor: pointer;
  }
  .iw-cover-action--soon,
  .iw-cover-action--soon * {
    cursor: not-allowed;
  }
  .iw-cover-inner {
    position: relative;
    z-index: 1;
    display: flex;
    flex-direction: column;
    gap: var(--space-lg);
    max-width: 42ch;
    text-align: left;
  }
  .iw-cover-title {
    margin: 0;
    font-family: var(--font-serif);
    font-weight: 600;
    font-size: clamp(2rem, 5vw, var(--text-xxl));
    color: #f4f4f5;
    line-height: var(--leading-tight);
    text-shadow: 0 1px 8px rgba(0, 0, 0, 0.65);
  }
  .iw-cover-text {
    margin: 0;
    font-family: var(--font-body);
    font-size: var(--text-md);
    line-height: var(--leading-loose);
    color: rgba(244, 244, 245, 0.78);
    text-wrap: pretty;
  }
  .iw-cover-actions {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: var(--space-sm);
    margin-top: var(--space-xs);
  }
  .iw-cover-action {
    display: inline-flex;
    align-items: center;
    gap: 0.5em;
    padding: 10px 16px;
    border: 1px solid rgba(255, 255, 255, 0.22);
    border-radius: var(--radius-pill);
    background: rgba(255, 255, 255, 0.08);
    cursor: pointer;
    text-align: left;
    transition: color 0.15s ease, background 0.15s ease, border-color 0.15s ease;
  }
  .iw-cover-action-label {
    font-family: var(--font-body);
    font-size: var(--text-sm);
    letter-spacing: 0.02em;
    color: #f4f4f5;
    text-shadow: 0 1px 6px rgba(0, 0, 0, 0.55), 0 0 2px rgba(0, 0, 0, 0.3);
    white-space: nowrap;
    transition: color 0.15s ease;
  }
  .iw-cover-action--enter {
    background: rgba(232, 212, 184, 0.14);
    border-color: rgba(232, 212, 184, 0.38);
  }
  .iw-cover-action--enter .iw-cover-action-label {
    color: #e8d4b8;
  }
  .iw-cover-action--enter:hover,
  .iw-cover-action--enter:focus-visible {
    background: rgba(232, 212, 184, 0.22);
    border-color: rgba(232, 212, 184, 0.55);
    outline: none;
  }
  .iw-cover-action--enter:hover .iw-cover-action-label,
  .iw-cover-action--enter:focus-visible .iw-cover-action-label {
    color: #fff;
  }
  .iw-cover-action--soon {
    cursor: not-allowed;
    background: rgba(255, 255, 255, 0.04);
    border-color: rgba(255, 255, 255, 0.12);
  }
  .iw-cover-action--soon .iw-cover-action-label {
    color: rgba(244, 244, 245, 0.55);
  }
  .iw-cover-soon {
    font-size: var(--text-xs);
    letter-spacing: 0.04em;
    text-transform: lowercase;
    color: rgba(244, 244, 245, 0.42);
    padding: 2px 8px;
    border-radius: var(--radius-pill);
    background: rgba(255, 255, 255, 0.08);
    text-shadow: none;
  }

  .iw-outer:not(.is-open) .iw-container,
  .iw-outer:not(.is-open) .iw-legend,
  .iw-outer:not(.is-open) .iw-reset,
  .iw-outer:not(.is-open) .iw-recenter,
  .iw-outer:not(.is-open) .iw-hint,
  .iw-outer:not(.is-open) .iw-menu {
    visibility: hidden;
    pointer-events: none;
  }

  .iw-menu {
    position: absolute;
    top: clamp(20px, 4vw, 40px);
    right: clamp(20px, 4vw, 48px);
    z-index: 21;
    display: inline-flex;
    padding: 0;
    border: none;
    background: none;
    cursor: pointer;
  }
  .iw-menu-glass {
    position: absolute;
    top: 0;
    left: 0;
    pointer-events: none;
    z-index: 0;
    border-radius: 24px;
    overflow: hidden;
    clip-path: inset(0 round 24px);
    background: rgba(255, 255, 255, 0.10);
    backdrop-filter: blur(2px) saturate(200%);
    -webkit-backdrop-filter: blur(2px) saturate(200%);
    box-shadow:
