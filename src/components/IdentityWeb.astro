// ── star point texture ────────────────────────────────────────────────────
function makeStarTexture() {
  const S = 32, c = document.createElement('canvas');
  c.width = c.height = S;
  const ctx = c.getContext('2d');
  const g = ctx.createRadialGradient(S/2, S/2, 0, S/2, S/2, S/2);
  g.addColorStop(0.0, 'rgba(255,252,245,1.0)');
  g.addColorStop(0.3, 'rgba(255,228,196,0.72)');
  g.addColorStop(1.0, 'rgba(0,0,0,0)');
  ctx.fillStyle = g;
  ctx.fillRect(0, 0, S, S);
  return new THREE.CanvasTexture(c);
}

// ── star glow + text (two sprites) ───────────────────────────────────────
function makeGlowSprite(node) {
  const isHub = node.hub === true;
  const s     = isHub
    ? { inner: '#FFFFFF', corona: '#DDEEFF', outer: '#99BBEE', halo: '#4466AA' }
    : SPECTRAL[node.spectral ?? 4];
  const isSub = node.group === 'interests-sub';
  const SCALE = 2;
  const CH    = isHub ? 420 : (isSub ? 260 : 320);
  const halo  = 90;
  const fontSize = isHub ? 26 : (isSub ? 19 : 22);
  const fontStr  = `700 ${fontSize}px 'Atkinson Hyperlegible Next', system-ui, sans-serif`;
  const worldH   = isHub ? 2.6 : (isSub ? 1.5 : 1.9);

  const probe = document.createElement('canvas').getContext('2d');
  probe.font  = fontStr;
  const textW = probe.measureText(node.label).width;
  const CW    = Math.max(CH, Math.ceil(textW + halo * 2));
  const worldW = worldH * (CW / CH);

  // ── glow orb (additive blend) ─────────────────────────────────────────
  const gc = document.createElement('canvas');
  gc.width = CW * SCALE; gc.height = CH * SCALE;
  const gctx = gc.getContext('2d');
  gctx.scale(SCALE, SCALE);
  const cx = CW / 2, cy = CH / 2, asp = CW / CH;
  gctx.save();
  gctx.scale(asp, 1);
  const grad = gctx.createRadialGradient(cx/asp, cy, 0, cx/asp, cy, CH * 0.48);
  grad.addColorStop(0.00, '#ffffff');
  grad.addColorStop(0.10, '#ffffff');
  grad.addColorStop(0.22, s.inner + 'EE');
  grad.addColorStop(0.40, s.corona + 'AA');
  grad.addColorStop(0.62, s.outer + '55');
  grad.addColorStop(0.82, s.halo + '18');
  grad.addColorStop(1.00, 'rgba(0,0,0,0)');
  gctx.fillStyle = grad;
  gctx.fillRect(0, 0, CW/asp, CH);
  gctx.restore();
  const glowSprite = new THREE.Sprite(new THREE.SpriteMaterial({
    map: new THREE.CanvasTexture(gc), transparent: true, depthWrite: false,
    blending: THREE.AdditiveBlending,
  }));
  glowSprite.scale.set(worldW, worldH, 1);
  glowSprite.renderOrder = 1;

  // ── text label (normal blend, dark text readable on bright core) ───────
  const padX = 44;
  const tCW  = Math.ceil(textW + padX * 2), tCH = 90;
  const tc   = document.createElement('canvas');
  tc.width = tCW * SCALE; tc.height = tCH * SCALE;
  const tctx = tc.getContext('2d');
  tctx.scale(SCALE, SCALE);
  tctx.font = fontStr;
  tctx.textAlign = 'center'; tctx.textBaseline = 'middle';
  tctx.fillStyle = '#000000';
  tctx.fillText(node.label, tCW / 2, tCH / 2);
  const tWorldH = worldH * (tCH / CH);
  const tWorldW = tWorldH * (tCW / tCH);
  const textSprite = new THREE.Sprite(new THREE.SpriteMaterial({
    map: new THREE.CanvasTexture(tc), transparent: true, depthWrite: false, depthTest: false,
  }));
  textSprite.scale.set(tWorldW, tWorldH, 1);
  textSprite.renderOrder = 2;

  return { glowSprite, textSprite };
}

// ── main init ─────────────────────────────────────────────────────────────
function init() {
  const container = document.getElementById('iw-container');
  if (!container) return;

  const W = container.clientWidth;
  const H = container.clientHeight;

  // renderer — transparent so CSS background shows through
  const renderer = new THREE.WebGLRenderer({ antialias: true, alpha: true });
  renderer.setSize(W, H);
  renderer.setPixelRatio(Math.min(window.devicePixelRatio, 2));
  renderer.toneMapping = THREE.ACESFilmicToneMapping;
  renderer.toneMappingExposure = 1.1;
  container.appendChild(renderer.domElement);

  // scene & camera
  const scene  = new THREE.Scene();
  scene.fog    = new THREE.FogExp2(0x100908, 0.030);

  const camera = new THREE.PerspectiveCamera(52, W / H, 0.1, 60);
  camera.position.set(0, 0, 14);

  // controls
  const controls = new OrbitControls(camera, renderer.domElement);
  controls.enableDamping  = true;
  controls.dampingFactor  = 0.06;
  controls.minDistance    = 5;
  controls.maxDistance    = 22;
  controls.enablePan      = false;
  controls.enableZoom     = false;
  controls.autoRotate     = true;
  controls.autoRotateSpeed = 0.35;

  // stop autorotate on user interaction, resume after 3s
  let autoRotateTimer: ReturnType<typeof setTimeout> | null = null;
  renderer.domElement.addEventListener('pointerdown', () => {
    controls.autoRotate = false;
    clearTimeout(autoRotateTimer);
  });
  renderer.domElement.addEventListener('pointerup', () => {
    autoRotateTimer = setTimeout(() => { controls.autoRotate = true; }, 3000);
  });

  // ── starfield ─────────────────────────────────────────────────────────────
  const starTex    = makeStarTexture();
  const starGroups: { mat: THREE.PointsMaterial; phase: number; speed: number }[] = [];
  const SR         = 48;

  // static background stars
  (() => {
    const N = 2800, pos = new Float32Array(N * 3);
    for (let i = 0; i < N; i++) {
      const th = Math.random() * Math.PI * 2;
      const ph = Math.acos(2 * Math.random() - 1);
      const r  = SR * (0.45 + Math.random() * 0.55);
      pos[i*3]   = r * Math.sin(ph) * Math.cos(th);
      pos[i*3+1] = r * Math.sin(ph) * Math.sin(th);
      pos[i*3+2] = r * Math.cos(ph);
    }
    const geo = new THREE.BufferGeometry();
    geo.setAttribute('position', new THREE.BufferAttribute(pos, 3));
    scene.add(new THREE.Points(geo, new THREE.PointsMaterial({
      map: starTex, size: 0.09, transparent: true, opacity: 0.34,
      sizeAttenuation: true, fog: false, depthWrite: false,
      blending: THREE.AdditiveBlending,
    })));
  })();

  // mid-layer dim stars
  (() => {
    const N = 1200, pos = new Float32Array(N * 3);
    for (let i = 0; i < N; i++) {
      const th = Math.random() * Math.PI * 2;
      const ph = Math.acos(2 * Math.random() - 1);
      const r  = SR * (0.60 + Math.random() * 0.40);
      pos[i*3]   = r * Math.sin(ph) * Math.cos(th);
      pos[i*3+1] = r * Math.sin(ph) * Math.sin(th);
      pos[i*3+2] = r * Math.cos(ph);
    }
    const geo = new THREE.BufferGeometry();
    geo.setAttribute('position', new THREE.BufferAttribute(pos, 3));
    scene.add(new THREE.Points(geo, new THREE.PointsMaterial({
      map: starTex, size: 0.12, transparent: true, opacity: 0.22,
      sizeAttenuation: true, fog: false, depthWrite: false,
      blending: THREE.AdditiveBlending,
    })));
  })();

  // twinkling stars — independent phase groups
  for (let g = 0; g < 14; g++) {
    const N = 55, pos = new Float32Array(N * 3);
    for (let i = 0; i < N; i++) {
      const th = Math.random() * Math.PI * 2;
      const ph = Math.acos(2 * Math.random() - 1);
      const r  = SR * (0.50 + Math.random() * 0.50);
      pos[i*3]   = r * Math.sin(ph) * Math.cos(th);
      pos[i*3+1] = r * Math.sin(ph) * Math.sin(th);
      pos[i*3+2] = r * Math.cos(ph);
    }
    const geo = new THREE.BufferGeometry();
    geo.setAttribute('position', new THREE.BufferAttribute(pos, 3));
    const mat = new THREE.PointsMaterial({
      map: starTex, size: 0.16, transparent: true, opacity: 0.7,
      sizeAttenuation: true, fog: false, depthWrite: false,
      blending: THREE.AdditiveBlending,
    });
    scene.add(new THREE.Points(geo, mat));
    starGroups.push({ mat, phase: (g / 14) * Math.PI * 2, speed: 0.5 + Math.random() * 1.5 });
  }

  // ── nodes as glow orb sprites ─────────────────────────────────────────────
  const spriteMap = {};
  const sprites: THREE.Sprite[] = [];

  NODES.forEach(node => {
    node.originPos  = new THREE.Vector3(node.x, node.y, node.z);
    node.basePos    = new THREE.Vector3(node.x, node.y, node.z);
    node.floatPhase = new THREE.Vector3(
      Math.random() * Math.PI * 2,
      Math.random() * Math.PI * 2,
      Math.random() * Math.PI * 2,
    );
    node.floatSpeed = 0.28 + Math.random() * 0.24;
    node.floatAmp   = node.fixed ? 0 : (0.08 + Math.random() * 0.10);

    if (node.id === 'center') {
      spriteMap['center'] = { position: new THREE.Vector3(0, 0, 0), userData: { node } };
      return;
    }

    const { glowSprite, textSprite } = makeGlowSprite(node);

    glowSprite.position.copy(node.basePos);
    textSprite.position.copy(node.basePos);
    glowSprite.userData.node = node;
    textSprite.userData.node = node;
    node._textSprite = textSprite;
    scene.add(glowSprite);
    scene.add(textSprite);
    spriteMap[node.id] = glowSprite;
    sprites.push(glowSprite);
  });

  // ── edges ─────────────────────────────────────────────────────────────────
  const edgeData = [];

  EDGES.forEach(edge => {
    const { hex, opacity } = EDGE_COLORS[edge.type] || EDGE_COLORS.identity;
    const mat = new THREE.LineBasicMaterial({ color: hex, transparent: true, opacity, fog: true });
    const geo = new THREE.BufferGeometry().setFromPoints([
      spriteMap[edge.from].position.clone(),
      spriteMap[edge.to].position.clone(),
    ]);
    const line = new THREE.Line(geo, mat);
    line.renderOrder = -1;
    scene.add(line);
    edgeData.push({ line, fromId: edge.from, toId: edge.to });
  });

  function updateEdges() {
    edgeData.forEach(({ line, fromId, toId }) => {
      const from = spriteMap[fromId].position;
      const to   = spriteMap[toId].position;
      const pos  = line.geometry.attributes.position;
      pos.setXYZ(0, from.x, from.y, from.z);
      pos.setXYZ(1, to.x, to.y, to.z);
      pos.needsUpdate = true;
    });
  }


  // ── heart GLB at center ───────────────────────────────────────────────────
  const heartMeshes = [];
  const heartPivot  = new THREE.Group();
  scene.add(heartPivot);

  // warm key light so the gold reads as metal
  const keyLight = new THREE.DirectionalLight(0xfff4d6, 2.2);
  keyLight.position.set(2, 3, 4);
  scene.add(keyLight);

  // IBL environment for reflections
  const pmrem      = new THREE.PMREMGenerator(renderer);
  scene.environment = pmrem.fromScene(new RoomEnvironment(), 0.04).texture;
  pmrem.dispose();

  const goldColor = () => {
    const css = getComputedStyle(document.documentElement).getPropertyValue('--color-heading').trim();
    return new THREE.Color(css || '#90642f');
  };
  const gold = new THREE.MeshStandardMaterial({
    color: goldColor(), metalness: 1.0, roughness: 0.26, envMapIntensity: 1.25, fog: false,
  });
  new MutationObserver(() => gold.color.set(goldColor())).observe(
    document.documentElement, { attributes: true, attributeFilter: ['data-theme'] },
  );

  const centerNode = NODES.find(n => n.id === 'center');
  const gltfLoader = new GLTFLoader();
  gltfLoader.setMeshoptDecoder(MeshoptDecoder);
  gltfLoader.load('/heart.glb', (gltf) => {
    const root = gltf.scene;
    root.traverse(o => {
      if (o.isMesh) {
        o.material = gold;
        o.userData.node = centerNode;
        heartMeshes.push(o);
      }
    });
    // center and scale to ~1.8 world units
    const box    = new THREE.Box3().setFromObject(root);
    const size   = box.getSize(new THREE.Vector3());
    const center = box.getCenter(new THREE.Vector3());
    const scale  = 1.8 / Math.max(size.x, size.y, size.z);
    root.scale.setScalar(scale);
    root.position.copy(center.multiplyScalar(-scale));
    heartPivot.add(root);
  });

  // ── raycasting & interaction ──────────────────────────────────────────────
  const raycaster = new THREE.Raycaster();
  const mouse     = new THREE.Vector2();
  const dragPlane = new THREE.Plane();
  const dragPoint = new THREE.Vector3();
  let isDragging  = false;
  let dragSprite: THREE.Object3D | null = null;
  let mouseDown   = { x: 0, y: 0 };

  function ndcFromEvent(e) {
    const r = container.getBoundingClientRect();
    return {
      x:  ((e.clientX - r.left) / r.width)  * 2 - 1,
      y: -((e.clientY - r.top)  / r.height) * 2 + 1,
    };
  }

  function hitSprite(e) {
    const ndc = ndcFromEvent(e);
    mouse.set(ndc.x, ndc.y);
    raycaster.setFromCamera(mouse, camera);
    if (heartMeshes.length) {
      const hh = raycaster.intersectObjects(heartMeshes);
      if (hh.length) return hh[0].object;
    }
    const hits = raycaster.intersectObjects(sprites);
    return hits.length > 0 ? hits[0].object : null;
  }

  container.addEventListener('pointerdown', e => {
    mouseDown = { x: e.clientX, y: e.clientY };
    const hit = hitSprite(e);
    if (!hit) return;
    const node = hit.userData.node;
    dragSprite = hit;
    if (!node.fixed) {
      controls.enabled = false;
      isDragging = true;
      const normal = new THREE.Vector3();
      camera.getWorldDirection(normal);
      dragPlane.setFromNormalAndCoplanarPoint(normal, hit.position);
    }
  });

  container.addEventListener('pointermove', e => {
    if (!isDragging || !dragSprite) return;
    const ndc = ndcFromEvent(e);
    mouse.set(ndc.x, ndc.y);
    raycaster.setFromCamera(mouse, camera);
    if (raycaster.ray.intersectPlane(dragPlane, dragPoint)) {
      dragSprite.position.copy(dragPoint);
      dragSprite.userData.node.basePos = dragPoint.clone();
      const ts = dragSprite.userData.node._textSprite;
      if (ts) ts.position.copy(dragPoint);
    }
  });

  container.addEventListener('pointerup', () => {
    if (isDragging) {
      isDragging = false;
      controls.enabled = true;
    }
    dragSprite = null;
  });

  // recenter
  const INIT_CAM_POS = new THREE.Vector3(0, 0, 14);
  document.getElementById('iw-recenter')?.addEventListener('click', () => {
    camera.position.copy(INIT_CAM_POS);
    controls.target.set(0, 0, 0);
    controls.update();
  });

  // reset node positions — smooth lerp back to origin
  const RESET_DURATION = 0.8;
  let resetStartTime: number | null = -1;
  const resetFrom = new Map();

  document.getElementById('iw-reset')?.addEventListener('click', () => {
    sprites.forEach(glowSprite => {
      const node = glowSprite.userData.node;
      resetFrom.set(node.id, glowSprite.position.clone());
    });
    resetStartTime = -1; // will be set on first frame with actual t
  });

  // ── animation loop ────────────────────────────────────────────────────────
  const clock = new THREE.Clock();

  renderer.setAnimationLoop(() => {
    const t = clock.getElapsedTime();

    // advance reset animation
    if (resetStartTime !== null) {
      if (resetStartTime < 0) resetStartTime = t;
      const progress = Math.min(1, (t - resetStartTime) / RESET_DURATION);
      const ease = 1 - Math.pow(1 - progress, 3); // cubic ease-out
      sprites.forEach(glowSprite => {
        const node = glowSprite.userData.node;
        const from = resetFrom.get(node.id);
        if (from) node.basePos.lerpVectors(from, node.originPos, ease);
      });
      if (progress >= 1) resetStartTime = null;
    }

    sprites.forEach(glowSprite => {
      const node = glowSprite.userData.node;
      if (!isDragging || glowSprite !== dragSprite) {
        const p = node.floatPhase, a = node.floatAmp, s = node.floatSpeed;
        const nx = node.basePos.x + Math.sin(t * s       + p.x) * a * 0.4;
        const ny = node.basePos.y + Math.sin(t * s * 0.7 + p.y) * a;
        const nz = node.basePos.z + Math.sin(t * s * 0.5 + p.z) * a * 0.3;
        glowSprite.position.set(nx, ny, nz);
        if (node._textSprite) node._textSprite.position.set(nx, ny, nz);
      }
    });

    starGroups.forEach(({ mat, phase, speed }) => {
      mat.opacity = 0.25 + 0.65 * (0.5 + 0.5 * Math.sin(t * speed + phase));
    });

    heartPivot.rotation.y = t * 0.4;
    updateEdges();
    controls.update();
    renderer.render(scene, camera);
  });

  // ── resize ────────────────────────────────────────────────────────────────
  const ro = new ResizeObserver(() => {
    const w = container.clientWidth, h = container.clientHeight;
    camera.aspect = w / h;
    camera.updateProjectionMatrix();
    renderer.setSize(w, h);
  });
  ro.observe(container);
}

let mapReady = false;

function initCoverStars() {
  const cover = document.getElementById('iw-cover');
  const canvas = cover?.querySelector<HTMLCanvasElement>('.iw-cover-stars');
  if (!cover || !canvas) return;

  const ctx = canvas.getContext('2d');
  if (!ctx) return;

  const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
  const stars = Array.from({ length: 220 }, () => ({
    x: Math.random(),
    y: Math.random(),
    r: Math.random() * 1.35 + 0.25,
    phase: Math.random() * Math.PI * 2,
    speed: 0.35 + Math.random() * 1.4,
    base: 0.12 + Math.random() * 0.38,
    tint: Math.random() > 0.7 ? '255, 228, 200' : '255, 245, 235',
  }));

  let running = true;
  let raf = 0;

  const resize = () => {
    const dpr = Math.min(window.devicePixelRatio, 2);
    const w = cover.clientWidth;
    const h = cover.clientHeight;
    canvas.width = Math.max(1, Math.floor(w * dpr));
    canvas.height = Math.max(1, Math.floor(h * dpr));
    canvas.style.width = `${w}px`;
    canvas.style.height = `${h}px`;
    ctx.setTransform(dpr, 0, 0, dpr, 0, 0);
  };

  const draw = (time = 0) => {
    const w = cover.clientWidth;
    const h = cover.clientHeight;
    ctx.clearRect(0, 0, w, h);
    const t = time * 0.001;

    for (const star of stars) {
      const twinkle = reduce
        ? star.base
        : star.base + 0.42 * (0.5 + 0.5 * Math.sin(t * star.speed + star.phase));
      ctx.fillStyle = `rgba(${star.tint}, ${twinkle})`;
      ctx.beginPath();
      ctx.arc(star.x * w, star.y * h, star.r, 0, Math.PI * 2);
      ctx.fill();
    }
  };

  const frame = (time: number) => {
    if (!running) return;
    draw(time);
    raf = requestAnimationFrame(frame);
  };

  resize();
  draw();
  if (!reduce) raf = requestAnimationFrame(frame);

  const ro = new ResizeObserver(() => {
    resize();
    draw();
  });
  ro.observe(cover);

  const mo = new MutationObserver(() => {
    const active = !cover.classList.contains('is-hidden');
    if (active === running) return;
    running = active;
    if (running && !reduce) {
      cancelAnimationFrame(raf);
      raf = requestAnimationFrame(frame);
    } else {
      cancelAnimationFrame(raf);
    }
  });
  mo.observe(cover, { attributes: true, attributeFilter: ['class'] });
}

initCoverStars();

function initCoverCursor() {
  const cover = document.getElementById('iw-cover');
  const glow = document.getElementById('iw-cover-glow');
  if (!cover || !glow) return;

  const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
  if (reduce) return;

  let targetX = -1000;
  let targetY = -1000;
  let curX = -1000;
  let curY = -1000;
  let active = false;
  let raf = 0;

  const tick = (time: number) => {
    curX += (targetX - curX) * 0.14;
    curY += (targetY - curY) * 0.14;
    glow.style.transform = `translate3d(${curX}px, ${curY}px, 0) translate(-50%, -50%)`;

    if (active) {
      const flicker = 0.84 + 0.16 * (0.5 + 0.5 * Math.sin(time * 0.005));
      glow.style.opacity = String(flicker);
    }

    raf = requestAnimationFrame(tick);
  };
  raf = requestAnimationFrame(tick);

  const show = () => { active = true; };
  const hide = () => {
    active = false;
    glow.style.opacity = '0';
  };

  const setTarget = (x: number, y: number) => {
    targetX = x;
    targetY = y;
  };

  cover.addEventListener('pointerenter', (e) => {
    setTarget(e.clientX, e.clientY);
    curX = e.clientX;
    curY = e.clientY;
    show();
  });
  cover.addEventListener('pointerleave', hide);
  cover.addEventListener('pointermove', (e) => {
    if ((e.target as HTMLElement).closest('button')) return;
    setTarget(e.clientX, e.clientY);
    show();
  });

  cover.querySelectorAll('button').forEach((btn) => {
    btn.addEventListener('pointerenter', hide);
    btn.addEventListener('pointerleave', () => {
      if (cover.matches(':hover') && !cover.classList.contains('is-hidden')) show();
    });
  });

  const mo = new MutationObserver(() => {
    if (cover.classList.contains('is-hidden')) hide();
  });
  mo.observe(cover, { attributes: true, attributeFilter: ['class'] });
}

initCoverCursor();

document.querySelectorAll<HTMLElement>('.iw-menu').forEach((btn) => {
  const glass = btn.querySelector<HTMLElement>('.iw-menu-glass');
  const lg = btn.querySelector<HTMLElement>('.lg');
  const sync = () => {
    if (!lg || !glass) return;
    glass.style.width = `${lg.offsetWidth}px`;
    glass.style.height = `${lg.offsetHeight}px`;
  };
  sync();
  if (lg) new ResizeObserver(sync).observe(lg);
});

function openMap() {
  const outer = document.getElementById('iw-outer');
  const cover = document.getElementById('iw-cover');
  outer?.classList.add('is-open');
  cover?.classList.add('is-hidden');
  cover?.setAttribute('aria-hidden', 'true');

  if (!mapReady) {
    mapReady = true;
    document.fonts.ready.then(init);
  }
}

function openMenu() {
  const outer = document.getElementById('iw-outer');
  const cover = document.getElementById('iw-cover');
  outer?.classList.remove('is-open');
  cover?.classList.remove('is-hidden');
  cover?.setAttribute('aria-hidden', 'false');
}

document.getElementById('iw-cover-enter')?.addEventListener('click', openMap);
document.getElementById('iw-menu')?.addEventListener('click', openMenu);
</script>
