    filter: url(#iw-menu);
  }
  .iw-menu-panel {
    position: relative;
    z-index: 1;
    display: inline-flex;
  }
  .iw-menu-panel :global(.lg) {
    box-shadow: none;
  }
  .iw-menu-panel :global(.lg__back) {
    background: transparent;
  }
  .iw-glass-inner {
    display: inline-flex;
    align-items: center;
    gap: 0.5em;
    padding: 10px 16px;
  }
  .iw-menu-label {
    font-family: var(--font-body);
    font-size: var(--text-sm);
    letter-spacing: 0.04em;
    color: #f4f4f5;
    text-shadow: 0 1px 6px rgba(0, 0, 0, 0.55), 0 0 2px rgba(0, 0, 0, 0.3);
    white-space: nowrap;
    transition: color 0.15s ease;
  }
  .iw-menu:hover .iw-menu-label,
  .iw-menu:focus-visible .iw-menu-label {
    color: #fff;
    outline: none;
  }
  .iw-menu:focus-visible {
    outline: none;
  }

  .iw-container {
    position: absolute;
    inset: 0;
    cursor: grab;
  }
  .iw-container:active { cursor: grabbing; }
  .iw-container canvas { display: block; }

  /* legend — spectral scale */
  .iw-legend {
    position: absolute;
    top: clamp(20px, 4vw, 40px);
    left: var(--space-md);
    display: flex;
    align-items: center;
    gap: 5px;
    z-index: 10;
    pointer-events: none;
  }
  .iw-leg-label {
    font-family: var(--font-body);
    font-size: 10px;
    color: rgba(255,255,255,0.35);
  }
  .iw-leg {
    width: 14px;
    height: 14px;
    border-radius: 50%;
    box-shadow: 0 0 6px 2px currentColor;
    opacity: 0.85;
  }
  .iw-leg--O { background: #5577FF; color: #5577FF; }
  .iw-leg--B { background: #99BBFF; color: #99BBFF; }
  .iw-leg--A { background: #EEEEFF; color: #EEEEFF; }
  .iw-leg--F { background: #EEFFAA; color: #EEFFAA; }
  .iw-leg--G { background: #FFE040; color: #FFE040; }
  .iw-leg--K { background: #FF8030; color: #FF8030; }
  .iw-leg--M { background: #FF2810; color: #FF2810; }

  /* reset + recenter buttons */
  .iw-reset {
    position: absolute;
    left: clamp(20px, 4vw, 48px);
    bottom: clamp(20px, 4vw, 48px);
    display: flex;
    align-items: center;
    gap: 6px;
    font-family: var(--font-body);
    font-size: 11px;
    color: rgba(255,255,255,0.45);
    background: rgba(255,255,255,0.06);
    border: 1px solid rgba(255,255,255,0.14);
    border-radius: var(--radius-pill);
    padding: 6px 12px;
    cursor: pointer;
    z-index: 11;
    transition: color 0.15s, border-color 0.15s, background 0.15s;
  }
  .iw-recenter {
    position: absolute;
    left: clamp(20px, 4vw, 48px);
    right: auto;
    bottom: calc(clamp(20px, 4vw, 48px) + 2.5rem);
    display: flex;
    align-items: center;
    gap: 6px;
    font-family: var(--font-body);
    font-size: 11px;
    color: rgba(255,255,255,0.45);
    background: rgba(255,255,255,0.06);
    border: 1px solid rgba(255,255,255,0.14);
    border-radius: var(--radius-pill);
    padding: 6px 12px;
    cursor: pointer;
    z-index: 11;
    transition: color 0.15s, border-color 0.15s, background 0.15s;
  }
  .iw-reset:hover,
  .iw-recenter:hover {
    color: rgba(255,255,255,0.85);
    border-color: rgba(255,255,255,0.35);
    background: rgba(255,255,255,0.10);
  }

  /* hint */
  .iw-hint {
    position: absolute;
    bottom: var(--space-md);
    left: 50%;
    transform: translateX(-50%);
    font-family: var(--font-body);
    font-size: 11px;
    color: rgba(255,255,255,0.30);
    pointer-events: none;
    white-space: nowrap;
    z-index: 10;
  }
</style>

