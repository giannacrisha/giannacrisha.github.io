---
// src/components/Nav.astro
import ThemeToggle from './ThemeToggle.astro';
import Icon from './Icon.astro';
import LogoCanvas from './LogoCanvas.astro';
import LiquidGlass from './LiquidGlass.astro';
const current = Astro.url.pathname;
const gardenActive = current.startsWith('/garden') || ['/lab','/archives','/gallery','/library'].some(p => current.startsWith(p));
const sublinks: { href: string; label: string; desc: string }[] = [
  { href: '/lab',      label: 'lab',      desc: 'design and code projects' },
  { href: '/archives', label: 'archives', desc: 'essays, poems, thoughts'  },
  { href: '/gallery',  label: 'gallery',  desc: 'artwork and visual work'  },
  { href: '/library',  label: 'library',  desc: 'films, books, shows'      },
];
---
<nav class="site-nav">
  <div class="nav-inner">
    <a href="/" class="nav-logo" aria-label="home"><LogoCanvas /></a>

    <!-- desktop -->
    <ul class="nav-links">
      <!-- the garden with hover dropdown -->
      <li class="nav-item nav-item--garden">
        <a href="/garden" class:list={['nav-link', { active: gardenActive }]} aria-haspopup="true" aria-expanded="false" id="garden-nav-trigger">
          the garden
          <Icon name="chevron-down" size={10} class="caret" />
        </a>
        <div class="garden-dropdown" id="garden-dropdown" role="region" aria-label="Garden sections">
          <div class="garden-dropdown-glass" aria-hidden="true"></div>
          <div class="garden-dropdown-panel">
            <LiquidGlass displacement={100} aberration={3} cornerRadius={24} filterId="garden-dd" backdrop={false}>
              <div class="garden-dropdown-inner">
                {sublinks.map(l => (
                  <a href={l.href} class:list={['dropdown-link', { active: current.startsWith(l.href) }]}>
                    <span class="dropdown-link-text">
                      <span class="dropdown-link-label">{l.label}</span>
                      <span class="dropdown-link-desc">{l.desc}</span>
                    </span>
                  </a>
                ))}
              </div>
            </LiquidGlass>
          </div>
        </div>
      </li>
      <li class="nav-item">
        <a href="/community" class:list={['nav-link', { active: current.startsWith('/community') }]}>community</a>
      </li>
      <li class="nav-item">
        <a href="/about" class:list={['nav-link', { active: current.startsWith('/about') }]}>about</a>
      </li>
      <li class="nav-item">
        <a href="/now" class:list={['nav-link', { active: current.startsWith('/now') }]}>now</a>
      </li>
    </ul>

    <!-- search trigger -->
    <button type="button" class="nav-search" id="nav-search-btn" aria-label="Search (⌘K)">
      <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true">
        <circle cx="6" cy="6" r="4.5" stroke="currentColor" stroke-width="1.3"/>
        <line x1="9.5" y1="9.5" x2="13" y2="13" stroke="currentColor" stroke-width="1.3" stroke-linecap="round"/>
      </svg>
      <kbd class="nav-search-hint">⌘K</kbd>
    </button>

    <!-- mobile hamburger -->
    <button class="nav-hamburger" aria-label="open menu" aria-expanded="false" id="hamburger">
      <Icon name="hamburger" size={20} />
    </button>
  </div>

  <!-- mobile backdrop -->
  <div class="nav-mobile-backdrop" id="nav-backdrop" aria-hidden="true"></div>

  <!-- mobile drawer -->
  <div class="nav-mobile-menu" id="nav-mobile-menu" aria-hidden="true" role="dialog" aria-label="Navigation menu">
    <button class="mobile-close" id="nav-close" aria-label="close menu">
      <Icon name="close" size={20} />
    </button>
    <a href="/garden" class="mobile-link">the garden</a>
    {sublinks.map(l => (
      <a href={l.href} class="mobile-link mobile-link--sub">{l.label}</a>
    ))}
    <a href="/community" class="mobile-link">community</a>
    <a href="/about" class="mobile-link">about</a>
    <a href="/now" class="mobile-link">now</a>
    <div class="mobile-theme-wrap">
      <ThemeToggle id="theme-toggle-nav" />
    </div>
  </div>
</nav>

<style>
  .site-nav {
    position: sticky;
    top: 0;
    z-index: 50;
    background: var(--color-bg);
    border-bottom: none;
  }
  .nav-inner {
    max-width: var(--width-site);
    margin: 0 auto;
    padding: 0 var(--space-xl);
    height: 56px;
    display: flex;
    align-items: center;
    justify-content: space-between;
  }
  .nav-logo {
    display: flex;
    align-items: center;
    text-decoration: none;
    line-height: 0;
  }

  /* desktop links */
  .nav-links {
    display: flex;
    gap: var(--space-xl);
    list-style: none;
    margin: 0;
    padding: 0;
    align-items: center;
  }
  .nav-item { position: relative; }

  .nav-link {
    display: inline-flex;
    align-items: center;
    gap: 4px;
    font-family: var(--font-serif);
    font-size: var(--text-md);
    color: var(--color-muted);
    text-decoration: none;
    letter-spacing: 0.01em;
    padding-bottom: 2px;
    border-bottom: 2px solid transparent;
    transition: color 0.15s, border-color 0.15s;
  }
  .nav-link:hover  { color: var(--color-fg); }
  .nav-link.active {
    color: var(--color-fg);
    border-bottom: 2px solid var(--color-accent);
  }
  .caret { transition: transform 0.15s; }

  /* hover dropdown — padding-top bridges the gap so mouse can travel to the menu */
  .garden-dropdown {
    display: none;
    position: absolute;
    top: 100%;
    left: 0;
    min-width: 220px;
    padding-top: 12px;
    --dd-stroke: 2.5px #fff;
    --dd-stroke-desc: 2px #fff;
    --dd-stroke-dark: 2.5px rgba(20, 20, 20, 0.95);
    --dd-stroke-desc-dark: 2px rgba(20, 20, 20, 0.95);
  }
  /* panel wraps LiquidGlass — glass layer is sized to match via JS (same as heart-cursor) */
  .garden-dropdown-panel {
    position: relative;
    display: inline-flex;
    z-index: 1;
  }
  .garden-dropdown-glass {
    position: absolute;
    top: 12px;
    left: 0;
    pointer-events: none;
    z-index: 0;
    border-radius: 24px;
    overflow: hidden;
    clip-path: inset(0 round 24px);
    background: rgba(255, 255, 255, 0.10);
    backdrop-filter: blur(2px) saturate(200%);
    -webkit-backdrop-filter: blur(2px) saturate(200%);
    box-shadow:
      0 0 0 0.75px rgba(255, 255, 255, 0.35) inset,
      0 4px 16px rgba(0, 0, 0, 0.12);
  }
  :global(:root[data-lg-refract="1"]) .garden-dropdown-glass {
    filter: url(#garden-dd);
  }
  .garden-dropdown-inner {
    padding: var(--space-sm);
    display: flex;
    flex-direction: column;
  }
  .nav-item--garden:hover .garden-dropdown,
  .nav-item--garden:focus-within .garden-dropdown {
    display: block;
  }
  .nav-item--garden:hover .caret {
    transform: rotate(180deg);
  }
  .dropdown-link {
    padding: var(--space-sm) var(--space-lg);
    display: flex;
    align-items: center;
    text-decoration: none;
    border-radius: 16px;
    transition: background 0.12s;
  }
  .dropdown-link:hover  { background: rgba(255, 255, 255, 0.5); }
  .dropdown-link:hover .dropdown-link-label {
    text-shadow: 0 0 0.6px var(--color-fg), 0 0 0.6px var(--color-fg);
  }
  .dropdown-link-text {
    display: flex;
    flex-direction: column;
    gap: 3px;
  }
  .dropdown-link-label {
    font-family: var(--font-serif);
    font-size: var(--text-sm);
    color: var(--color-fg);
    letter-spacing: 0.01em;
    -webkit-text-stroke: var(--dd-stroke);
    paint-order: stroke fill;
    transition: text-shadow 0.2s ease;
  }
  .dropdown-link.active .dropdown-link-label {
    color: var(--color-heading);
    text-shadow: 0 0 0.6px var(--color-heading), 0 0 0.6px var(--color-heading);
  }
  .dropdown-link-desc {
    font-family: var(--font-body);
    font-size: 11px;
    color: var(--color-muted);
    letter-spacing: 0.02em;
    -webkit-text-stroke: var(--dd-stroke-desc);
    paint-order: stroke fill;
  }
  :global(:root[data-theme="dark"]) .dropdown-link-label {
    -webkit-text-stroke: var(--dd-stroke-dark);
  }
  :global(:root[data-theme="dark"]) .dropdown-link-desc {
    -webkit-text-stroke: var(--dd-stroke-desc-dark);
  }
  :global(:root[data-theme="dark"]) .dropdown-link:hover .dropdown-link-label,
  :global(:root[data-theme="dark"]) .dropdown-link.active .dropdown-link-label {
    text-shadow: 0 0 0.6px currentColor, 0 0 0.6px currentColor;
  }

  /* search */
  .nav-search {
    display: flex;
    align-items: center;
    gap: 6px;
    background: var(--color-accent-light);
    border: var(--border);
    border-radius: var(--radius-pill);
    color: var(--color-muted);
    cursor: pointer;
    padding: 5px 10px;
    transition: background 0.15s, border-color 0.15s, color 0.15s;
  }
  .nav-search:hover {
    background: var(--color-card);
    border-color: var(--color-accent);
    color: var(--color-fg);
  }
  .nav-search-hint {
    font-family: var(--font-body);
    font-size: 11px;
    letter-spacing: 0.02em;
  }
  @media (max-width: 767px) { .nav-search-hint { display: none; } }

  /* hamburger */
  .nav-hamburger {
    display: none;
    background: none;
    border: none;
    color: var(--color-fg);
    cursor: pointer;
    padding: 4px;
  }

  /* mobile drawer */
  .nav-mobile-menu {
    position: fixed;
    top: 0;
    right: 0;
    bottom: 0;
    width: min(80vw, 300px);
    background: var(--color-bg);
    display: flex;
    flex-direction: column;
    padding: var(--space-xxl) var(--space-xl);
    gap: var(--space-sm);
    z-index: 200;
    transform: translateX(100%);
    transition: transform 0.35s cubic-bezier(0.4, 0, 0.2, 1);
    box-shadow: none;
  }
  .nav-mobile-menu.open {
    transform: translateX(0);
    box-shadow: -8px 0 32px rgba(0,0,0,0.18);
  }
  .nav-mobile-backdrop {
    position: fixed;
    inset: 0;
    background: rgba(0,0,0,0.4);
    z-index: 199;
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.3s ease;
  }
  .nav-mobile-backdrop.open {
    opacity: 1;
    pointer-events: auto;
  }
  .mobile-close {
    align-self: flex-end;
    background: none;
    border: none;
    color: var(--color-fg);
    cursor: pointer;
    padding: 8px;
    margin: -8px -8px var(--space-lg) 0;
    min-width: 44px;
    min-height: 44px;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: 6px;
    transition: background 0.15s;
  }
  .mobile-close:hover,
  .mobile-close:focus-visible { background: var(--color-border); }
  .mobile-close:focus-visible {
    outline: 2px solid var(--color-accent);
    outline-offset: 2px;
  }
  .mobile-link {
    padding: var(--space-md) 0;
    font-family: var(--font-body);
    font-size: var(--text-md);
    color: var(--color-fg);
    text-decoration: none;
    border-bottom: 1px solid var(--color-border);
    min-height: 44px;
    display: flex;
    align-items: center;
    transition: color 0.15s;
  }
  .mobile-link:last-of-type { border-bottom: none; }
  .mobile-theme-wrap {
    margin-top: auto;
    padding-top: var(--space-xl);
    display: flex;
    align-items: center;
    justify-content: space-between;
  }
  .mobile-link:hover,
  .mobile-link:focus-visible { color: var(--color-accent); }
  .mobile-link:focus-visible {
    outline: 2px solid var(--color-accent);
    outline-offset: 2px;
    border-radius: 2px;
  }
  .mobile-link--sub {
    padding-left: var(--space-lg);
    font-size: var(--text-sm);
    color: var(--color-muted);
  }
  :root[data-theme="dark"] .mobile-link--sub {
    color: var(--color-fg);
    opacity: 0.7;
  }

  @media (max-width: 767px) {
    .nav-links     { display: none; }
    .nav-hamburger { display: block; }
  }
</style>

<script>
  const btn      = document.getElementById('hamburger');
  const menu     = document.getElementById('nav-mobile-menu');
  const backdrop = document.getElementById('nav-backdrop');
  const closeBtn = document.getElementById('nav-close');

  const FOCUSABLE = 'a[href], button:not([disabled]), [tabindex]:not([tabindex="-1"])';
  function getFocusable(): HTMLElement[] {
    return Array.from(menu?.querySelectorAll<HTMLElement>(FOCUSABLE) ?? []);
  }

  function openMenu() {
    menu?.classList.add('open');
    backdrop?.classList.add('open');
    btn?.setAttribute('aria-expanded', 'true');
    menu?.setAttribute('aria-hidden', 'false');
    document.body.style.overflow = 'hidden';
    setTimeout(() => closeBtn?.focus(), 50);
  }
  function closeMenu() {
    menu?.classList.remove('open');
    backdrop?.classList.remove('open');
    btn?.setAttribute('aria-expanded', 'false');
    menu?.setAttribute('aria-hidden', 'true');
    document.body.style.overflow = '';
    btn?.focus();
  }

  btn?.addEventListener('click', openMenu);
  closeBtn?.addEventListener('click', closeMenu);
  backdrop?.addEventListener('click', closeMenu);

  menu?.addEventListener('keydown', (e: KeyboardEvent) => {
    if (e.key === 'Escape') { closeMenu(); return; }
    if (e.key !== 'Tab') return;
    const focusable = getFocusable();
    if (!focusable.length) return;
    const first = focusable[0];
    const last  = focusable[focusable.length - 1];
    if (e.shiftKey) {
      if (document.activeElement === first) { e.preventDefault(); last.focus(); }
    } else {
      if (document.activeElement === last)  { e.preventDefault(); first.focus(); }
    }
  });

  // Garden dropdown aria-expanded on hover/focus
  const gardenItem    = document.querySelector('.nav-item--garden');
  const gardenTrigger = document.getElementById('garden-nav-trigger');
  const gardenPanel   = document.querySelector<HTMLElement>('.garden-dropdown-panel');
  const gardenGlass   = document.querySelector<HTMLElement>('.garden-dropdown-glass');
  const syncGardenGlass = () => {
    if (!gardenPanel || !gardenGlass) return;
    gardenGlass.style.width  = gardenPanel.offsetWidth  + 'px';
    gardenGlass.style.height = gardenPanel.offsetHeight + 'px';
  };
  syncGardenGlass();
  if (gardenPanel) new ResizeObserver(syncGardenGlass).observe(gardenPanel);
  if (gardenItem && gardenTrigger) {
    const setExpanded = (v: boolean) => gardenTrigger.setAttribute('aria-expanded', String(v));
    gardenItem.addEventListener('mouseenter', () => setExpanded(true));
    gardenItem.addEventListener('mouseleave', () => setExpanded(false));
    gardenItem.addEventListener('focusin',    () => setExpanded(true));
    gardenItem.addEventListener('focusout',   (e) => {
      if (!gardenItem.contains((e as FocusEvent).relatedTarget as Node)) setExpanded(false);
    });
  }
</script>
