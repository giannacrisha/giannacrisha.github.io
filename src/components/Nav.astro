---
// src/components/Nav.astro
const current = Astro.url.pathname;
const gardenActive = ['/','/lab','/archives','/gallery','/library'].some(p => current.startsWith(p));
const sublinks = [
  { href: '/lab',      label: 'lab',      desc: 'design and code projects',    icon: '/icons/lab-icon.png'     },
  { href: '/archives', label: 'archives', desc: 'essays, poems, thoughts',     icon: '/icons/archive-icon.png' },
  { href: '/gallery',  label: 'gallery',  desc: 'artwork and visual work',     icon: '/icons/gallery-icon.png' },
  { href: '/library',  label: 'library',  desc: 'films, books, shows', icon: '/icons/lib-icon.png'     },
];
---
<nav class="site-nav">
  <div class="nav-inner">
    <a href="/" class="nav-logo">gi</a>

    <!-- desktop -->
    <ul class="nav-links">
      <!-- the garden with hover dropdown -->
      <li class="nav-item nav-item--garden">
        <a href="/" class:list={['nav-link', { active: gardenActive }]}>
          the garden
          <svg width="10" height="10" viewBox="0 0 10 10" fill="none" aria-hidden="true" class="caret">
            <path d="M2 3.5l3 3 3-3" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </a>
        <div class="garden-dropdown">
          <div class="garden-dropdown-inner">
            {sublinks.map(l => (
              <a href={l.href} class:list={['dropdown-link', { active: current.startsWith(l.href) }]}>
                <img src={l.icon} alt="" class="dropdown-link-icon" aria-hidden="true" />
                <span class="dropdown-link-text">
                  <span class="dropdown-link-label">{l.label}</span>
                  <span class="dropdown-link-desc">{l.desc}</span>
                </span>
              </a>
            ))}
          </div>
        </div>
      </li>
      <li class="nav-item">
        <a href="/about" class:list={['nav-link', { active: current.startsWith('/about') }]}>about</a>
      </li>
    </ul>

    <!-- mobile hamburger -->
    <button class="nav-hamburger" aria-label="open menu" aria-expanded="false" id="hamburger">
      <svg width="20" height="20" viewBox="0 0 20 20" fill="none">
        <line x1="3" y1="6"  x2="17" y2="6"  stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
        <line x1="3" y1="10" x2="17" y2="10" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
        <line x1="3" y1="14" x2="17" y2="14" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
      </svg>
    </button>
  </div>

  <!-- mobile backdrop -->
  <div class="nav-mobile-backdrop" id="nav-backdrop" aria-hidden="true"></div>

  <!-- mobile drawer -->
  <div class="nav-mobile-menu" id="nav-mobile-menu" aria-hidden="true" role="dialog" aria-label="Navigation menu">
    <button class="mobile-close" id="nav-close" aria-label="close menu">
      <svg width="20" height="20" viewBox="0 0 20 20" fill="none">
        <line x1="4" y1="4" x2="16" y2="16" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
        <line x1="16" y1="4" x2="4"  y2="16" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
      </svg>
    </button>
    <a href="/" class="mobile-link">the garden</a>
    {sublinks.map(l => (
      <a href={l.href} class="mobile-link mobile-link--sub">{l.label}</a>
    ))}
    <a href="/about" class="mobile-link">about</a>
  </div>
</nav>

<style>
  .site-nav {
    position: sticky;
    top: 0;
    z-index: 50;
    background: transparent;
    border-bottom: none;
  }
  .nav-inner {
    max-width: var(--width-site);
    margin: 0 auto;
    padding: 0 var(--space-xl);
    height: 56px;
    display: flex;
    align-items: center;
    justify-content: space-between;
  }
  .nav-logo {
    font-family: var(--font-display);
    font-size: 22px;
    color: var(--color-fg);
    text-decoration: none;
  }

  /* desktop links */
  .nav-links {
    display: flex;
    gap: var(--space-xl);
    list-style: none;
    margin: 0;
    padding: 0;
    align-items: center;
  }
  .nav-item { position: relative; }

  .nav-link {
    display: inline-flex;
    align-items: center;
    gap: 4px;
    font-family: var(--font-body);
    font-size: var(--text-xs);
    color: var(--color-muted);
    text-decoration: none;
    letter-spacing: 0.06em;
    padding-bottom: 2px;
    border-bottom: 2px solid transparent;
    transition: color 0.15s, border-color 0.15s;
  }
  .nav-link:hover  { color: var(--color-fg); }
  .nav-link.active {
    color: var(--color-fg);
    border-bottom: 2px solid var(--color-accent);
  }
  .caret { transition: transform 0.15s; }

  /* hover dropdown — padding-top bridges the gap so mouse can travel to the menu */
  .garden-dropdown {
    display: none;
    position: absolute;
    top: 100%;
    right: 0;
    min-width: 200px;
    padding-top: 12px; /* invisible bridge — keeps hover alive */
    flex-direction: column;
  }
  .garden-dropdown-inner {
    background: #ffffff;
    border: 0.5px solid var(--color-border);
    border-radius: var(--radius-card);
    box-shadow: 0 4px 20px rgba(0,0,0,0.07);
    padding: var(--space-sm) 0;
    display: flex;
    flex-direction: column;
  }
  .nav-item--garden:hover .garden-dropdown,
  .nav-item--garden:focus-within .garden-dropdown {
    display: flex;
  }
  .nav-item--garden:hover .caret {
    transform: rotate(180deg);
  }
  .dropdown-link {
    padding: var(--space-sm) var(--space-lg);
    display: flex;
    flex-direction: row;
    align-items: center;
    gap: var(--space-md);
    text-decoration: none;
    transition: background 0.12s;
  }
  .dropdown-link-icon {
    width: 28px;
    height: 28px;
    object-fit: contain;
    flex-shrink: 0;
    opacity: 0.7;
    transition: opacity 0.12s;
    image-rendering: pixelated;
  }
  .dropdown-link:hover .dropdown-link-icon,
  .dropdown-link.active .dropdown-link-icon {
    opacity: 1;
  }
  .dropdown-link-text {
    display: flex;
    flex-direction: column;
    gap: 2px;
  }
  .dropdown-link:hover  { background: var(--color-accent-light); }
  .dropdown-link.active .dropdown-link-label { color: var(--color-fg); font-weight: 600; }
  .dropdown-link-label {
    font-family: var(--font-body);
    font-size: var(--text-xs);
    color: var(--color-fg);
    letter-spacing: 0.05em;
  }
  .dropdown-link-desc {
    font-family: var(--font-body);
    font-size: 10px;
    color: var(--color-muted);
    letter-spacing: 0.03em;
  }

  /* hamburger */
  .nav-hamburger {
    display: none;
    background: none;
    border: none;
    color: var(--color-fg);
    cursor: pointer;
    padding: 4px;
  }

  /* mobile drawer */
  .nav-mobile-menu {
    position: fixed;
    top: 0;
    right: 0;
    bottom: 0;
    width: min(80vw, 300px);
    background: #f5f0e8;
    display: flex;
    flex-direction: column;
    padding: var(--space-xxl) var(--space-xl);
    gap: var(--space-sm);
    z-index: 200;
    transform: translateX(100%);
    transition: transform 0.35s cubic-bezier(0.4, 0, 0.2, 1);
    box-shadow: -8px 0 32px rgba(0,0,0,0.08);
  }
  .nav-mobile-menu.open {
    transform: translateX(0);
  }
  .nav-mobile-backdrop {
    position: fixed;
    inset: 0;
    background: rgba(0,0,0,0.25);
    z-index: 199;
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.3s ease;
  }
  .nav-mobile-backdrop.open {
    opacity: 1;
    pointer-events: auto;
  }
  .mobile-close {
    align-self: flex-end;
    background: none;
    border: none;
    color: var(--color-fg);
    cursor: pointer;
    padding: 4px;
    margin-bottom: var(--space-lg);
  }
  .mobile-link {
    padding: var(--space-sm) 0;
    font-family: var(--font-body);
    font-size: var(--text-md);
    color: var(--color-fg);
    text-decoration: none;
    border-bottom: 1px solid rgba(0,0,0,0.08);
  }
  .mobile-link:last-child { border-bottom: none; }
  .mobile-link--sub {
    padding-left: var(--space-lg);
    font-size: var(--text-sm);
    color: var(--color-muted);
  }

  @media (max-width: 767px) {
    .nav-links     { display: none; }
    .nav-hamburger { display: block; }
  }
</style>

<script>
  const btn      = document.getElementById('hamburger');
  const menu     = document.getElementById('nav-mobile-menu');
  const backdrop = document.getElementById('nav-backdrop');
  const closeBtn = document.getElementById('nav-close');

  function openMenu() {
    menu?.classList.add('open');
    backdrop?.classList.add('open');
    btn?.setAttribute('aria-expanded', 'true');
    menu?.setAttribute('aria-hidden', 'false');
    document.body.style.overflow = 'hidden';
  }

  function closeMenu() {
    menu?.classList.remove('open');
    backdrop?.classList.remove('open');
    btn?.setAttribute('aria-expanded', 'false');
    menu?.setAttribute('aria-hidden', 'true');
    document.body.style.overflow = '';
  }

  btn?.addEventListener('click', openMenu);
  closeBtn?.addEventListener('click', closeMenu);
  backdrop?.addEventListener('click', closeMenu);

  // Close on Escape
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape') closeMenu();
  });
</script>
