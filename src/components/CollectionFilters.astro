---
// src/components/CollectionFilters.astro
// Same chip+dropdown style as GardenFilters, but driven by props
// so it works on any collection index page.

interface FilterOption {
  value: string;
  label: string;
}
interface FilterGroup {
  label: string;
  param: string;
  options: FilterOption[];
}
interface Props {
  filters: FilterGroup[];
  showSort?: boolean;
}

const { filters, showSort = true } = Astro.props;
---

<div class="col-controls" id="col-controls" data-pagefind-ignore>

  <!-- Filters chip -->
  <div class="chip-wrap">
    <button class="control-chip" id="col-filters-btn" aria-expanded="false" aria-haspopup="true">
      <i class="hn hn-filter-solid"></i>
      <span class="chip-label">filters</span>
    </button>
    <div class="dropdown" id="col-filters-dropdown" aria-hidden="true">
      {filters.map(group => (
        <div class="dropdown-section">
          <span class="dropdown-label">{group.label}</span>
          <div class="dropdown-pills">
            {group.options.map((opt, i) => (
              <button
                class:list={['dpill', { active: i === 0 }]}
                data-col-param={group.param}
                data-col-value={opt.value}
              >
                {opt.label}
              </button>
            ))}
          </div>
        </div>
      ))}
    </div>
  </div>

  <!-- Sort chip -->
  {showSort && (
    <div class="chip-wrap">
      <button class="control-chip" id="col-sort-btn" aria-expanded="false" aria-haspopup="true">
        <i class="hn hn-sort-solid"></i>
        <span class="chip-label">sort</span>
      </button>
      <div class="dropdown" id="col-sort-dropdown" aria-hidden="true">
        <div class="dropdown-section">
          <div class="dropdown-pills">
            <button class="dpill active" data-col-sort="newest">most recent</button>
            <button class="dpill" data-col-sort="oldest">oldest first</button>
            <button class="dpill" data-col-sort="stage">by growth stage</button>
          </div>
        </div>
      </div>
    </div>
  )}

</div>

<style>
  .col-controls {
    display: flex;
    gap: var(--space-sm);
    margin-bottom: var(--space-xxl);
  }
  .chip-wrap { position: relative; }

  .control-chip {
    display: inline-flex;
    align-items: center;
    gap: var(--space-xs);
    padding: 5px 14px;
    border-radius: var(--radius-pill);
    border: 0.5px solid var(--color-accent-border);
    background: var(--color-card);
    color: var(--color-fg);
    font-family: var(--font-body);
    font-size: var(--text-xs);
    letter-spacing: 0.05em;
    cursor: pointer;
    transition: border-color 0.12s, background 0.12s;
  }
  .control-chip:hover,
  .control-chip[aria-expanded="true"] {
    border-color: var(--color-fg);
    background: var(--color-fg);
    color: #ffffff;
  }
  .control-chip .hn { font-size: 16px; line-height: 1; }

  .dropdown {
    display: none;
    position: absolute;
    top: calc(100% + 8px);
    left: 0;
    min-width: 220px;
    background: var(--color-card);
    border: 0.5px solid var(--color-border);
    border-radius: var(--radius-card);
    box-shadow: 0 4px 24px rgba(0,0,0,0.08);
    z-index: 200;
    padding: var(--space-lg);
    flex-direction: column;
    gap: var(--space-lg);
  }
  .dropdown.open { display: flex; }

  .dropdown-section {
    display: flex;
    flex-direction: column;
    gap: var(--space-sm);
  }
  .dropdown-label {
    font-family: var(--font-body);
    font-size: var(--text-xs);
    color: var(--color-muted);
    letter-spacing: 0.08em;
  }
  .dropdown-pills {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-xs);
  }

  .dpill {
    display: inline-flex;
    align-items: center;
    padding: 4px 12px;
    border-radius: var(--radius-pill);
    border: 0.5px solid var(--color-accent-border);
    background: var(--color-pill-bg);
    color: var(--color-pill-text);
    font-family: var(--font-body);
    font-size: var(--text-xs);
    letter-spacing: 0.04em;
    cursor: pointer;
    transition: background 0.1s, color 0.1s, border-color 0.1s;
  }
  .dpill.active {
    background: var(--color-fg);
    color: #ffffff;
    border-color: var(--color-fg);
  }
  .dpill:hover:not(.active) {
    border-color: var(--color-accent);
    color: var(--color-fg);
  }

  @media (max-width: 600px) {
    .chip-label { display: none; }
  }
</style>

<script>
  // ── toggle dropdowns ─────────────────────────────────────────────────────
  function toggle(btnId: string, dropId: string, otherId: string, otherBtnId: string) {
    const btn      = document.getElementById(btnId)!;
    const drop     = document.getElementById(dropId)!;
    const other    = document.getElementById(otherId);
    const otherBtn = document.getElementById(otherBtnId);
    btn.addEventListener('click', (e) => {
      e.stopPropagation();
      const open = drop.classList.toggle('open');
      btn.setAttribute('aria-expanded', String(open));
      drop.setAttribute('aria-hidden', String(!open));
      other?.classList.remove('open');
      otherBtn?.setAttribute('aria-expanded', 'false');
    });
  }

  document.addEventListener('click', () => {
    ['col-filters-dropdown', 'col-sort-dropdown'].forEach(id => {
      document.getElementById(id)?.classList.remove('open');
    });
    ['col-filters-btn', 'col-sort-btn'].forEach(id => {
      document.getElementById(id)?.setAttribute('aria-expanded', 'false');
    });
  });

  toggle('col-filters-btn', 'col-filters-dropdown', 'col-sort-dropdown',   'col-sort-btn');
  toggle('col-sort-btn',    'col-sort-dropdown',    'col-filters-dropdown', 'col-filters-btn');

  // ── state ─────────────────────────────────────────────────────────────────
  const activeFilters: Record<string, string> = {};
  let activeSort = 'newest';

  // initialise from rendered pills (first option = 'all' by default)
  document.querySelectorAll<HTMLButtonElement>('.dpill[data-col-param]').forEach(pill => {
    const param = pill.dataset.colParam!;
    if (!activeFilters[param]) activeFilters[param] = pill.dataset.colValue!;
  });

  // ── filter ────────────────────────────────────────────────────────────────
  function applyFilters() {
    document.querySelectorAll<HTMLElement>('[data-filter]').forEach(item => {
      const f = JSON.parse(item.dataset.filter!);
      const visible = Object.entries(activeFilters).every(([param, val]) =>
        val === 'all' || f[param] === val
      );
      item.style.display = visible ? '' : 'none';
    });
  }

  // ── sort ──────────────────────────────────────────────────────────────────
  const stageOrder: Record<string, number> = { dust: 1, spark: 2, star: 3 };

  function applySort() {
    const items = Array.from(
      document.querySelectorAll<HTMLElement>('[data-filter]')
    );
    const parent = items[0]?.parentElement;
    if (!parent) return;

    items.sort((a, b) => {
      const ad = Number(a.dataset.date ?? 0);
      const bd = Number(b.dataset.date ?? 0);
      const as_ = stageOrder[a.dataset.stage ?? ''] ?? 0;
      const bs_ = stageOrder[b.dataset.stage ?? ''] ?? 0;
      if (activeSort === 'newest') return bd - ad;
      if (activeSort === 'oldest') return ad - bd;
      if (activeSort === 'stage')  return bs_ - as_;
      return 0;
    });
    items.forEach(i => parent.appendChild(i));
  }

  // ── pill clicks ───────────────────────────────────────────────────────────
  document.querySelectorAll<HTMLButtonElement>('.dpill[data-col-param]').forEach(pill => {
    pill.addEventListener('click', () => {
      activeFilters[pill.dataset.colParam!] = pill.dataset.colValue!;
      pill.closest('.dropdown-pills')!.querySelectorAll('.dpill')
        .forEach(p => p.classList.toggle('active', p === pill));
      applyFilters();
    });
  });

  document.querySelectorAll<HTMLButtonElement>('.dpill[data-col-sort]').forEach(pill => {
    pill.addEventListener('click', () => {
      activeSort = pill.dataset.colSort!;
      pill.closest('.dropdown-pills')!.querySelectorAll('.dpill')
        .forEach(p => p.classList.toggle('active', p === pill));
      applySort();
    });
  });
</script>
