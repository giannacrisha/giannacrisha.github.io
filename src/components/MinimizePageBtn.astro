---
// src/components/MinimizePageBtn.astro
// Minimize button for detail pages.
// Registers the current page as a tab, plays a shrink animation, then navigates.
import Icon from './Icon.astro';
interface Props {
  title?: string;
}
const { title } = Astro.props;
---

<button
  class="minimize-page-btn"
  aria-label="Minimize page to tab"
  data-page-title={title ?? ''}
  data-page-url={Astro.url.pathname}
  id="minimize-page-btn"
>
  <Icon name="minimize" size={14} />
  <span class="minimize-label">minimize</span>
</button>

<style is:global>
  .minimize-page-btn {
    display: inline-flex;
    align-items: center;
    padding: 6px;
    border-radius: 999px;
    border: 0.5px solid var(--color-border);
    background: var(--color-card);
    font-family: var(--font-body);
    font-size: var(--text-xs);
    color: var(--color-muted);
    cursor: pointer;
    letter-spacing: 0.04em;
    transition: background 0.15s, color 0.15s;
  }
  /* Label is collapsed to icon-only by default; expands on hover/focus. */
  .minimize-label {
    display: inline-block;
    max-width: 0;
    overflow: hidden;
    white-space: nowrap;
    opacity: 0;
    margin-left: 0;
    transition: max-width 0.2s ease, opacity 0.2s ease, margin-left 0.2s ease;
  }
  .minimize-page-btn:hover,
  .minimize-page-btn:focus-visible {
    background: var(--color-accent-light);
    color: var(--color-fg);
  }
  .minimize-page-btn:hover .minimize-label,
  .minimize-page-btn:focus-visible .minimize-label {
    max-width: 80px;
    opacity: 1;
    margin-left: 6px;
  }
  .minimize-page-btn:focus-visible {
    outline: 2px solid var(--color-accent);
    outline-offset: 2px;
  }

  @media (max-width: 767px) {
    .minimize-page-btn { display: none; }
  }

  /* ── Shrink animation ─────────────────────────── */
  @keyframes page-shrink-to-tab {
    0%   { transform: scale(1)    translateY(0);    opacity: 1; transform-origin: center bottom; }
    60%  { opacity: 0.6; }
    100% { transform: scale(0.05) translateY(60vh); opacity: 0; transform-origin: center bottom; }
  }

  body.minimizing {
    overflow: hidden;
    pointer-events: none;
  }
  body.minimizing main {
    animation: page-shrink-to-tab 0.43s cubic-bezier(0.4, 0, 0.2, 1) forwards;
    will-change: transform, opacity;
    position: relative;
    z-index: 10;
  }
  body.minimizing .site-nav,
  body.minimizing footer {
    opacity: 0;
    transition: opacity 0.2s ease;
    position: relative;
    z-index: 10;
  }
  body.minimizing #gi-tabbar {
    z-index: 20;
  }
</style>

<script is:inline>
(function () {
  var btn = document.getElementById('minimize-page-btn');
  if (!btn) return;

  btn.addEventListener('click', function () {
    var rawTitle = btn.getAttribute('data-page-title') || document.title;
    var url      = btn.getAttribute('data-page-url') || window.location.pathname;
    var title    = rawTitle || document.title.replace(/\s*[–|]\s*gi.*$/, '').trim();
    var id       = url;

    // Destination: back if same-origin referrer that isn't the current page, else home
    var dest = (document.referrer
      && document.referrer.includes(window.location.host)
      && document.referrer !== window.location.href)
      ? document.referrer
      : '/';

    // 1. Register the tab
    if (window.__giTabs) window.__giTabs.add(id, title, url);

    // 2. Inject destination as a silent background iframe so it paints
    //    behind the shrinking page — eliminates the blank flash on navigate
    var bgFrame = document.createElement('iframe');
    bgFrame.src = dest;
    bgFrame.setAttribute('aria-hidden', 'true');
    bgFrame.setAttribute('tabindex', '-1');
    bgFrame.style.cssText = 'position:fixed;inset:0;width:100%;height:100%;border:none;z-index:0;pointer-events:none';
    document.body.appendChild(bgFrame);

    // 3. Play shrink animation
    document.body.classList.add('minimizing');

    // 4. Navigate once animation is done
    setTimeout(function () {
      window.location.href = dest;
    }, 430);
  });
})();
</script>
