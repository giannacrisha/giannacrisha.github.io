---
// src/components/MinimizePageBtn.astro
// Minimize button for detail pages.
// Registers the current page as a tab, then navigates away.
interface Props {
  title?: string;
}
const { title } = Astro.props;
---

<button
  class="minimize-page-btn"
  aria-label="Minimize page to tab"
  data-page-title={title ?? ''}
  data-page-url={Astro.url.pathname}
  id="minimize-page-btn"
>
  <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true">
    <line x1="2" y1="7" x2="12" y2="7" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
  </svg>
  minimize
</button>

<style is:global>
  .minimize-page-btn {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    padding: 5px 12px 5px 10px;
    border-radius: 999px;
    border: 0.5px solid var(--color-border);
    background: var(--color-card);
    font-family: var(--font-body);
    font-size: var(--text-xs);
    color: var(--color-muted);
    cursor: pointer;
    letter-spacing: 0.04em;
    transition: background 0.15s, color 0.15s;
  }
  .minimize-page-btn:hover {
    background: var(--color-accent-light);
    color: var(--color-fg);
  }
  .minimize-page-btn:focus-visible {
    outline: 2px solid var(--color-accent);
    outline-offset: 2px;
  }
</style>

<script is:inline>
(function () {
  var btn = document.getElementById('minimize-page-btn');
  if (!btn) return;

  btn.addEventListener('click', function () {
    var rawTitle = btn.getAttribute('data-page-title') || document.title;
    var url      = btn.getAttribute('data-page-url') || window.location.pathname;
    var title    = rawTitle || document.title.replace(/\s*[–|]\s*gi.*$/, '').trim();
    var id       = url;

    // Register the tab
    if (window.__giTabs) window.__giTabs.add(id, title, url);

    // Navigate back — referrer if same-origin, else home
    var dest = (document.referrer && document.referrer.includes(window.location.host))
      ? document.referrer
      : '/';

    window.location.href = dest;
  });
})();
</script>
