---
// src/components/SearchModal.astro
// ⌘K / Ctrl+K search powered by Pagefind.
// Pagefind index is generated at build time (`npm run build`).
// `npm run build` copies the index to public/pagefind/ for local dev.
---

<div id="search-modal" class="search-modal" role="dialog" aria-modal="true" aria-label="Search the garden" hidden>
  <div class="search-backdrop" id="search-backdrop"></div>
  <div class="search-box">
    <div class="search-input-row">
      <svg class="search-icon" width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true">
        <circle cx="6" cy="6" r="4.5" stroke="currentColor" stroke-width="1.3"/>
        <line x1="9.5" y1="9.5" x2="13" y2="13" stroke="currentColor" stroke-width="1.3" stroke-linecap="round"/>
      </svg>
      <input
        id="search-input"
        class="search-input"
        type="search"
        placeholder="search the garden…"
        autocomplete="off"
        spellcheck="false"
      />
      <kbd class="search-esc" aria-label="Press Escape to close">esc</kbd>
    </div>
    <div id="search-results" class="search-results" role="listbox" aria-label="Search results"></div>
    <div id="search-empty" class="search-empty" hidden>nothing found in the garden.</div>
    <div id="search-hint" class="search-hint">type to search across all collections</div>
  </div>
</div>

<style>
  .search-modal {
    position: fixed;
    inset: 0;
    z-index: 900;
    display: flex;
    align-items: flex-start;
    justify-content: center;
    padding-top: 14vh;
    padding-bottom: 0;
  }
  .search-modal[hidden] { display: none; }

  .search-backdrop {
    position: fixed;
    inset: 0;
    background: rgba(0,0,0,0.3);
    backdrop-filter: blur(2px);
  }

  .search-box {
    position: relative;
    z-index: 1;
    background: var(--color-card);
    border: var(--border);
    border-radius: var(--radius-card);
    box-shadow: var(--shadow-gold), 0 16px 48px rgba(0, 0, 0, 0.08);
    width: min(560px, calc(100vw - 32px));
    display: flex;
    flex-direction: column;
    overflow: hidden;
    animation: searchIn 0.18s ease both;
  }
  @keyframes searchIn {
    from { opacity: 0; transform: translateY(-8px) scale(0.98); }
    to   { opacity: 1; transform: translateY(0) scale(1); }
  }

  /* ── Input row ─────────────────────────────────────────────────────── */
  .search-input-row {
    display: flex;
    align-items: center;
    gap: var(--space-md);
    padding: var(--space-lg) var(--space-xl);
    border-bottom: var(--border);
  }
  .search-icon { color: var(--color-muted); flex-shrink: 0; }
  .search-input {
    flex: 1;
    font-family: var(--font-body);
    font-size: var(--text-md);
    color: var(--color-fg);
    background: transparent;
    border: none;
    outline: none;
    min-width: 0;
  }
  .search-input::placeholder { color: var(--color-muted); opacity: 0.6; }
  .search-input::-webkit-search-cancel-button { display: none; }

  kbd.search-esc {
    font-family: var(--font-body);
    font-size: var(--text-xs);
    color: var(--color-muted);
    background: var(--color-pill-bg);
    border: var(--border);
    border-radius: var(--radius-pill);
    padding: 2px 8px;
    flex-shrink: 0;
  }

  /* ── Results list ──────────────────────────────────────────────────── */
  .search-results {
    display: flex;
    flex-direction: column;
    max-height: 360px;
    overflow-y: auto;
    overscroll-behavior: contain;
  }
  .search-results:empty { display: none; }

  /* ── Results (injected via innerHTML — must be :global) ───────────── */
  .search-results :global(.search-result) {
    display: flex;
    flex-direction: column;
    gap: var(--space-xs);
    padding: var(--space-md) var(--space-xl);
    text-decoration: none;
    color: inherit;
    border-bottom: var(--border);
    transition: background 0.12s, border-color 0.12s;
    cursor: pointer;
  }
  .search-results :global(.search-result:last-child) { border-bottom: none; }
  .search-results :global(.search-result:hover),
  .search-results :global(.search-result[aria-selected="true"]) {
    background: var(--color-accent-light);
  }

  .search-results :global(.search-result-header) {
    display: flex;
    align-items: center;
    gap: var(--space-sm);
    flex-wrap: wrap;
  }

  .search-results :global(.search-result-title) {
    font-family: var(--font-serif);
    font-size: var(--text-md);
    font-weight: 500;
    color: var(--color-fg);
    line-height: var(--leading-tight);
  }

  .search-results :global(.search-result-collection) {
    font-family: var(--font-body);
    font-size: var(--text-xs);
    color: var(--color-pill-text);
    letter-spacing: 0.06em;
    text-transform: lowercase;
    background: var(--color-pill-bg);
    border: var(--border);
    border-radius: var(--radius-pill);
    padding: 2px 8px;
    flex-shrink: 0;
  }

  .search-results :global(.search-result-excerpt) {
    font-family: var(--font-body);
    font-size: var(--text-sm);
    color: var(--color-muted);
    line-height: var(--leading-base);
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .search-results :global(.search-result-excerpt mark) {
    background: var(--color-accent-light);
    color: var(--color-heading);
    font-weight: 600;
    border-radius: 2px;
    padding: 0 1px;
  }

  /* ── States ────────────────────────────────────────────────────────── */
  .search-hint,
  .search-empty {
    font-family: var(--font-body);
    font-size: var(--text-xs);
    color: var(--color-muted);
    text-align: center;
    padding: var(--space-xl);
    opacity: 0.6;
  }
  .search-empty[hidden],
  .search-hint[hidden] { display: none; }
</style>

<script>
  let pagefind: any = null;
  let pagefindFailed = false;
  let pagefindLoading: Promise<void> | null = null;
  let activeIndex = -1;
  let bound = false;

  function els() {
    return {
      modal:    document.getElementById('search-modal') as HTMLElement | null,
      input:    document.getElementById('search-input') as HTMLInputElement | null,
      results:  document.getElementById('search-results') as HTMLElement | null,
      empty:    document.getElementById('search-empty') as HTMLElement | null,
      hint:     document.getElementById('search-hint') as HTMLElement | null,
      backdrop: document.getElementById('search-backdrop') as HTMLElement | null,
    };
  }

  async function loadPagefind() {
    if (pagefind || pagefindFailed) return;
    if (pagefindLoading) return pagefindLoading;

    pagefindLoading = (async () => {
      try {
        const imp = new Function('p', 'return import(p)');
        pagefind = await imp('/pagefind/pagefind.js');
        await pagefind.options({ excerptLength: 12 });
      } catch {
        pagefindFailed = true;
      }
    })();

    return pagefindLoading;
  }

  function collectionFromUrl(url: string): string {
    if (url.includes('/lab/'))      return 'lab';
    if (url.includes('/archives/')) return 'archives';
    if (url.includes('/gallery/'))  return 'gallery';
    if (url.includes('/library/'))  return 'library';
    if (url.includes('/now'))       return 'now';
    if (url.includes('/seeds'))     return 'seeds';
    if (url.includes('/garden'))    return 'garden';
    return '';
  }

  function escapeHtml(text: string): string {
    return text
      .replace(/&/g, '&amp;')
      .replace(/</g, '&lt;')
      .replace(/>/g, '&gt;')
      .replace(/"/g, '&quot;');
  }

  function displayTitle(item: any): string {
    let title = item.meta?.title ?? '';
    title = title.replace(/\s*(\||[—–-])\s*gianna crisha\s*$/i, '').trim();
    if (!title) {
      const parts = item.url.split('/').filter(Boolean);
      title = parts[parts.length - 1] ?? item.url;
    }
    return title;
  }

  function displayExcerpt(item: any, query: string): string {
    const desc = item.meta?.description?.trim();
    if (desc) {
      const re = new RegExp(`(${query.replace(/[.*+?^${}()|[\]\\]/g, '\\$&')})`, 'gi');
      return escapeHtml(desc).replace(re, '<mark>$1</mark>');
    }
    return item.excerpt ?? '';
  }

  function resultDepth(url: string): number {
    try {
      return new URL(url, location.origin).pathname.split('/').filter(Boolean).length;
    } catch {
      return 0;
    }
  }

  function rankResults(items: any[]): any[] {
    const best = new Map<string, { item: any; depth: number }>();
    for (const item of items) {
      const title = displayTitle(item).toLowerCase();
      const depth = resultDepth(item.url);
      const prev = best.get(title);
      if (!prev || depth > prev.depth) best.set(title, { item, depth });
    }
    return [...best.values()]
      .sort((a, b) => b.depth - a.depth)
      .map(({ item }) => item);
  }

  function open() {
    const { modal, input } = els();
    if (!modal || !input) return;
    modal.hidden = false;
    input.focus();
    document.body.style.overflow = 'hidden';
    loadPagefind();
  }

  function close() {
    const { modal, input, results, empty, hint } = els();
    if (!modal || !input || !results || !empty || !hint) return;
    modal.hidden = true;
    input.value = '';
    results.innerHTML = '';
    empty.hidden = true;
    hint.hidden = false;
    hint.textContent = 'type to search across all collections';
    activeIndex = -1;
    document.body.style.overflow = '';
  }

  // Keep legacy bridge for any external callers
  (window as any).__searchOpen  = open;
  (window as any).__searchClose = close;

  async function doSearch(q: string) {
    const { results, empty, hint } = els();
    if (!results || !empty || !hint) return;

    if (!q.trim()) {
      results.innerHTML = '';
      empty.hidden = true;
      hint.hidden = false;
      hint.textContent = 'type to search across all collections';
      return;
    }

    await loadPagefind();

    if (!pagefind) {
      results.innerHTML = '';
      empty.hidden = true;
      hint.hidden = false;
      hint.textContent = pagefindFailed
        ? 'search index missing — run npm run build'
        : 'loading search index…';
      return;
    }

    hint.hidden = true;
    const res = await pagefind.debouncedSearch(q, {}, 200);
    if (!res) return;

    const items = rankResults(
      await Promise.all(res.results.slice(0, 12).map((r: any) => r.data()))
    ).slice(0, 6);

    if (!items.length) {
      results.innerHTML = '';
      empty.hidden = false;
      return;
    }

    empty.hidden = true;
    activeIndex = -1;
    results.innerHTML = items.map((item: any, i: number) => {
      const col = collectionFromUrl(item.url);
      const title = escapeHtml(displayTitle(item));
      const excerpt = displayExcerpt(item, q.trim());
      return `<a href="${item.url}" class="search-result" role="option" data-index="${i}">
        <div class="search-result-header">
          <span class="search-result-title">${title}</span>
          ${col ? `<span class="search-result-collection">${col}</span>` : ''}
        </div>
        ${excerpt ? `<span class="search-result-excerpt">${excerpt}</span>` : ''}
      </a>`;
    }).join('');
  }

  function moveActive(dir: number) {
    const { results } = els();
    if (!results) return;
    const items = results.querySelectorAll<HTMLElement>('.search-result');
    if (!items.length) return;
    activeIndex = Math.max(0, Math.min(activeIndex + dir, items.length - 1));
    items.forEach((el, i) => el.setAttribute('aria-selected', String(i === activeIndex)));
    items[activeIndex]?.scrollIntoView({ block: 'nearest' });
  }

  function bindEvents() {
    if (bound) return;
    const { modal, input, results, backdrop } = els();
    if (!modal || !input || !results || !backdrop) return;
    bound = true;

    // Nav button + any future triggers — delegation survives script order
    document.addEventListener('click', (e) => {
      const trigger = (e.target as HTMLElement).closest('#nav-search-btn');
      if (!trigger) return;
      e.preventDefault();
      open();
    });

    backdrop.addEventListener('click', close);

    input.addEventListener('input', () => doSearch(input.value));

    input.addEventListener('keydown', (e: KeyboardEvent) => {
      if (e.key === 'Escape') { close(); return; }
      if (e.key === 'ArrowDown') { e.preventDefault(); moveActive(1); return; }
      if (e.key === 'ArrowUp')   { e.preventDefault(); moveActive(-1); return; }
      if (e.key === 'Enter') {
        const items = results.querySelectorAll<HTMLAnchorElement>('.search-result');
        const target = items[activeIndex] ?? items[0];
        if (target) { target.click(); close(); }
      }
    });

    results.addEventListener('click', (e) => {
      const link = (e.target as HTMLElement).closest('a');
      if (link) close();
    });

    document.addEventListener('keydown', (e: KeyboardEvent) => {
      if ((e.metaKey || e.ctrlKey) && e.key === 'k') {
        e.preventDefault();
        modal.hidden ? open() : close();
      }
      if (e.key === 'Escape' && !modal.hidden) close();
    });
  }

  bindEvents();
  document.addEventListener('astro:page-load', bindEvents);
</script>
