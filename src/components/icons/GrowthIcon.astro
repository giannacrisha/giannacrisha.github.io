---
import type { GrowthStage } from '../../config/design';

interface Props {
  stage: GrowthStage;
  size?: number;
  color?: string;
}

const { stage, size = 16, color = 'currentColor' } = Astro.props;
---

{stage === 'dust' && (
  <svg width={size} height={size} viewBox="0 0 16 16" fill="none"
    aria-label="dust — early stage" role="img">
    <circle cx="4"  cy="7"  r="1"   fill={color} opacity="0.35"/>
    <circle cx="9"  cy="4"  r="0.8" fill={color} opacity="0.25"/>
    <circle cx="12" cy="9"  r="1.1" fill={color} opacity="0.3"/>
    <circle cx="6"  cy="12" r="0.7" fill={color} opacity="0.3"/>
    <circle cx="11" cy="3"  r="0.6" fill={color} opacity="0.2"/>
    <circle cx="2"  cy="11" r="0.5" fill={color} opacity="0.2"/>
    <circle cx="13" cy="12" r="0.8" fill={color} opacity="0.2"/>
  </svg>
)}

{stage === 'spark' && (
  <svg width={size} height={size} viewBox="0 0 16 16" fill="none"
    aria-label="spark — in progress" role="img">
    <circle cx="8" cy="8" r="2.5" fill={color} opacity="0.6"/>
    <line x1="8" y1="1"  x2="8" y2="4"  stroke={color} stroke-width="1.2" stroke-linecap="round"/>
    <line x1="8" y1="12" x2="8" y2="15" stroke={color} stroke-width="1.2" stroke-linecap="round"/>
    <line x1="1" y1="8"  x2="4" y2="8"  stroke={color} stroke-width="1.2" stroke-linecap="round"/>
    <line x1="12" y1="8" x2="15" y2="8" stroke={color} stroke-width="1.2" stroke-linecap="round"/>
    <line x1="3"  y1="3"  x2="5" y2="5"   stroke={color} stroke-width="0.8" stroke-linecap="round" opacity="0.6"/>
    <line x1="11" y1="11" x2="13" y2="13" stroke={color} stroke-width="0.8" stroke-linecap="round" opacity="0.6"/>
    <line x1="13" y1="3"  x2="11" y2="5"  stroke={color} stroke-width="0.8" stroke-linecap="round" opacity="0.6"/>
    <line x1="5"  y1="11" x2="3"  y2="13" stroke={color} stroke-width="0.8" stroke-linecap="round" opacity="0.6"/>
  </svg>
)}

{stage === 'star' && (
  <svg width={size} height={size} viewBox="0 0 16 16" fill="none"
    aria-label="star — complete" role="img">
    <circle cx="8" cy="8" r="3" fill={color}/>
    <line x1="8" y1="0.5" x2="8" y2="4"   stroke={color} stroke-width="1.5" stroke-linecap="round"/>
    <line x1="8" y1="12"  x2="8" y2="15.5" stroke={color} stroke-width="1.5" stroke-linecap="round"/>
    <line x1="0.5" y1="8" x2="4" y2="8"   stroke={color} stroke-width="1.5" stroke-linecap="round"/>
    <line x1="12"  y1="8" x2="15.5" y2="8" stroke={color} stroke-width="1.5" stroke-linecap="round"/>
    <line x1="2.5" y1="2.5" x2="4.8" y2="4.8" stroke={color} stroke-width="1.2" stroke-linecap="round"/>
    <line x1="11.2" y1="11.2" x2="13.5" y2="13.5" stroke={color} stroke-width="1.2" stroke-linecap="round"/>
    <line x1="13.5" y1="2.5" x2="11.2" y2="4.8" stroke={color} stroke-width="1.2" stroke-linecap="round"/>
    <line x1="4.8" y1="11.2" x2="2.5" y2="13.5" stroke={color} stroke-width="1.2" stroke-linecap="round"/>
  </svg>
)}
